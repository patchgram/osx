    g_unique_value_info_request_ids[g_unique_value_info_request_head] = request_id;
    g_unique_value_info_request_head = (g_unique_value_info_request_head + 1) % PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS;
    pthread_mutex_unlock(&g_unique_value_info_request_mutex);
}
static bool patchgram_take_unique_value_info_request(int32_t request_id) {
    if (request_id == 0) { return false; }
    bool found = false;
    pthread_mutex_lock(&g_unique_value_info_request_mutex);
    for (int i = 0; i < PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS; i++) {
        if (g_unique_value_info_request_ids[i] == request_id) { g_unique_value_info_request_ids[i] = 0; found = true; break; }
    }
    pthread_mutex_unlock(&g_unique_value_info_request_mutex);
    return found;
}
static bool patchgram_unique_value_info_request_id(void *request_ref, int32_t *out) {
    if (!request_ref) { return false; }
    void *request_data = NULL; memcpy(&request_data, request_ref, sizeof(request_data));
    if (!request_data) { return false; }
    uint32_t *words = NULL; int64_t word_count = 0;
    memcpy(&words, (const uint8_t *)request_data + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&word_count, (const uint8_t *)request_data + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(word_count));
    if (!words || word_count <= PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION) { return false; }
    if (words[PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION] != PATCHGRAM_TL_GET_UNIQUE_STAR_GIFT_VALUE_INFO) { return false; }
    int32_t request_id = 0;
    memcpy(&request_id, (const uint8_t *)request_data + PATCHGRAM_REQUEST_DATA_REQUEST_ID_OFFSET, sizeof(request_id));
    if (request_id == 0) { return false; }
    *out = request_id;
    return true;
}

// Build a fresh payments.uniqueStarGiftValueInfo#512fe446 from the configured value/last-resale (used to
// answer a CONVERTED gift's value request, whose server reply is an error). Returns a malloc'd word
// buffer (caller installs it, Qt-borrowed style; never freed — small, user-triggered) + *wc_out.
static uint32_t *patchgram_build_unique_value_info_reply(int64_t *wc_out) {
    if (wc_out) { *wc_out = 0; }
    const char *currency = g_unique_last_resale_currency[0] ? g_unique_last_resale_currency
                          : (g_unique_value_currency[0] ? g_unique_value_currency : "TON");
    const int has_last = (g_unique_last_resale_amount || g_unique_last_resale_date);
    const int32_t flags = has_last ? 1 : 0;  // flags.0 → last_sale_date + last_sale_price present
    const int32_t initial_date = g_unique_last_resale_date ? g_unique_last_resale_date
                               : (g_unique_date ? g_unique_date : 1700000000);
    const int64_t value = g_unique_value_amount;
    const int64_t init_amount = value ? value : 1;
    size_t byte_count = sizeof(uint32_t)              // ctor
        + sizeof(int32_t)                             // flags
        + patchgram_tl_string_length(currency)        // currency
        + sizeof(int64_t)                             // value
        + sizeof(int32_t)                             // initial_sale_date
        + sizeof(int64_t)                             // initial_sale_stars
        + sizeof(int64_t);                            // initial_sale_price
    if (has_last) { byte_count += sizeof(int32_t) + sizeof(int64_t); }  // last_sale_date + last_sale_price
    const size_t padded = (byte_count + 3U) & ~(size_t)3U;
    uint8_t *buf = (uint8_t *)calloc(padded, 1);
    if (!buf) { return NULL; }
    size_t off = 0;
    patchgram_tl_write_u32(buf, &off, 0x512fe446u);
    patchgram_tl_write_i32(buf, &off, flags);
    patchgram_tl_write_string(buf, &off, currency);
    patchgram_tl_write_i64(buf, &off, value);
    patchgram_tl_write_i32(buf, &off, initial_date);
    patchgram_tl_write_i64(buf, &off, init_amount);
    patchgram_tl_write_i64(buf, &off, init_amount);
    if (has_last) {
        patchgram_tl_write_i32(buf, &off, g_unique_last_resale_date ? g_unique_last_resale_date : initial_date);
        patchgram_tl_write_i64(buf, &off, g_unique_last_resale_amount);
    }
    if (wc_out) { *wc_out = (int64_t)(padded / sizeof(uint32_t)); }
    return (uint32_t *)buf;
}

// One byte-range edit on the response: replace [off, off+oldlen) with `rep` (replen bytes). oldlen==0
// is a pure insert. `rep` points into the caller's scratch / message buffer (alive across the splice).
struct PatchgramGiftEdit { size_t off; size_t oldlen; const uint8_t *rep; size_t replen; };

// Safety net: re-decode a rebuilt savedStarGifts buffer with our own TL decoder and confirm it parses
// cleanly AND consumes exactly `len` bytes. A zeroed rewrite ctx forces the full walk without touching
// the bytes. If any offset/insert in the rebuild desynced the structure this returns false, so the
// caller discards the rebuild instead of handing Qt a malformed buffer (which would crash the client).
static bool patchgram_savedgifts_valid(const uint8_t *buf, size_t len) {
    if (len < 4 || (len & 3u) != 0) { return false; }
    struct PatchgramTLReader r = { buf, len, 0, false };
    char sink = 0;
    struct PatchgramTLOut o = { &sink, 1, 0, true };
    struct PatchgramTLRewrite vrw;
    memset(&vrw, 0, sizeof vrw);
    vrw.base = (uint8_t *)buf;  // all spoof fields are 0 → rewrite_field never writes
    uint32_t top = patchgram_tl_u32(&r);
    if (r.err || top != PATCHGRAM_TL_PAYMENTS_SAVED_STAR_GIFTS) { return false; }
    patchgram_tl_decode_ctor(top, &r, &o, 0, false, &vrw);
    return !r.err && r.pos == len;
}

// Build a brand-new savedStarGifts response with every configured per-gift edit applied
// (supply / limited / upgrade / auction / caption). Returns a malloc'd buffer (caller frees) +
// *out_len, or NULL when there is nothing to change. Unlike a fixed-size in-place overwrite this can
// GROW or SHRINK freely — the caller installs it via a real Qt buffer reallocation, so the sticker is
// left intact and there is no size limit.
static uint8_t *patchgram_gift_build(const uint8_t *old, size_t old_len,
                                     struct PatchgramTLRewrite *rw, bool use_slim, size_t *out_len) {
    const int gc = rw->gift_count;
    if (gc <= 0) { return NULL; }
    const bool want_caption = g_gift_spoof_caption[0] != 0;
    const bool want_limited = g_gift_spoof_force_limited != 0;  // supply is governed by the limited toggle
    const bool want_upgrade = g_gift_spoof_force_upgrade != 0;
    const bool want_auction = g_gift_spoof_force_auction != 0;
    const bool want_subst = g_gift_spoof_sticker_id != 0 && g_captured_emoji_full_len > 0
        && g_captured_emoji_doc_id == g_gift_spoof_sticker_id;
    const uint8_t *subst_doc = use_slim ? g_captured_emoji_slim : g_captured_emoji_full;
    const size_t subst_len = use_slim ? g_captured_emoji_slim_len : g_captured_emoji_full_len;
    if (!want_caption && !want_limited && !want_upgrade && !want_auction && !want_subst) { return NULL; }

    const bool want_title = want_auction && g_gift_spoof_auction_title[0] != 0;
    uint8_t *msg = NULL; size_t msg_len = 0;
    if (want_caption) {
        msg = (uint8_t *)calloc(sizeof(uint32_t) + patchgram_tl_string_length(g_gift_spoof_caption) + 2 * sizeof(uint32_t) + 4, 1);
        if (!msg) { return NULL; }
        patchgram_tl_write_u32(msg, &msg_len, PATCHGRAM_TL_TEXT_WITH_ENTITIES);
        patchgram_tl_write_string(msg, &msg_len, g_gift_spoof_caption);
        patchgram_tl_write_u32(msg, &msg_len, PATCHGRAM_TL_VECTOR_ID);
        patchgram_tl_write_i32(msg, &msg_len, 0);
    }
    // Shared starGift.title bytes (a plain TL string) — reused across every gift.
    uint8_t *titlebuf = NULL; size_t title_len = 0;
    if (want_title) {
        titlebuf = (uint8_t *)calloc(patchgram_tl_string_length(g_gift_spoof_auction_title) + 4, 1);
        if (!titlebuf) { free(msg); return NULL; }
        patchgram_tl_write_string(titlebuf, &title_len, g_gift_spoof_auction_title);
    }

    static const uint8_t empty_vec[8] = { 0x15, 0xc4, 0xb5, 0x1c, 0, 0, 0, 0 }; // vector#1cb5c415 count=0
    const int MAXE = PATCHGRAM_MAX_GIFT_ENTRIES * 12;
    struct PatchgramGiftEdit *edits = (struct PatchgramGiftEdit *)calloc((size_t)MAXE, sizeof(*edits));
    uint8_t *scratch = (uint8_t *)calloc((size_t)gc, 64);  // per-gift inline replacement bytes
    if (!edits || !scratch) { free(edits); free(scratch); free(msg); return NULL; }
    int ne = 0;
    bool ok = true;
    for (int g = 0; g < gc && ok; g++) {
        struct PatchgramGiftEntry *e = &rw->entries[g];
        if (e->sg_flags_off == 0) { continue; }  // no starGift captured (e.g. starGiftUnique) → leave it
        uint8_t *sc = scratch + (size_t)g * 64;
        size_t sp = 0;
        uint32_t sg_new = e->sg_flags;
        uint32_t saved_new = e->saved_flags;

        // sticker — substitute the WHOLE captured custom-emoji Document (consistent id/access_hash/
        // file_reference/stickerset) so the cache isn't corrupted. Skips the thumbs-clear for this gift
        // since the replacement covers the entire document range.
        const bool subst_sticker = want_subst && e->sticker_doc_off && e->sticker_doc_len;
        if (subst_sticker) {
            edits[ne].off = e->sticker_doc_off; edits[ne].oldlen = e->sticker_doc_len;
            edits[ne].rep = subst_doc; edits[ne].replen = subst_len; ne++;
        }

        // limited / supply — insert availability when absent (overwrite-when-present is in-place).
        // Values are verbatim so 0 = sold out is honoured; only total falls back when the user left
        // it 0 but set a remaining count (an X-of-0 gift would be nonsensical).
        if (want_limited && !(e->sg_flags & 0x1u) && e->avail_at) {
            int32_t rem = g_gift_spoof_available;
            int32_t tot = g_gift_spoof_total ? g_gift_spoof_total
                          : (g_gift_spoof_available ? g_gift_spoof_available : 0);
            size_t at = sp;
            patchgram_tl_write_i32(sc, &sp, rem);
            patchgram_tl_write_i32(sc, &sp, tot);
            edits[ne].off = e->avail_at; edits[ne].oldlen = 0; edits[ne].rep = sc + at; edits[ne].replen = sp - at; ne++;
            sg_new |= 0x1u;
        }
        // upgrade — set both savedStarGift.can_upgrade (flag.10) and starGift.upgrade_stars (flag.3)
        if (want_upgrade) {
            saved_new |= (1u << 10);
            if (!(e->sg_flags & 0x8u) && e->upgrade_at) {
                int64_t up = g_gift_spoof_upgrade_price > 0 ? g_gift_spoof_upgrade_price : 25;
                size_t at = sp;
                patchgram_tl_write_i32(sc, &sp, (int32_t)(up & 0xffffffff));
                patchgram_tl_write_i32(sc, &sp, (int32_t)((up >> 32) & 0xffffffff));
                edits[ne].off = e->upgrade_at; edits[ne].oldlen = 0; edits[ne].rep = sc + at; edits[ne].replen = sp - at; ne++;
                sg_new |= 0x8u;
            }
        }
        // NOTE: edits that can land on the SAME offset (several absent optional fields share an insert
        // point) MUST be added in TL declaration order — the stable sort keeps that order, which is
        // exactly the serialization order. starGift: title(f5) before auction_slug(f11); savedStarGift:
        // message(f2) before gift_num(f19); and all starGift fields precede the savedStarGift ones.
        // auction title — replace/insert starGift.title (flag.5) with the configured name
        if (want_title && e->title_off) {
            edits[ne].off = e->title_off; edits[ne].oldlen = e->title_len; edits[ne].rep = titlebuf; edits[ne].replen = title_len; ne++;
            sg_new |= 0x20u;
        }
        // auction — flag.11 + auction_slug + gifts_per_round + auction_start_date
        if (want_auction && !(e->sg_flags & 0x800u) && e->auction_at) {
            size_t at = sp;
            patchgram_tl_write_string(sc, &sp, "auction");
            patchgram_tl_write_i32(sc, &sp, 1);
            patchgram_tl_write_i32(sc, &sp, g_gift_spoof_date ? g_gift_spoof_date : 1700000000);
            edits[ne].off = e->auction_at; edits[ne].oldlen = 0; edits[ne].rep = sc + at; edits[ne].replen = sp - at; ne++;
            sg_new |= 0x800u;
        }
        // caption — replace/insert savedStarGift.message (flag.2)
        if (want_caption && e->msg_off) {
            edits[ne].off = e->msg_off; edits[ne].oldlen = e->msg_len; edits[ne].rep = msg; edits[ne].replen = msg_len; ne++;
            saved_new |= 0x4u;
        }
        // auction gift number — insert savedStarGift.gift_num (flag.19) when absent (present → in-place)
        if (want_auction && g_gift_spoof_gift_num != 0 && !(e->saved_flags & (1u << 19)) && e->gift_num_at) {
            size_t at = sp; patchgram_tl_write_i32(sc, &sp, g_gift_spoof_gift_num);
            edits[ne].off = e->gift_num_at; edits[ne].oldlen = 0; edits[ne].rep = sc + at; edits[ne].replen = sp - at; ne++;
            saved_new |= (1u << 19);
        }
        // flag-word overwrites (same size)
        if (sg_new != e->sg_flags && e->sg_flags_off) {
            size_t at = sp; patchgram_tl_write_u32(sc, &sp, sg_new);
            edits[ne].off = e->sg_flags_off; edits[ne].oldlen = 4; edits[ne].rep = sc + at; edits[ne].replen = 4; ne++;
        }
        if (saved_new != e->saved_flags && e->flags_off) {
            size_t at = sp; patchgram_tl_write_u32(sc, &sp, saved_new);
            edits[ne].off = e->flags_off; edits[ne].oldlen = 4; edits[ne].rep = sc + at; edits[ne].replen = 4; ne++;
        }
        // Free room by emptying ONLY the sticker thumbs (the inline preview). We must NOT touch
        // file_reference — it's required to fetch the sticker/emoji document, and clearing it makes the
        // client fail with FILE_REFERENCE_EXPIRED so the sticker never loads. Thumbs are just the blur
        // placeholder, so the document still loads via its id/access_hash/file_reference/dc_id. Skipped
        // when substituting the whole sticker document (the thumbs offset is inside the replaced range).
        if (!subst_sticker && e->thumbs_len > sizeof(empty_vec)) {
            edits[ne].off = e->thumbs_off; edits[ne].oldlen = e->thumbs_len; edits[ne].rep = empty_vec; edits[ne].replen = sizeof(empty_vec); ne++;
        }
        if (sp > 64 || ne > MAXE - 12) { ok = false; }
    }
    if (!ok || ne == 0) { free(edits); free(scratch); free(msg); return NULL; }

    // Sort edits by offset (insertion sort; small n, already nearly ordered).
    for (int i = 1; i < ne; i++) {
        struct PatchgramGiftEdit key = edits[i];
        int j = i - 1;
        while (j >= 0 && edits[j].off > key.off) { edits[j + 1] = edits[j]; j--; }
        edits[j + 1] = key;
    }
    long long delta = 0;
    for (int i = 0; i < ne; i++) { delta += (long long)edits[i].replen - (long long)edits[i].oldlen; }
    if ((long long)old_len + delta <= 0) { free(edits); free(scratch); free(msg); return NULL; }
    size_t new_len = (size_t)((long long)old_len + delta);
    uint8_t *buf = (uint8_t *)malloc(new_len);
    if (!buf) { free(edits); free(scratch); free(msg); return NULL; }
    size_t src = 0, dst = 0;
    for (int i = 0; i < ne && ok; i++) {
        if (edits[i].off < src || edits[i].off + edits[i].oldlen > old_len) { ok = false; break; }
        size_t gap = edits[i].off - src;
        if (dst + gap + edits[i].replen > new_len) { ok = false; break; }
        memcpy(buf + dst, old + src, gap); dst += gap; src += gap;
        memcpy(buf + dst, edits[i].rep, edits[i].replen); dst += edits[i].replen;
        src += edits[i].oldlen;
    }
    if (ok && src <= old_len && dst + (old_len - src) <= new_len) {
        memcpy(buf + dst, old + src, old_len - src); dst += old_len - src;
    } else {
        ok = false;
    }
    free(edits); free(scratch); free(msg); free(titlebuf);
    if (!ok || dst != new_len) { free(buf); return NULL; }
    // Final guard: only accept the rebuild if it re-decodes cleanly + fully. Discard otherwise so a
    // bad offset can never reach Qt.
    if (!patchgram_savedgifts_valid(buf, dst)) {
        if (g_gift_spoof_logs < 42) { g_gift_spoof_logs++; patchgram_log("GIFT REBUILD discarded: failed self-validation (len=%zu gifts=%d)", dst, gc); }
        free(buf);
        return NULL;
    }
    *out_len = dst;
    return buf;
}

// Install a rebuilt response. We ONLY ever overwrite Qt's own buffer in place and shrink its size
// word — never grow the allocation, never hand Qt a foreign block (a previous version that swapped in
// a hand-rolled QArrayData corrupted the heap). The builder frees room (empties sticker thumbs/
// file_reference) so the rebuilt response fits the original; if it still doesn't fit, we skip it (the
// in-place scalar spoofs from the walk stand) so the client can't crash.
static bool patchgram_gift_writeback(void *response, uint32_t *words, int64_t old_count,
                                     const uint8_t *newbuf, size_t new_len) {
    if (new_len == 0 || (new_len & 3u) != 0) { return false; }
    int64_t new_count = (int64_t)(new_len / sizeof(uint32_t));
    if (new_count <= old_count) {
        memcpy(words, newbuf, new_len);
        memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, &new_count, sizeof(new_count));
        return true;
    }
    if (g_gift_spoof_logs < 41) {
        g_gift_spoof_logs++;
        patchgram_log("GIFT WB skip: rebuilt %lld words > original %lld (not enough room to free) — in-place spoofs only",
                      (long long)new_count, (long long)old_count);
    }
    return false;
}

static void patchgram_gift_apply_rebuild(void *response, uint32_t *words, int64_t word_count,
                                         struct PatchgramTLRewrite *rw) {
    if (rw->gift_count <= 0) { return; }
    const size_t old_len = (size_t)word_count * sizeof(uint32_t);
    // First try the FULL captured sticker doc (with thumbs → detail view renders); if that would grow
    // the response past its original size, fall back to the SLIM (thumbless) doc so it still fits.
    bool used_slim = false;
    size_t new_len = 0;
    uint8_t *buf = patchgram_gift_build((const uint8_t *)words, old_len, rw, false, &new_len);
    if (buf && new_len > old_len) {
        free(buf);
        used_slim = true;
        new_len = 0;
        buf = patchgram_gift_build((const uint8_t *)words, old_len, rw, true, &new_len);
    }
    if (!buf) { return; }  // nothing to rebuild, or discarded by self-validation
    const bool wrote = patchgram_gift_writeback(response, words, word_count, buf, new_len);
    if (g_gift_spoof_logs < 32) {
        g_gift_spoof_logs++;
        patchgram_log("GIFT REBUILD gifts=%d old=%zu new=%zu sticker=%s %s", rw->gift_count, old_len, new_len,
                      used_slim ? "slim" : "full", wrote ? "applied (in-place, validated)" : "skipped");
    }
    free(buf);
}

// Persistence path for the captured emoji document — next to the hook log (inside the app bundle's
// Resources, which the dylib already writes to). Lets the substitution survive a Telegram restart,
// since the emoji is then in the client's disk cache and getCustomEmojiDocuments won't re-fire.
static bool patchgram_emoji_doc_path(char *out, size_t cap) {
    if (!g_log_path[0]) { return false; }
    snprintf(out, cap, "%s", g_log_path);
    char *slash = strrchr(out, '/');
    if (!slash) { return false; }
    snprintf(slash + 1, cap - (size_t)(slash + 1 - out), "PatchgramEmojiDoc.bin");
    return true;
}

static void patchgram_persist_emoji_doc(void) {
    char path[4096];
    if (!patchgram_emoji_doc_path(path, sizeof path)) { return; }
    FILE *f = fopen(path, "wb");
    if (!f) { return; }
    uint64_t flen = g_captured_emoji_full_len, slen = g_captured_emoji_slim_len;
    fwrite(&g_captured_emoji_doc_id, sizeof(g_captured_emoji_doc_id), 1, f);
    fwrite(&flen, sizeof(flen), 1, f);
    fwrite(g_captured_emoji_full, 1, (size_t)flen, f);
    fwrite(&slen, sizeof(slen), 1, f);
    fwrite(g_captured_emoji_slim, 1, (size_t)slen, f);
    fclose(f);
}

// Load the persisted emoji document when the configured sticker id changed (or on first use). Only
// keeps it if its id still matches the configured sticker so a stale file is ignored.
static int64_t g_emoji_doc_loaded_for = -1;
static void patchgram_ensure_emoji_doc_loaded(void) {
    if (g_gift_spoof_sticker_id == g_emoji_doc_loaded_for) { return; }
    g_emoji_doc_loaded_for = g_gift_spoof_sticker_id;
    if (g_captured_emoji_doc_id == g_gift_spoof_sticker_id && g_captured_emoji_full_len > 0) { return; }
    g_captured_emoji_full_len = 0; g_captured_emoji_slim_len = 0;
    if (g_gift_spoof_sticker_id == 0) { return; }
    char path[4096];
    if (!patchgram_emoji_doc_path(path, sizeof path)) { return; }
    FILE *f = fopen(path, "rb");
    if (!f) { return; }
    int64_t id = 0; uint64_t flen = 0, slen = 0;
    const bool ok = fread(&id, sizeof(id), 1, f) == 1
        && fread(&flen, sizeof(flen), 1, f) == 1 && flen > 0 && flen <= sizeof(g_captured_emoji_full)
        && fread(g_captured_emoji_full, 1, (size_t)flen, f) == (size_t)flen
        && fread(&slen, sizeof(slen), 1, f) == 1 && slen > 0 && slen <= sizeof(g_captured_emoji_slim)
        && fread(g_captured_emoji_slim, 1, (size_t)slen, f) == (size_t)slen;
    fclose(f);
    if (ok && id == g_gift_spoof_sticker_id) {
        g_captured_emoji_doc_id = id;
        g_captured_emoji_full_len = (size_t)flen;
        g_captured_emoji_slim_len = (size_t)slen;
        if (g_gift_spoof_logs < 48) { g_gift_spoof_logs++; patchgram_log("EMOJI DOC loaded from disk id=%lld full=%zu slim=%zu", (long long)id, (size_t)flen, (size_t)slen); }
    } else {
        g_captured_emoji_full_len = 0; g_captured_emoji_slim_len = 0;
    }
}

// Store a captured custom-emoji Document (bytes at body[off..off+len)) as the FULL copy + a SLIM copy
// (thumbs emptied). Persists to disk so the substitution survives a Telegram restart.
static void patchgram_store_emoji_doc(const uint8_t *body, size_t off, size_t len, int64_t doc_id) {
    static uint8_t tmp[8192];
    if (len == 0 || len > sizeof(g_captured_emoji_full) || len > sizeof(tmp)) { return; }
    memcpy(tmp, body + off, len);
    // Gift stickers are custom emojis; if the chosen document is a plain sticker
    // (documentAttributeSticker), convert that attribute to documentAttributeCustomEmoji so the gift's
    // detail view (which renders via the custom-emoji path) shows it. Same byte layout when flags==0
    // (no mask_coords) — just a 4-byte ctor swap; skipped otherwise so we never desync the document.
    {
        struct PatchgramTLRewrite frw;
        memset(&frw, 0, sizeof frw);
        frw.base = tmp; frw.find_sticker_attr = 1;
        struct PatchgramTLReader rr = { tmp, len, 0, false };
        char sk = 0; struct PatchgramTLOut oo = { &sk, 1, 0, true };
        const uint32_t tc = patchgram_tl_u32(&rr);
        patchgram_tl_decode_ctor(tc, &rr, &oo, 0, false, &frw);
        if (frw.sticker_attr_off > 0 && frw.sticker_attr_flags == 0 && frw.sticker_attr_off + 4 <= len) {
            uint32_t emoji_ctor = PATCHGRAM_TL_DOC_ATTR_CUSTOM_EMOJI;
            memcpy(tmp + frw.sticker_attr_off, &emoji_ctor, 4);
            if (g_gift_spoof_logs < 48) { g_gift_spoof_logs++; patchgram_log("EMOJI DOC converted documentAttributeSticker -> customEmoji"); }
        }
    }
    body = tmp; off = 0;  // operate on the (possibly converted) copy from here on
    memcpy(g_captured_emoji_full, body + off, len);
    g_captured_emoji_full_len = len;
    g_captured_emoji_slim_len = 0;
    // Find the document's thumbs range (re-decode with a capture ctx + in_sticker=1) and splice it out.
    struct PatchgramGiftEntry de;
    memset(&de, 0, sizeof de);
    struct PatchgramTLRewrite drw;
    memset(&drw, 0, sizeof drw);
    drw.capture = 1; drw.cur = &de; drw.in_sticker = 1; drw.base = (uint8_t *)body;
    struct PatchgramTLReader r2 = { body, off + len, off, false };
    char s2 = 0; struct PatchgramTLOut o2 = { &s2, 1, 0, true };
    const uint32_t c2 = patchgram_tl_u32(&r2);
    patchgram_tl_decode_ctor(c2, &r2, &o2, 0, false, &drw);
    static const uint8_t empty_vec8[8] = { 0x15, 0xc4, 0xb5, 0x1c, 0, 0, 0, 0 };
    if (de.thumbs_off >= off && de.thumbs_len > sizeof(empty_vec8)
        && de.thumbs_off + de.thumbs_len <= off + len) {
        const size_t rel = de.thumbs_off - off;
        const size_t newlen = len - de.thumbs_len + sizeof(empty_vec8);
        if (newlen <= sizeof(g_captured_emoji_slim)) {
            memcpy(g_captured_emoji_slim, body + off, rel);
            memcpy(g_captured_emoji_slim + rel, empty_vec8, sizeof(empty_vec8));
            memcpy(g_captured_emoji_slim + rel + sizeof(empty_vec8),
                   body + off + rel + de.thumbs_len, len - rel - de.thumbs_len);
            g_captured_emoji_slim_len = newlen;
        }
    }
    if (g_captured_emoji_slim_len == 0) {  // no thumbs to drop → slim == full
        memcpy(g_captured_emoji_slim, body + off, len);
        g_captured_emoji_slim_len = len;
    }
    g_captured_emoji_doc_id = doc_id;
    g_emoji_doc_loaded_for = doc_id;
    patchgram_persist_emoji_doc();
    if (g_gift_spoof_logs < 48) {
        g_gift_spoof_logs++;
        patchgram_log("EMOJI DOC captured id=%lld full=%zu slim=%zu (persisted)", (long long)doc_id, g_captured_emoji_full_len, g_captured_emoji_slim_len);
    }
}

// Capture the configured custom-emoji's FULL Document from ANY response that carries it — the reply to
// getCustomEmojiDocuments (bare Vector<Document>, fired when the emoji is shown inline) OR a
// messages.stickerSet (fired when its pack is opened). Uses the generic Document-by-id finder so it
// works regardless of where the document is nested.
static void patchgram_capture_emoji_doc_response(void *response) {
    if (!response || g_gift_spoof_sticker_id == 0) { return; }
    if (g_captured_emoji_doc_id == g_gift_spoof_sticker_id && g_captured_emoji_full_len > 0) { return; }
    uint32_t *words = NULL;
    int64_t word_count = 0;
    memcpy(&words, (const uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&word_count, (const uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(word_count));
    if (!words || word_count < 3) { return; }
    if (words[0] != PATCHGRAM_TL_VECTOR_ID && words[0] != PATCHGRAM_TL_MESSAGES_STICKER_SET) { return; }
    const uint8_t *body = (const uint8_t *)words;
    const size_t bytelen = (size_t)word_count * sizeof(uint32_t);
    struct PatchgramTLReader r = { body, bytelen, 0, false };
    char sink = 0;
    struct PatchgramTLOut o = { &sink, 1, 0, true };
    struct PatchgramTLRewrite vrw;
    memset(&vrw, 0, sizeof vrw);
    vrw.base = (uint8_t *)body;
    vrw.find_doc_id = g_gift_spoof_sticker_id;
    const uint32_t top = patchgram_tl_u32(&r);
    if (top == PATCHGRAM_TL_VECTOR_ID) {
        // Bare Vector<Document> — the vector ctor isn't a schema type, so walk the items directly as
        // boxed values (each call records last_ctor_start, so the finder can mark the matching doc).
        const int32_t count = (int32_t)patchgram_tl_u32(&r);
        if (count < 0 || count > 4096) { return; }
        for (int32_t i = 0; i < count && !r.err && vrw.found_len == 0; i++) {
            patchgram_tl_decode_value(0, PG_TL_BOXED, &r, &o, 0, &vrw);
        }
    } else {
        patchgram_tl_decode_ctor(top, &r, &o, 0, false, &vrw);
    }
    if (vrw.found_len > 0 && vrw.found_off + vrw.found_len <= bytelen) {
        patchgram_store_emoji_doc(body, vrw.found_off, vrw.found_len, g_gift_spoof_sticker_id);
    }
}

// Produce a thumbs-emptied copy of a Document into out[]; returns the new length (0 on failure).
static size_t patchgram_doc_slim(const uint8_t *doc, size_t len, uint8_t *out, size_t outcap) {
    if (len == 0 || len > outcap) { return 0; }
    struct PatchgramGiftEntry de; memset(&de, 0, sizeof de);
    struct PatchgramTLRewrite drw; memset(&drw, 0, sizeof drw);
    drw.capture = 1; drw.cur = &de; drw.in_sticker = 1; drw.base = (uint8_t *)doc;
    struct PatchgramTLReader r = { doc, len, 0, false };
    char s = 0; struct PatchgramTLOut o = { &s, 1, 0, true };
    const uint32_t c = patchgram_tl_u32(&r);
    patchgram_tl_decode_ctor(c, &r, &o, 0, false, &drw);
    static const uint8_t empty_vec8[8] = { 0x15, 0xc4, 0xb5, 0x1c, 0, 0, 0, 0 };
    if (de.thumbs_off > 0 && de.thumbs_len > sizeof(empty_vec8) && de.thumbs_off + de.thumbs_len <= len) {
        const size_t rel = de.thumbs_off;  // offset within `doc` (decode started at 0)
        const size_t newlen = len - de.thumbs_len + sizeof(empty_vec8);
        if (newlen > outcap) { return 0; }
        memcpy(out, doc, rel);
        memcpy(out + rel, empty_vec8, sizeof(empty_vec8));
        memcpy(out + rel + sizeof(empty_vec8), doc + rel + de.thumbs_len, len - rel - de.thumbs_len);
        return newlen;
    }
    memcpy(out, doc, len);
    return len;
}

// Validate that `buf` decodes as a payments.starGifts and consumes exactly `len` bytes.
static bool patchgram_star_gifts_valid(const uint8_t *buf, size_t len) {
    if (len < 4 || (len & 3u)) { return false; }
    struct PatchgramTLReader r = { buf, len, 0, false };
    char sink = 0; struct PatchgramTLOut o = { &sink, 1, 0, true };
    struct PatchgramTLRewrite vrw; memset(&vrw, 0, sizeof vrw); vrw.base = (uint8_t *)buf;
    uint32_t top = patchgram_tl_u32(&r);
    if (r.err || top != PATCHGRAM_TL_PAYMENTS_STAR_GIFTS) { return false; }
    patchgram_tl_decode_ctor(top, &r, &o, 0, false, &vrw);
    return !r.err && r.pos == len;
}

// Inject the configured hidden gifts into a payments.starGifts (available-gifts) response. Appends
// new starGift entries (flags=0, stars=50, convert_stars=43) at the end of the gifts vector and bumps
// its count — writing ONLY into the buffer's existing spare capacity (QArrayData.alloc), never growing
// or reallocating the Qt buffer. If it doesn't fit the capacity, it's skipped (no crash). Each new
// gift's sticker is the captured slim emoji document when available, else a clone of an existing gift's
// sticker with its id swapped to the emoji id (which makes the client fetch + cache that emoji).
static void patchgram_inject_hidden_gifts(void *response) {
    if (!response || !g_show_hidden_gifts_enabled || g_hidden_gift_count <= 0) { return; }
    uint32_t *words = NULL; int64_t word_count = 0;
    memcpy(&words, (const uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&word_count, (const uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(word_count));
    if (!words || word_count < 4) { return; }
    if (words[0] != PATCHGRAM_TL_PAYMENTS_STAR_GIFTS || words[2] != PATCHGRAM_TL_VECTOR_ID) { return; }
    const uint8_t *body = (const uint8_t *)words;
    const size_t old_len = (size_t)word_count * sizeof(uint32_t);

    // One decode pass to find (a) the clone template = first existing gift's sticker document, and
    // (b) where the gifts vector ends (= the `chats` field) — used only as a correctness guard that
    // the buffer really is a well-formed payments.starGifts (= hash, gifts, chats, users).
    struct PatchgramTLRewrite frw; memset(&frw, 0, sizeof frw);
    frw.base = (uint8_t *)body; frw.find_first_doc = 1; frw.find_gifts_end = 1;
    struct PatchgramTLReader r = { body, old_len, 0, false };
    char sk = 0; struct PatchgramTLOut o = { &sk, 1, 0, true };
    const uint32_t top = patchgram_tl_u32(&r);
    patchgram_tl_decode_ctor(top, &r, &o, 0, false, &frw);
    if (frw.found_len == 0 || frw.found_off + frw.found_len > old_len) { return; }
    if (frw.gifts_end_off < 16 || frw.gifts_end_off > old_len) { return; }
    // Insert at the FRONT of the gifts vector so the hidden gifts show first: items begin right after
    // payments.starGifts ctor (w0) + hash (w1) + vector ctor (w2) + count (w3) = byte offset 16.
    const size_t gifts_start = 16;
    static uint8_t tmpl[2048];
    const size_t tmpl_len = patchgram_doc_slim(body + frw.found_off, frw.found_len, tmpl, sizeof tmpl);
    if (tmpl_len < 16) { return; }

    static uint8_t add[PATCHGRAM_MAX_HIDDEN_GIFTS * 1280];
    size_t ap = 0; int injected = 0;
    for (int i = 0; i < g_hidden_gift_count && i < PATCHGRAM_MAX_HIDDEN_GIFTS; i++) {
        const uint8_t *doc = NULL; size_t doclen = 0;
        for (int k = 0; k < PATCHGRAM_MAX_HIDDEN_GIFTS; k++) {
            if (g_hidden_doc_ids[k] == g_hidden_emoji_ids[i] && g_hidden_doc_len[k] > 0) {
                doc = g_hidden_doc_bytes[k]; doclen = g_hidden_doc_len[k]; break;
            }
        }
        static uint8_t clone[2048];
        if (!doc) {  // bootstrap: clone template with the emoji id so the client fetches that emoji
            memcpy(clone, tmpl, tmpl_len);
            memcpy(clone + 8, &g_hidden_emoji_ids[i], 8);  // document.id at +8
            doc = clone; doclen = tmpl_len;
        }
        const size_t need = 4 + 4 + 8 + doclen + 8 + 8;
        if (ap + need > sizeof add) { break; }
        uint32_t sg = PATCHGRAM_TL_STAR_GIFT; memcpy(add + ap, &sg, 4); ap += 4;
        int32_t fl = 0; memcpy(add + ap, &fl, 4); ap += 4;
        memcpy(add + ap, &g_hidden_gift_ids[i], 8); ap += 8;
        memcpy(add + ap, doc, doclen); ap += doclen;
        int64_t stars = 50; memcpy(add + ap, &stars, 8); ap += 8;
        int64_t conv = 43; memcpy(add + ap, &conv, 8); ap += 8;
        injected++;
    }
    if (injected == 0 || (ap & 3u)) { return; }

    const int64_t new_word_count = word_count + (int64_t)(ap / 4);
    void *d = NULL; memcpy(&d, (const uint8_t *)response + PATCHGRAM_QVECTOR_D_OFFSET, sizeof(d));
    int64_t cap = 0; if (d) { memcpy(&cap, (const uint8_t *)d + 8, sizeof(cap)); }
    if (!d || new_word_count > cap) {
        if (g_hidden_gift_logs < 16) { g_hidden_gift_logs++; patchgram_log("HIDDEN GIFTS skip: need %lld words > capacity %lld", (long long)new_word_count, (long long)cap); }
        return;
    }
    // Splice into spare capacity: shift the whole gifts body (existing gifts + chats + users) down by
    // `ap` from the front of the vector, drop the new gift entries into the gap so they come first,
    // bump the gifts count + size word, then validate.
    uint8_t *w = (uint8_t *)words;
    memmove(w + gifts_start + ap, w + gifts_start, old_len - gifts_start);
    memcpy(w + gifts_start, add, ap);
    uint32_t cnt = 0; memcpy(&cnt, w + 12, 4); cnt += (uint32_t)injected; memcpy(w + 12, &cnt, 4);
    if (!patchgram_star_gifts_valid(body, (size_t)new_word_count * sizeof(uint32_t))) {
        // revert: shift the body back up + restore the count (the trailing tail is now stale but the
        // size word is never bumped, so the client still reads the original response).
        memcpy(&cnt, w + 12, 4); cnt -= (uint32_t)injected; memcpy(w + 12, &cnt, 4);
        memmove(w + gifts_start, w + gifts_start + ap, old_len - gifts_start);
        if (g_hidden_gift_logs < 16) { g_hidden_gift_logs++; patchgram_log("HIDDEN GIFTS skip: rebuilt response failed validation"); }
        return;
    }
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, &new_word_count, sizeof(new_word_count));
    if (g_hidden_gift_logs < 16) { g_hidden_gift_logs++; patchgram_log("HIDDEN GIFTS injected=%d new=%lld words (cap=%lld)", injected, (long long)new_word_count, (long long)cap); }
}

// Re-decode a rebuilt help.appConfig buffer and confirm it parses cleanly AND consumes exactly `len`
// bytes (same safety net as the gift injectors). If the splice desynced the structure this returns
// false and the caller reverts instead of handing Qt a malformed buffer.
static bool patchgram_appconfig_valid(const uint8_t *buf, size_t len) {
    if (len < 4 || (len & 3u)) { return false; }
    struct PatchgramTLReader r = { buf, len, 0, false };
    char sink = 0; struct PatchgramTLOut o = { &sink, 1, 0, true };
    struct PatchgramTLRewrite vrw; memset(&vrw, 0, sizeof vrw); vrw.base = (uint8_t *)buf;
    uint32_t top = patchgram_tl_u32(&r);
    if (r.err || top != PATCHGRAM_TL_HELP_APP_CONFIG) { return false; }
    patchgram_tl_decode_ctor(top, &r, &o, 0, false, &vrw);
    return !r.err && r.pos == len;
}

// Raw byte search (no dependency on memmem): does [hay,haylen) contain the bytes [needle,nlen)?
static int patchgram_buf_contains(const uint8_t *hay, size_t haylen, const char *needle, size_t nlen) {
    if (nlen == 0 || haylen < nlen) { return 0; }
    for (size_t i = 0; i + nlen <= haylen; i++) {
        if (memcmp(hay + i, needle, nlen) == 0) { return 1; }
    }
    return 0;
}

// Append one jsonObjectValue { key, jsonNumber(value) } to `out` at byte cursor `ap`; returns new ap.
// TL: jsonObjectValue#c0de1bd9 + key:string(len-prefixed, padded to 4) + jsonNumber#2be0dfa4 + double.
// `ap` is word-aligned on entry, so each 4-byte ctor keeps alignment and the string pad lands right.
static size_t patchgram_appcfg_add_number(uint8_t *out, size_t ap, const char *key, double value) {
    size_t klen = strlen(key);
    uint32_t ctor = PATCHGRAM_TL_JSON_OBJECT_VALUE; memcpy(out + ap, &ctor, 4); ap += 4;
    out[ap++] = (uint8_t)klen; memcpy(out + ap, key, klen); ap += klen;
    while ((ap & 3u) != 0) { out[ap++] = 0; }
    uint32_t nctor = PATCHGRAM_TL_JSON_NUMBER; memcpy(out + ap, &nctor, 4); ap += 4;
    memcpy(out + ap, &value, 8); ap += 8;
    return ap;
}
// Same, but value is jsonString#b71e767a.
static size_t patchgram_appcfg_add_string(uint8_t *out, size_t ap, const char *key, const char *value) {
    size_t klen = strlen(key), vlen = strlen(value);
    uint32_t ctor = PATCHGRAM_TL_JSON_OBJECT_VALUE; memcpy(out + ap, &ctor, 4); ap += 4;
    out[ap++] = (uint8_t)klen; memcpy(out + ap, key, klen); ap += klen;
    while ((ap & 3u) != 0) { out[ap++] = 0; }
    uint32_t sctor = PATCHGRAM_TL_JSON_STRING; memcpy(out + ap, &sctor, 4); ap += 4;
    out[ap++] = (uint8_t)vlen; memcpy(out + ap, value, vlen); ap += vlen;
    while ((ap & 3u) != 0) { out[ap++] = 0; }
    return ap;
}

// Force the account-frozen state by injecting the three freeze_* keys into the help.appConfig response
// before Telegram parses it (Main::Session reads freeze_since_date/until/appeal_url from the app config).
// Layout: help.appConfig#dd18782e { hash:int, config:jsonObject#99c1d49d { value:Vector<jsonObjectValue> } }.
// The jsonObject's items are the LAST bytes of the response, so we append at the buffer end + bump the
// vector count (word 4). since = now ("always today" / activation time); until = a fixed far date.
static void patchgram_apply_account_freeze_response(void *response) {
    if (!response || !g_account_freeze_enabled) { return; }
    uint32_t *words = NULL; int64_t word_count = 0;
    memcpy(&words, (const uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&word_count, (const uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(word_count));
    if (!words || word_count < 5) { return; }
    if (words[0] != PATCHGRAM_TL_HELP_APP_CONFIG
        || words[2] != PATCHGRAM_TL_JSON_OBJECT
        || words[3] != PATCHGRAM_TL_VECTOR_ID) { return; }
    uint8_t *w = (uint8_t *)words;
    const size_t old_len = (size_t)word_count * sizeof(uint32_t);
    // Already frozen server-side (or we already injected) → leave the response untouched.
    if (patchgram_buf_contains(w, old_len, "freeze_since_date", 17)) { return; }

    static uint8_t add[256];
    size_t ap = 0;
    ap = patchgram_appcfg_add_number(add, ap, "freeze_since_date", (double)time(NULL));
    ap = patchgram_appcfg_add_number(add, ap, "freeze_until_date", (double)PATCHGRAM_ACCOUNT_FREEZE_UNTIL);
    ap = patchgram_appcfg_add_string(add, ap, "freeze_appeal_url", "https://t.me/spambot");
    if (ap == 0 || (ap & 3u) || ap > sizeof add) { return; }
    const uint32_t injected = 3;

    const int64_t new_word_count = word_count + (int64_t)(ap / 4);
    void *d = NULL; memcpy(&d, (const uint8_t *)response + PATCHGRAM_QVECTOR_D_OFFSET, sizeof(d));
    int64_t cap = 0; if (d) { memcpy(&cap, (const uint8_t *)d + 8, sizeof(cap)); }
    if (!d || new_word_count > cap) {
        if (g_account_freeze_logs < 8) { g_account_freeze_logs++; patchgram_log("ACCOUNT FREEZE skip: need %lld words > capacity %lld", (long long)new_word_count, (long long)cap); }
        return;
    }
    // Append at the end of the jsonObject vector, bump its count (word 4 / byte 16), validate, publish size.
    memcpy(w + old_len, add, ap);
    uint32_t cnt = 0; memcpy(&cnt, w + 16, 4); cnt += injected; memcpy(w + 16, &cnt, 4);
    if (!patchgram_appconfig_valid(w, (size_t)new_word_count * sizeof(uint32_t))) {
        memcpy(&cnt, w + 16, 4); cnt -= injected; memcpy(w + 16, &cnt, 4);  // revert count; size word never bumped
        if (g_account_freeze_logs < 8) { g_account_freeze_logs++; patchgram_log("ACCOUNT FREEZE skip: rebuilt response failed validation"); }
        return;
    }
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, &new_word_count, sizeof(new_word_count));
    if (g_account_freeze_logs < 8) { g_account_freeze_logs++; patchgram_log("ACCOUNT FREEZE injected since/until/appeal -> %lld words (cap=%lld)", (long long)new_word_count, (long long)cap); }
}

// Clone a Document into `out`, swapping its id to `new_id` and converting a documentAttributeSticker →
// Persist the captured model/symbol docs next to the hook log so they survive a Telegram restart.
static bool patchgram_unique_docs_path(char *out, size_t cap) {
    if (!g_log_path[0]) { return false; }
    snprintf(out, cap, "%s", g_log_path);
    char *slash = strrchr(out, '/');
    if (!slash) { return false; }
    snprintf(slash + 1, cap - (size_t)(slash + 1 - out), "PatchgramUniqueDocs.bin");
    return true;
}
static void patchgram_persist_unique_docs(void) {
    char path[4096];
    if (!patchgram_unique_docs_path(path, sizeof path)) { return; }
    FILE *f = fopen(path, "wb");
    if (!f) { return; }
    for (int i = 0; i < PATCHGRAM_UNIQUE_DOC_SLOTS; i++) {
        if (g_unique_doc_len[i] == 0) { continue; }
        uint16_t len = g_unique_doc_len[i];
        fwrite(&g_unique_doc_ids[i], sizeof(int64_t), 1, f);
        fwrite(&len, sizeof(uint16_t), 1, f);
        fwrite(g_unique_doc_bytes[i], 1, len, f);
    }
    fclose(f);
}
static void patchgram_load_unique_docs(void) {
    static int loaded = 0;
    if (loaded) { return; }
    loaded = 1;
    char path[4096];
    if (!patchgram_unique_docs_path(path, sizeof path)) { return; }
    FILE *f = fopen(path, "rb");
    if (!f) { return; }
    for (int i = 0; i < PATCHGRAM_UNIQUE_DOC_SLOTS; ) {
        int64_t id = 0; uint16_t len = 0;
        if (fread(&id, sizeof(int64_t), 1, f) != 1) { break; }
        if (fread(&len, sizeof(uint16_t), 1, f) != 1) { break; }
        if (len == 0 || len > sizeof(g_unique_doc_bytes[0])) { break; }
        if (fread(g_unique_doc_bytes[i], 1, len, f) != (size_t)len) { break; }
        g_unique_doc_ids[i] = id; g_unique_doc_len[i] = len; i++;
    }
    fclose(f);
}

// Captured real custom-emoji document for `emoji_id`, if we have one. Returns 1 + sets out/out_len.
static int patchgram_unique_captured_doc(int64_t emoji_id, const uint8_t **out, size_t *out_len) {
    if (!emoji_id) { return 0; }
    for (int i = 0; i < PATCHGRAM_UNIQUE_DOC_SLOTS; i++) {
        if (g_unique_doc_ids[i] == emoji_id && g_unique_doc_len[i] > 0) {
            *out = g_unique_doc_bytes[i]; *out_len = g_unique_doc_len[i]; return 1;
        }
    }
    return 0;
}

// Store a captured Document (slimmed + sticker→customEmoji) for `emoji_id` into a free/matching slot.
static void patchgram_unique_store_doc(const uint8_t *body, size_t off, size_t len, int64_t emoji_id) {
    static uint8_t slim[4096];
    size_t slen = patchgram_doc_slim(body + off, len, slim, sizeof slim);
    if (slen == 0 || slen > sizeof(g_unique_doc_bytes[0])) { return; }
    struct PatchgramTLRewrite frw; memset(&frw, 0, sizeof frw); frw.base = slim; frw.find_sticker_attr = 1;
    struct PatchgramTLReader rr = { slim, slen, 0, false }; char sk = 0; struct PatchgramTLOut oo = { &sk, 1, 0, true };
    patchgram_tl_decode_ctor(patchgram_tl_u32(&rr), &rr, &oo, 0, false, &frw);
    if (frw.sticker_attr_off > 0 && frw.sticker_attr_flags == 0 && frw.sticker_attr_off + 4 <= slen) {
        uint32_t ce = PATCHGRAM_TL_DOC_ATTR_CUSTOM_EMOJI; memcpy(slim + frw.sticker_attr_off, &ce, 4);
    }
    int slot = -1;
    // This cache only ever holds the current config's model + symbol docs, so RESERVE a fixed slot for
    // each (model→0, symbol→1). Otherwise, once the 4 slots fill with accumulated/stale docs across
    // sessions, the "first free, else slot 0" fallback pushed BOTH the model and symbol onto slot 0 in
    // the same view — the symbol (captured second) overwrote the model, so the gift rebuilt with the
    // original sticker as its model while the symbol rendered fine.
    if (g_unique_model_emoji_id && emoji_id == g_unique_model_emoji_id) { slot = 0; }
    else if (g_unique_symbol_emoji_id && emoji_id == g_unique_symbol_emoji_id) { slot = 1; }
    if (slot < 0) { for (int i = 0; i < PATCHGRAM_UNIQUE_DOC_SLOTS; i++) { if (g_unique_doc_ids[i] == emoji_id) { slot = i; break; } } }
    if (slot < 0) { for (int i = 0; i < PATCHGRAM_UNIQUE_DOC_SLOTS; i++) { if (g_unique_doc_len[i] == 0) { slot = i; break; } } }
    if (slot < 0) { slot = 0; }
    memcpy(g_unique_doc_bytes[slot], slim, slen);
    g_unique_doc_len[slot] = (uint16_t)slen;
    g_unique_doc_ids[slot] = emoji_id;
    patchgram_persist_unique_docs();  // survive a Telegram restart
    if (g_gift_unique_logs < 48) { g_gift_unique_logs++; patchgram_log("GIFT UNIQUE captured doc id=%lld len=%zu slot=%d", (long long)emoji_id, slen, slot); }
}

// Opportunistically capture the chosen model/symbol documents from a getCustomEmojiDocuments (bare
// Vector<Document>) or messages.stickerSet response, so the next gift rebuild can embed a renderable doc.
static void patchgram_unique_capture_response(void *response) {
    if (!response || !g_gift_unique_enabled) { return; }
    int64_t wanted[2] = { g_unique_model_emoji_id, g_unique_symbol_emoji_id };
    if (!wanted[0] && !wanted[1]) { return; }
    uint32_t *words = NULL; int64_t wc = 0;
    memcpy(&words, (const uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&wc, (const uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(wc));
    if (!words || wc < 3) { return; }
    if (words[0] != PATCHGRAM_TL_VECTOR_ID && words[0] != PATCHGRAM_TL_MESSAGES_STICKER_SET
        && words[0] != PATCHGRAM_TL_STAR_GIFT_UPGRADE_PREVIEW) { return; }
    const uint8_t *body = (const uint8_t *)words; const size_t blen = (size_t)wc * sizeof(uint32_t);
    for (int k = 0; k < 2; k++) {
        const uint8_t *have = NULL; size_t hl = 0;
        if (!wanted[k] || patchgram_unique_captured_doc(wanted[k], &have, &hl)) { continue; }
        struct PatchgramTLReader r = { body, blen, 0, false };
        char s = 0; struct PatchgramTLOut o = { &s, 1, 0, true };
        struct PatchgramTLRewrite vrw; memset(&vrw, 0, sizeof vrw); vrw.base = (uint8_t *)body; vrw.find_doc_id = wanted[k];
        const uint32_t top = patchgram_tl_u32(&r);
        if (top == PATCHGRAM_TL_VECTOR_ID) {
            const int32_t count = (int32_t)patchgram_tl_u32(&r);
            if (count < 0 || count > 4096) { continue; }
            for (int32_t i = 0; i < count && !r.err && vrw.found_len == 0; i++) {
                patchgram_tl_decode_value(0, PG_TL_BOXED, &r, &o, 0, &vrw);
            }
        } else {
            patchgram_tl_decode_ctor(top, &r, &o, 0, false, &vrw);
        }
        if (vrw.found_len > 0 && vrw.found_off + vrw.found_len <= blen) {
            patchgram_unique_store_doc(body, vrw.found_off, vrw.found_len, wanted[k]);
        }
    }
}

// Capture the chosen HIDDEN-gift emoji documents (by id) from a getCustomEmojiDocuments (bare
// Vector<Document>) / messages.stickerSet / starGiftUpgradePreview response into g_hidden_doc_* (slot i ↔
// hidden gift i), so patchgram_inject_hidden_gifts embeds a renderable doc (correct id + access_hash)
// instead of a swapped-id clone of some other gift's sticker (wrong hash → the chosen emoji never renders).
// The autoload appends these ids to the client's getCustomEmojiDocuments, so the docs flow by here.
static void patchgram_capture_hidden_docs(void *response) {
    if (!response || !g_show_hidden_gifts_enabled || g_hidden_gift_count <= 0) { return; }
    uint32_t *words = NULL; int64_t wc = 0;
    memcpy(&words, (const uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&wc, (const uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(wc));
    if (!words || wc < 3) { return; }
    if (words[0] != PATCHGRAM_TL_VECTOR_ID && words[0] != PATCHGRAM_TL_MESSAGES_STICKER_SET
        && words[0] != PATCHGRAM_TL_STAR_GIFT_UPGRADE_PREVIEW) { return; }
    const uint8_t *body = (const uint8_t *)words; const size_t blen = (size_t)wc * sizeof(uint32_t);
    for (int i = 0; i < g_hidden_gift_count && i < PATCHGRAM_MAX_HIDDEN_GIFTS; i++) {
        const int64_t want = g_hidden_emoji_ids[i];
        if (!want || (g_hidden_doc_ids[i] == want && g_hidden_doc_len[i] > 0)) { continue; }  // unset / already have it
        struct PatchgramTLReader r = { body, blen, 0, false };
        char s = 0; struct PatchgramTLOut o = { &s, 1, 0, true };
        struct PatchgramTLRewrite vrw; memset(&vrw, 0, sizeof vrw); vrw.base = (uint8_t *)body; vrw.find_doc_id = want;
        const uint32_t top = patchgram_tl_u32(&r);
        if (top == PATCHGRAM_TL_VECTOR_ID) {
            const int32_t count = (int32_t)patchgram_tl_u32(&r);
            if (count < 0 || count > 4096) { continue; }
            for (int32_t j = 0; j < count && !r.err && vrw.found_len == 0; j++) {
                patchgram_tl_decode_value(0, PG_TL_BOXED, &r, &o, 0, &vrw);
            }
        } else {
            patchgram_tl_decode_ctor(top, &r, &o, 0, false, &vrw);
        }
        if (vrw.found_len == 0 || vrw.found_off + vrw.found_len > blen) { continue; }
        // Slim (drop thumbs) + flip documentAttributeSticker → customEmoji, then store into slot i.
        static uint8_t slim[1024];
        size_t slen = patchgram_doc_slim(body + vrw.found_off, vrw.found_len, slim, sizeof slim);
        if (slen == 0 || slen > sizeof(g_hidden_doc_bytes[0])) { continue; }
        struct PatchgramTLRewrite frw; memset(&frw, 0, sizeof frw); frw.base = slim; frw.find_sticker_attr = 1;
        struct PatchgramTLReader rr = { slim, slen, 0, false }; char sk = 0; struct PatchgramTLOut oo = { &sk, 1, 0, true };
        patchgram_tl_decode_ctor(patchgram_tl_u32(&rr), &rr, &oo, 0, false, &frw);
        if (frw.sticker_attr_off > 0 && frw.sticker_attr_flags == 0 && frw.sticker_attr_off + 4 <= slen) {
            uint32_t ce = PATCHGRAM_TL_DOC_ATTR_CUSTOM_EMOJI; memcpy(slim + frw.sticker_attr_off, &ce, 4);
        }
        memcpy(g_hidden_doc_bytes[i], slim, slen);
        g_hidden_doc_len[i] = (uint16_t)slen;
        g_hidden_doc_ids[i] = want;
        if (g_hidden_gift_logs < 32) { g_hidden_gift_logs++; patchgram_log("HIDDEN GIFT captured doc id=%lld len=%zu slot=%d", (long long)want, slen, i); }
    }
}

// documentAttributeCustomEmoji (so it renders via the custom-emoji path; only when its flags==0). Used to
// turn a regular gift's sticker into the model/pattern documents of a built starGiftUnique. Returns bytes.
static size_t patchgram_clone_doc_emoji(const uint8_t *src, size_t src_len, int64_t new_id,
                                        uint8_t *out, size_t outcap) {
    if (src_len < 16 || src_len > outcap) { return 0; }
    memcpy(out, src, src_len);
    if (new_id) { memcpy(out + 8, &new_id, 8); }  // document#8fd4c4d8: ctor(4) flags(4) id(8)
    struct PatchgramTLRewrite frw; memset(&frw, 0, sizeof frw);
    frw.base = out; frw.find_sticker_attr = 1;
    struct PatchgramTLReader rr = { out, src_len, 0, false };
    char sk = 0; struct PatchgramTLOut oo = { &sk, 1, 0, true };
    const uint32_t tc = patchgram_tl_u32(&rr);
    patchgram_tl_decode_ctor(tc, &rr, &oo, 0, false, &frw);
    if (frw.sticker_attr_off > 0 && frw.sticker_attr_flags == 0 && frw.sticker_attr_off + 4 <= src_len) {
        uint32_t emoji_ctor = PATCHGRAM_TL_DOC_ATTR_CUSTOM_EMOJI;
        memcpy(out + frw.sticker_attr_off, &emoji_ctor, 4);
    }
    return src_len;
}

// Build the model/pattern document for a built unique gift. tdesktop REQUIRES model/pattern
// document->sticker() to be valid (else it drops the whole gift) and renders it by downloading the
// DocumentData directly — so the id must match its access_hash. Prefer a real CAPTURED custom-emoji doc
// for the chosen id (renders the chosen model/symbol); otherwise fall back to the gift's OWN sticker
// UNCHANGED (id NOT swapped) so it actually downloads & renders — the attribute name still shows the
// chosen model/symbol; the visual upgrades to the chosen sticker once that emoji's doc is captured.
static size_t patchgram_unique_attr_doc(int64_t emoji_id, const uint8_t *src_doc, size_t src_doc_len,
                                        uint8_t *out, size_t outcap) {
    const uint8_t *cap = NULL; size_t cap_len = 0;
    if (emoji_id && patchgram_unique_captured_doc(emoji_id, &cap, &cap_len) && cap_len > 0 && cap_len <= outcap) {
        memcpy(out, cap, cap_len);
        return cap_len;
    }
    // Fallback: a SLIM (thumbs-emptied) clone of the gift's own sticker — keeps the blob small so the
    // converted response fits the buffer's spare capacity more often (full clones blew past it).
    static uint8_t slimbuf[4096];
    size_t sl = patchgram_doc_slim(src_doc, src_doc_len, slimbuf, sizeof slimbuf);
    if (sl > 0) { return patchgram_clone_doc_emoji(slimbuf, sl, 0, out, outcap); }
    return patchgram_clone_doc_emoji(src_doc, src_doc_len, 0, out, outcap);
}

static uint32_t patchgram_peer_ctor(int peer_type) {
    return (peer_type == 1) ? PATCHGRAM_TL_PEER_CHANNEL
         : (peer_type == 2) ? PATCHGRAM_TL_PEER_CHAT
         : PATCHGRAM_TL_PEER_USER;
}

#define PATCHGRAM_UNIQUE_BLOB_MAX 16384
// Build a fresh starGiftUnique blob (used to CONVERT a regular gift) from the configured title/num/
// backdrop/model/symbol, cloning `src_doc` (the regular gift's sticker) for the model + pattern document
// fields with their ids swapped to the chosen custom-emoji ids. Returns bytes (0 on overflow).
static size_t patchgram_build_unique_blob(uint8_t *out, size_t outcap, int64_t gift_id,
                                          const uint8_t *src_doc, size_t src_doc_len) {
    size_t p = 0;
#define PG_PUT_U32(v) do { if (p + 4 > outcap) { return 0; } uint32_t _t = (uint32_t)(v); memcpy(out + p, &_t, 4); p += 4; } while (0)
#define PG_PUT_I64(v) do { if (p + 8 > outcap) { return 0; } int64_t _t = (int64_t)(v); memcpy(out + p, &_t, 8); p += 8; } while (0)
#define PG_PUT_STR(s) do { const char *_s = (s); if (p + patchgram_tl_string_length(_s) > outcap) { return 0; } patchgram_tl_write_string(out, &p, _s); } while (0)
    uint32_t uflags = 0;
    if (g_unique_owner_id) { uflags |= (1u << 0); }       // owner_id
    if (g_unique_owner_address[0]) { uflags |= (1u << 2); } // owner_address
    const int have_value = (g_unique_value_amount || g_unique_value_usd || g_unique_value_currency[0]);
    if (have_value) { uflags |= (1u << 8); }              // value_amount + value_currency + value_usd_amount
    if (g_unique_host_id) { uflags |= (1u << 12); }       // host_id
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_UNIQUE);
    PG_PUT_U32(uflags);
    PG_PUT_I64(gift_id ? gift_id : 1);               // id
    PG_PUT_I64(gift_id ? gift_id : 1);               // gift_id
    PG_PUT_STR(g_unique_title[0] ? g_unique_title : "Gift");          // title
    PG_PUT_STR("Patchgram");                                         // slug
    PG_PUT_U32(g_unique_num ? g_unique_num : 1);     // num
    if (g_unique_owner_id) { PG_PUT_U32(patchgram_peer_ctor(g_unique_owner_peer_type)); PG_PUT_I64(g_unique_owner_id); }
    if (g_unique_owner_address[0]) { PG_PUT_STR(g_unique_owner_address); }
    PG_PUT_U32(PATCHGRAM_TL_VECTOR_ID);              // attributes vector
    PG_PUT_U32(3);                                   // model + pattern + backdrop
    // model
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_ATTR_MODEL);
    PG_PUT_U32(0);                                   // flags
    PG_PUT_STR(g_unique_model_name[0] ? g_unique_model_name : "Model");
    { size_t dl = patchgram_unique_attr_doc(g_unique_model_emoji_id, src_doc, src_doc_len, out + p, outcap - p); if (!dl) { return 0; } p += dl; }
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_ATTR_RARITY); PG_PUT_U32(g_unique_model_rarity ? g_unique_model_rarity : 5);
    // pattern (symbol)
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_ATTR_PATTERN);
    PG_PUT_STR(g_unique_symbol_name[0] ? g_unique_symbol_name : "Symbol");
    { size_t dl = patchgram_unique_attr_doc(g_unique_symbol_emoji_id, src_doc, src_doc_len, out + p, outcap - p); if (!dl) { return 0; } p += dl; }
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_ATTR_RARITY); PG_PUT_U32(g_unique_symbol_rarity ? g_unique_symbol_rarity : 5);
    // backdrop
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_ATTR_BACKDROP);
    PG_PUT_STR(g_unique_backdrop_name[0] ? g_unique_backdrop_name : "Backdrop");
    PG_PUT_U32(0);                                   // backdrop_id
    PG_PUT_U32(g_unique_backdrop_center);
    PG_PUT_U32(g_unique_backdrop_edge);
    PG_PUT_U32(g_unique_backdrop_pattern);
    PG_PUT_U32(g_unique_backdrop_text);
    PG_PUT_U32(PATCHGRAM_TL_STAR_GIFT_ATTR_RARITY); PG_PUT_U32(g_unique_backdrop_rarity ? g_unique_backdrop_rarity : 5);
    PG_PUT_U32(g_unique_total_upgraded ? g_unique_total_upgraded : 1);     // availability_issued
    PG_PUT_U32(g_unique_max_upgraded ? g_unique_max_upgraded : 1000);      // availability_total
    // value (flags.8): value_amount(long) + value_currency(string) + value_usd_amount(long), in order
    if (have_value) {
        PG_PUT_I64(g_unique_value_amount);
        PG_PUT_STR(g_unique_value_currency[0] ? g_unique_value_currency : "TON");
        PG_PUT_I64(g_unique_value_usd);
    }
    if (g_unique_host_id) { PG_PUT_U32(patchgram_peer_ctor(g_unique_host_peer_type)); PG_PUT_I64(g_unique_host_id); } // host_id (flags.12)
#undef PG_PUT_U32
#undef PG_PUT_I64
#undef PG_PUT_STR
    return p;
}

// Spoof-profile-unique-gifts rebuild. For an already-unique gift: variable-length name edits
// (title / backdrop / model / symbol) — fixed fields (num, colours, doc ids, rarity, sender, date) were
// written in place by the walk. For a REGULAR gift (convert → unique): replace the whole gift field with
// a freshly-built starGiftUnique. Returns a malloc'd buffer (caller frees) + *out_len, or NULL.
static uint8_t *patchgram_unique_build(const uint8_t *old, size_t old_len,
                                       struct PatchgramTLRewrite *rw, size_t *out_len) {
    const int gc = rw->gift_count;
    if (gc <= 0) { return NULL; }
    const bool want_title = g_unique_title[0] != 0;
    const bool want_bd = g_unique_backdrop_name[0] != 0;
    const bool want_model = g_unique_model_name[0] != 0;
    const bool want_symbol = g_unique_symbol_name[0] != 0;
    // Convert a regular gift only when at least one unique attribute is configured.
    const bool want_convert = g_unique_model_emoji_id || g_unique_symbol_emoji_id || g_unique_has_backdrop
        || g_unique_title[0] || g_unique_num;

    static uint8_t titlebuf[300]; size_t title_len = 0;
    if (want_title) { patchgram_tl_write_string(titlebuf, &title_len, g_unique_title); }
    static uint8_t bdbuf[180]; size_t bd_len = 0;
    if (want_bd) { patchgram_tl_write_string(bdbuf, &bd_len, g_unique_backdrop_name); }
    static uint8_t modelbuf[180]; size_t model_len = 0;
    if (want_model) { patchgram_tl_write_string(modelbuf, &model_len, g_unique_model_name); }
    static uint8_t symbuf[180]; size_t sym_len = 0;
    if (want_symbol) { patchgram_tl_write_string(symbuf, &sym_len, g_unique_symbol_name); }

    static const uint8_t zero8[8] = {0};  // transfer_stars = 0 (free transfer) for the fake-transfer button
    const int MAXE = PATCHGRAM_MAX_GIFT_ENTRIES * 7;
    struct PatchgramGiftEdit *edits = (struct PatchgramGiftEdit *)calloc((size_t)MAXE, sizeof(*edits));
    uint8_t *blobs = (uint8_t *)calloc((size_t)gc, PATCHGRAM_UNIQUE_BLOB_MAX);  // built unique blobs (mode B)
    uint8_t *flagbufs = (uint8_t *)calloc((size_t)gc, 4);  // per-gift rewritten savedStarGift flags (fake transfer)
    if (!edits || !blobs || !flagbufs) { free(edits); free(blobs); free(flagbufs); return NULL; }
    int ne = 0;
    for (int g = 0; g < gc; g++) {
        struct PatchgramGiftEntry *e = &rw->entries[g];
        // Fake transfer: add savedStarGift.transfer_stars (flags.8 = 0) so unique->starsForTransfer >= 0 and
        // tdesktop shows a working Transfer button. Insert at the gift_num position (correct field order for
        // f8) and set the flag bit — only when f8 isn't already present and no field of order >f8 / <f19 is
        // present (else the insert would break field order; skip → no button, no corruption). The rebuild is
        // re-validated below, so a bad insert is discarded rather than applied.
        if (g_fake_transfer_enabled && e->flags_off && e->gift_num_at
            && !(e->saved_flags & (1u << 8))
            && !(e->saved_flags & ((1u << 13) | (1u << 15) | (1u << 16) | (1u << 18)))
            && ne + 2 <= MAXE) {
            uint32_t *fl = (uint32_t *)(flagbufs + (size_t)g * 4);
            *fl = e->saved_flags | (1u << 8);
            edits[ne].off = e->flags_off; edits[ne].oldlen = 4; edits[ne].rep = (const uint8_t *)fl; edits[ne].replen = 4; ne++;
            edits[ne].off = e->gift_num_at; edits[ne].oldlen = 0; edits[ne].rep = zero8; edits[ne].replen = 8; ne++;
        }
        if (e->is_unique) {
            if (want_title && e->u_title_off && e->u_title_len) {
                edits[ne].off = e->u_title_off; edits[ne].oldlen = e->u_title_len; edits[ne].rep = titlebuf; edits[ne].replen = title_len; ne++;
            }
            if (want_bd && e->bd_name_off && e->bd_name_len) {
                edits[ne].off = e->bd_name_off; edits[ne].oldlen = e->bd_name_len; edits[ne].rep = bdbuf; edits[ne].replen = bd_len; ne++;
            }
            if (want_model && e->model_name_off && e->model_name_len) {
                edits[ne].off = e->model_name_off; edits[ne].oldlen = e->model_name_len; edits[ne].rep = modelbuf; edits[ne].replen = model_len; ne++;
            }
            if (want_symbol && e->symbol_name_off && e->symbol_name_len) {
                edits[ne].off = e->symbol_name_off; edits[ne].oldlen = e->symbol_name_len; edits[ne].rep = symbuf; edits[ne].replen = sym_len; ne++;
            }
        } else if (want_convert && e->gift_field_off && e->gift_field_len) {
            // Regular gift → build a starGiftUnique and replace the whole gift field. Model/pattern use
            // minimal custom-emoji docs for the chosen ids; the gift's own sticker is only the fallback
            // when an attribute wasn't chosen.
            const uint8_t *sd = (e->sticker_doc_off && e->sticker_doc_len) ? old + e->sticker_doc_off : (const uint8_t *)"";
            const size_t sdl = (e->sticker_doc_off && e->sticker_doc_len) ? e->sticker_doc_len : 0;
            uint8_t *slot = blobs + (size_t)g * PATCHGRAM_UNIQUE_BLOB_MAX;
            size_t blen = patchgram_build_unique_blob(slot, PATCHGRAM_UNIQUE_BLOB_MAX, 0, sd, sdl);
            if (blen > 0) {
                edits[ne].off = e->gift_field_off; edits[ne].oldlen = e->gift_field_len; edits[ne].rep = slot; edits[ne].replen = blen; ne++;
            }
        }
    }
    if (ne == 0) { free(edits); free(blobs); free(flagbufs); return NULL; }
    for (int i = 1; i < ne; i++) {  // sort by offset
        struct PatchgramGiftEdit key = edits[i]; int j = i - 1;
        while (j >= 0 && edits[j].off > key.off) { edits[j + 1] = edits[j]; j--; }
        edits[j + 1] = key;
    }
    long long delta = 0;
    for (int i = 0; i < ne; i++) { delta += (long long)edits[i].replen - (long long)edits[i].oldlen; }
    if ((long long)old_len + delta <= 0) { free(edits); free(blobs); free(flagbufs); return NULL; }
    size_t new_len = (size_t)((long long)old_len + delta);
    uint8_t *buf = (uint8_t *)malloc(new_len);
    if (!buf) { free(edits); free(blobs); free(flagbufs); return NULL; }
    size_t src = 0, dst = 0; bool ok = true;
    for (int i = 0; i < ne && ok; i++) {
        if (edits[i].off < src || edits[i].off + edits[i].oldlen > old_len) { ok = false; break; }
        size_t gap = edits[i].off - src;
        if (dst + gap + edits[i].replen > new_len) { ok = false; break; }
        memcpy(buf + dst, old + src, gap); dst += gap; src += gap;
        memcpy(buf + dst, edits[i].rep, edits[i].replen); dst += edits[i].replen; src += edits[i].oldlen;
    }
    if (ok && src <= old_len && dst + (old_len - src) <= new_len) {
        memcpy(buf + dst, old + src, old_len - src); dst += old_len - src;
    } else { ok = false; }
    free(edits); free(blobs); free(flagbufs);  // blob bytes already copied into buf
    if (!ok || dst != new_len) { free(buf); return NULL; }
    if (!patchgram_savedgifts_valid(buf, dst)) { free(buf); return NULL; }
    *out_len = dst;
    return buf;
}

// Install a rebuilt unique-gifts response: shrink-in-place, or grow only into the buffer's existing
// spare capacity (QArrayData.alloc) — never reallocate Qt's buffer. Skips (keeping the in-place spoofs)
// if it doesn't fit, so the client can't crash.
static bool patchgram_unique_writeback(void *response, uint32_t *words, int64_t old_count,
                                       const uint8_t *newbuf, size_t new_len) {
    if (new_len == 0 || (new_len & 3u) != 0) { return false; }
    int64_t new_count = (int64_t)(new_len / sizeof(uint32_t));
    if (new_count <= old_count) {
        memcpy(words, newbuf, new_len);
        memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, &new_count, sizeof(new_count));
        return true;
    }
    // Grow only into the buffer's existing spare capacity (QArrayData.alloc at d+8). The `d` field is
    // ONLY a real QArrayData header when this is an owned QList; some responses carry a borrowed/raw
    // vector whose `d` holds a non-pointer value (observed garbage like 0x1c13… → deref crashed). Validate
    // before touching d+8: `d` must be an aligned heap pointer AND `words` (the data) must sit just past
    // the header (Qt6 QArrayData is 16 bytes; data follows, aligned) — true only for a genuine owned d.
    // If it doesn't hold, skip the grow (the in-place scalar spoofs from the walk still stand). No crash.
    void *d = NULL; memcpy(&d, (const uint8_t *)response + PATCHGRAM_QVECTOR_D_OFFSET, sizeof(d));
    const uintptr_t dp = (uintptr_t)d;
    const uintptr_t wp = (uintptr_t)words;
    const uintptr_t data_off = (wp > dp) ? (wp - dp) : 0;  // data sits just past the QArrayData header
    const bool d_sane = d && (dp & 7u) == 0 && dp >= 0x1000u && dp < 0x0001000000000000ULL
                        && data_off >= 16 && data_off <= 64;
    if (d_sane) {
        int64_t cap = 0; memcpy(&cap, (const uint8_t *)d + 8, sizeof(cap));
        if (cap >= new_count && cap < (1 << 28)) {
            memcpy(words, newbuf, new_len);
            memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, &new_count, sizeof(new_count));
            return true;
        }
    }
    if (g_gift_unique_logs < 16) { g_gift_unique_logs++; patchgram_log("GIFT UNIQUE WB skip: rebuilt %lld words > old %lld (d=%p dataOff=%lu sane=%d) — in-place only", (long long)new_count, (long long)old_count, d, (unsigned long)data_off, (int)d_sane); }
    return false;
}

// ===================== Fake transfer (binary.gifts.fake_transfer) =====================
// Captures the recipient peer from each payments.transferStarGift request, then replaces the
// (consumed-once) Updates response with a fabricated `updates` carrying a transferred
// messageActionStarGiftUnique service message in the recipient's chat. pts=0/pts_count=0 + seq=0 make it
// apply immediately (no gap check, no getDifference). Nothing is sent server-side; local-only.
#define PATCHGRAM_TL_TRANSFER_STAR_GIFT 0x7f18176au
#define PATCHGRAM_TL_INPUT_SAVED_GIFT_USER 0x69279795u
#define PATCHGRAM_TL_INPUT_SAVED_GIFT_CHAT 0xf101aa7fu
#define PATCHGRAM_TL_INPUT_SAVED_GIFT_SLUG 0x2085c238u
#define PATCHGRAM_TL_INPUT_PEER_USER_FULL 0xdde8a54cu
#define PATCHGRAM_TL_INPUT_PEER_CHANNEL_FULL 0x27bcbbfcu
#define PATCHGRAM_TL_INPUT_PEER_CHAT_FULL 0x35a95cb9u
#define PATCHGRAM_TL_UPDATES 0x74ae4240u
#define PATCHGRAM_TL_UPDATE_NEW_MESSAGE 0x1f2b0afdu
#define PATCHGRAM_TL_MESSAGE_SERVICE 0x7a800e0au
#define PATCHGRAM_TL_MSG_ACTION_STAR_GIFT_UNIQUE 0xe6c31522u

// A sticker Document captured from the gift list — used as the model/pattern fallback when building the
// gift inside the transfer message, so it renders (tdesktop requires model/pattern document->sticker()).
static uint8_t g_transfer_src_doc[4096];
static size_t g_transfer_src_doc_len = 0;
static int g_fake_transfer_logs = 0;
// Distinct message id per fake transfer so re-transferring (same peer) doesn't collide with a previous
// fake message (same id → tdesktop dedups/replaces it). High base keeps it above real msg ids.
static uint32_t g_fake_transfer_msg_seq = 0;

struct PatchgramTransferReq { int32_t request_id; int peer_type; int64_t peer_id; };
static struct PatchgramTransferReq g_transfer_reqs[PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS] = {0};
static int g_transfer_req_head = 0;
static pthread_mutex_t g_transfer_req_mutex = PTHREAD_MUTEX_INITIALIZER;
static void patchgram_track_transfer_req(int32_t id, int pt, int64_t pid) {
    if (id == 0) { return; }
    pthread_mutex_lock(&g_transfer_req_mutex);
    g_transfer_reqs[g_transfer_req_head].request_id = id;
    g_transfer_reqs[g_transfer_req_head].peer_type = pt;
    g_transfer_reqs[g_transfer_req_head].peer_id = pid;
    g_transfer_req_head = (g_transfer_req_head + 1) % PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS;
    pthread_mutex_unlock(&g_transfer_req_mutex);
}
static bool patchgram_take_transfer_req(int32_t id, int *pt, int64_t *pid) {
    if (id == 0) { return false; }
    bool found = false;
    pthread_mutex_lock(&g_transfer_req_mutex);
    for (int i = 0; i < PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS; i++) {
        if (g_transfer_reqs[i].request_id == id) {
            *pt = g_transfer_reqs[i].peer_type; *pid = g_transfer_reqs[i].peer_id;
            g_transfer_reqs[i].request_id = 0; found = true; break;
        }
    }
    pthread_mutex_unlock(&g_transfer_req_mutex);
    return found;
}

// Advance `*off` past one InputPeer (the fixed-size variants we expect). False on unknown → caller bails.
static bool patchgram_skip_input_peer(const uint8_t *b, size_t len, size_t *off) {
    if (*off + 4 > len) { return false; }
    uint32_t c; memcpy(&c, b + *off, 4); *off += 4;
    switch (c) {
        case PATCHGRAM_TL_INPUT_PEER_SELF: return true;                       // no fields
        case PATCHGRAM_TL_INPUT_PEER_CHAT_FULL: *off += 8; return *off <= len;    // chat_id
        case PATCHGRAM_TL_INPUT_PEER_USER_FULL:                               // user_id + access_hash
        case PATCHGRAM_TL_INPUT_PEER_CHANNEL_FULL: *off += 16; return *off <= len; // channel_id + access_hash
        default: return false;
    }
}

// Parse a payments.transferStarGift request → recipient (peer_type 0 user / 1 channel / 2 chat, peer_id)
// + request id. False on anything unexpected (then no fake is attempted).
static bool patchgram_transfer_request_peer(void *request_ref, int32_t *id_out, int *pt_out, int64_t *pid_out) {
    if (!request_ref) { return false; }
    void *request_data = NULL; memcpy(&request_data, request_ref, sizeof(request_data));
    if (!request_data) { return false; }
    uint32_t *words = NULL; int64_t wc = 0;
    memcpy(&words, (const uint8_t *)request_data + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&wc, (const uint8_t *)request_data + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(wc));
    if (!words || wc <= PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION) { return false; }
    if (words[PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION] != PATCHGRAM_TL_TRANSFER_STAR_GIFT) { return false; }
    const uint8_t *b = (const uint8_t *)(words + PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION);
    size_t len = (size_t)(wc - PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION) * sizeof(uint32_t);
    size_t off = 4;  // past the transferStarGift ctor
    if (off + 4 > len) { return false; }
    uint32_t sg; memcpy(&sg, b + off, 4); off += 4;          // stargift: InputSavedStarGift
    if (sg == PATCHGRAM_TL_INPUT_SAVED_GIFT_USER) { off += 4; }                                    // msg_id:int
    else if (sg == PATCHGRAM_TL_INPUT_SAVED_GIFT_CHAT) { if (!patchgram_skip_input_peer(b, len, &off)) { return false; } off += 8; }  // peer + saved_id
    else if (sg == PATCHGRAM_TL_INPUT_SAVED_GIFT_SLUG) { if (!patchgram_tl_skip_string(b, len, &off)) { return false; } }
    else { return false; }
    if (off + 4 > len) { return false; }
    uint32_t pc; memcpy(&pc, b + off, 4); off += 4;          // to_id: InputPeer
    int64_t pid = 0; int pt = 0;
    if (pc == PATCHGRAM_TL_INPUT_PEER_USER_FULL) { pt = 0; if (off + 8 > len) { return false; } memcpy(&pid, b + off, 8); }
    else if (pc == PATCHGRAM_TL_INPUT_PEER_CHANNEL_FULL) { pt = 1; if (off + 8 > len) { return false; } memcpy(&pid, b + off, 8); }
    else if (pc == PATCHGRAM_TL_INPUT_PEER_CHAT_FULL) { pt = 2; if (off + 8 > len) { return false; } memcpy(&pid, b + off, 8); }
    else if (pc == PATCHGRAM_TL_INPUT_PEER_SELF) { pt = 0; pid = (int64_t)g_self_user_id; }
    else { return false; }
    if (pid == 0) { return false; }
    int32_t rid = 0; memcpy(&rid, (const uint8_t *)request_data + PATCHGRAM_REQUEST_DATA_REQUEST_ID_OFFSET, sizeof(rid));
    if (rid == 0) { return false; }
    *id_out = rid; *pt_out = pt; *pid_out = pid;
    return true;
}

// Build the fabricated `updates` with a transferred service message in the recipient's chat. Returns a
// malloc'd word buffer (caller installs Qt-borrowed; never freed — small, user-triggered) + *wc_out, or
// NULL when the message gift couldn't be built (no renderable model/pattern doc → no fake, error shows).
static uint32_t *patchgram_build_transfer_updates(int peer_type, int64_t peer_id, int32_t now, int64_t *wc_out) {
    if (wc_out) { *wc_out = 0; }
    static uint8_t giftblob[PATCHGRAM_UNIQUE_BLOB_MAX];
    size_t glen = patchgram_build_unique_blob(giftblob, sizeof giftblob, 0, g_transfer_src_doc, g_transfer_src_doc_len);
    if (glen == 0) { return NULL; }
    const uint32_t peer_ctor = patchgram_peer_ctor(peer_type);
    const int have_self = (g_self_user_id != 0);
    const size_t cap = glen + 256;
    uint8_t *out = (uint8_t *)calloc(cap, 1);
    if (!out) { return NULL; }
    size_t p = 0;
#define PG_PUT_U32(v) do { if (p + 4 > cap) { free(out); return NULL; } uint32_t _t=(uint32_t)(v); memcpy(out+p,&_t,4); p+=4; } while(0)
#define PG_PUT_I64(v) do { if (p + 8 > cap) { free(out); return NULL; } int64_t _t=(int64_t)(v); memcpy(out+p,&_t,8); p+=8; } while(0)
#define PG_PUT_BLOB(s,n) do { if (p + (n) > cap) { free(out); return NULL; } memcpy(out+p,(s),(n)); p+=(n); } while(0)
    PG_PUT_U32(PATCHGRAM_TL_UPDATES);                 // updates#74ae4240
    PG_PUT_U32(PATCHGRAM_TL_VECTOR_ID); PG_PUT_U32(1);// updates: Vector<Update> count=1
    PG_PUT_U32(PATCHGRAM_TL_UPDATE_NEW_MESSAGE);      // updateNewMessage
    // message: messageService#7a800e0a
    {
        uint32_t mflags = (1u << 1);                  // out
        if (have_self) { mflags |= (1u << 8); }       // from_id
        PG_PUT_U32(PATCHGRAM_TL_MESSAGE_SERVICE);
        PG_PUT_U32(mflags);
        PG_PUT_U32(0x70000000u + (g_fake_transfer_msg_seq++ & 0x0fffffffu)); // unique high local-only id
        if (have_self) { PG_PUT_U32(PATCHGRAM_TL_PEER_USER); PG_PUT_I64((int64_t)g_self_user_id); } // from_id
        PG_PUT_U32(peer_ctor); PG_PUT_I64(peer_id);   // peer_id (recipient)
        PG_PUT_U32((uint32_t)now);                    // date
        // action: messageActionStarGiftUnique#e6c31522
        uint32_t aflags = (1u << 1) | (1u << 7);      // transferred + peer/saved_id
        if (have_self) { aflags |= (1u << 6); }       // from_id
        PG_PUT_U32(PATCHGRAM_TL_MSG_ACTION_STAR_GIFT_UNIQUE);
        PG_PUT_U32(aflags);
        PG_PUT_BLOB(giftblob, glen);                  // gift: StarGift
        if (have_self) { PG_PUT_U32(PATCHGRAM_TL_PEER_USER); PG_PUT_I64((int64_t)g_self_user_id); } // from_id (f6)
        PG_PUT_U32(peer_ctor); PG_PUT_I64(peer_id);   // peer (f7)
        PG_PUT_I64(0);                                 // saved_id (f7)
    }
    PG_PUT_U32(0);                                     // pts (0 + count 0 → applied without gap check)
    PG_PUT_U32(0);                                     // pts_count
    PG_PUT_U32(PATCHGRAM_TL_VECTOR_ID); PG_PUT_U32(0); // users (empty)
    PG_PUT_U32(PATCHGRAM_TL_VECTOR_ID); PG_PUT_U32(0); // chats (empty)
    PG_PUT_U32((uint32_t)now);                         // date
    PG_PUT_U32(0);                                     // seq (0 → skip the seq gate)
#undef PG_PUT_U32
#undef PG_PUT_I64
#undef PG_PUT_BLOB
    if (p & 3u) { free(out); return NULL; }
    if (wc_out) { *wc_out = (int64_t)(p / sizeof(uint32_t)); }
    return (uint32_t *)out;
}

static void patchgram_apply_transfer_response(void *response) {
    if (!response || !g_fake_transfer_enabled) { return; }
    int32_t request_id = 0;
    memcpy(&request_id, (const uint8_t *)response + PATCHGRAM_RESPONSE_REQUEST_ID_OFFSET, sizeof(request_id));
    int pt = 0; int64_t pid = 0;
    if (!patchgram_take_transfer_req(request_id, &pt, &pid)) { return; }  // only OUR transferStarGift
    int32_t now = (int32_t)time(NULL);
    int64_t wc = 0;
    uint32_t *reply = patchgram_build_transfer_updates(pt, pid, now, &wc);
    if (!reply || wc <= 0) { free(reply); return; }
    void *data_header = NULL;  // Qt-borrowed buffer (consumed once via applyUpdates), like fragment phone
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_D_OFFSET, &data_header, sizeof(data_header));
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, &reply, sizeof(reply));

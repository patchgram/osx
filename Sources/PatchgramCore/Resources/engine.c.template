- (void)loadState {
    self.buttonFx = 0.5; self.buttonFy = 0.5;
    self.rainFx = 0.37; self.rainFy = 0.05; self.rainFw = 0.30; self.rainFh = 0.90;
    self.rainSizeMul = 1.0;
    self.rainStyle = 0;
    self.rainSpeed = 1.0;
    self.rainOpacity = 1.0;
    self.autoRegion = NO;
    NSDictionary *d = [NSDictionary dictionaryWithContentsOfFile:patchgram_overlay_state_path()];
    if (d) {
        patchgram_overlay_animation_on = [d[@"animation"] boolValue];
        NSString *p = d[@"png"];
        patchgram_overlay_png_path = (p.length > 0) ? p : nil;
        if (d[@"buttonFx"]) self.buttonFx = [d[@"buttonFx"] doubleValue];
        if (d[@"buttonFy"]) self.buttonFy = [d[@"buttonFy"] doubleValue];
        if (d[@"rainFx"]) self.rainFx = [d[@"rainFx"] doubleValue];
        if (d[@"rainFy"]) self.rainFy = [d[@"rainFy"] doubleValue];
        if (d[@"rainFw"]) self.rainFw = [d[@"rainFw"] doubleValue];
        if (d[@"rainFh"]) self.rainFh = [d[@"rainFh"] doubleValue];
        if (d[@"rainSizeMul"]) self.rainSizeMul = [d[@"rainSizeMul"] doubleValue];
        if (d[@"rainStyle"]) self.rainStyle = (int)[d[@"rainStyle"] integerValue];
        if (d[@"rainSpeed"]) self.rainSpeed = [d[@"rainSpeed"] doubleValue];
        if (d[@"rainOpacity"]) self.rainOpacity = [d[@"rainOpacity"] doubleValue];
        if (d[@"autoRegion"]) self.autoRegion = [d[@"autoRegion"] boolValue];
    }
    if (self.rainOpacity < 0.1 || self.rainOpacity > 1.0) self.rainOpacity = 1.0;
    if (self.rainSizeMul < 0.2 || self.rainSizeMul > 3.0) self.rainSizeMul = 1.0;
    if (self.rainStyle < 0 || self.rainStyle > 3) self.rainStyle = 0;
    if (self.rainSpeed < 0.25 || self.rainSpeed > 3.0) self.rainSpeed = 1.0;
    patchgram_log("OVERLAY state loaded animation=%d png=%s btn=(%.2f,%.2f)",
        (int)patchgram_overlay_animation_on,
        patchgram_overlay_png_path ? patchgram_overlay_png_path.UTF8String : "(none)",
        self.buttonFx, self.buttonFy);
}

- (void)saveState {
    NSDictionary *d = @{ @"animation": @(patchgram_overlay_animation_on),
                         @"png": (patchgram_overlay_png_path ?: @""),
                         @"buttonFx": @(self.buttonFx), @"buttonFy": @(self.buttonFy),
                         @"rainFx": @(self.rainFx), @"rainFy": @(self.rainFy),
                         @"rainFw": @(self.rainFw), @"rainFh": @(self.rainFh),
                         @"rainSizeMul": @(self.rainSizeMul), @"rainStyle": @(self.rainStyle),
                         @"rainSpeed": @(self.rainSpeed), @"autoRegion": @(self.autoRegion),
                         @"rainOpacity": @(self.rainOpacity) };
    BOOL ok = [d writeToFile:patchgram_overlay_state_path() atomically:YES];
    patchgram_log("OVERLAY state saved ok=%d", (int)ok);
}

- (NSWindow *)findHostWindow {
    NSWindow *main = NSApp.mainWindow ?: NSApp.keyWindow;
    if (main && main != self.buttonWindow && main != self.panelWindow && main != self.animWindow) return main;
    NSWindow *largest = nil; CGFloat area = 0;
    for (NSWindow *w in NSApp.windows) {
        if (w == self.buttonWindow || w == self.panelWindow || w == self.animWindow || !w.isVisible) continue;
        CGFloat a = w.frame.size.width * w.frame.size.height;
        if (a > area) { area = a; largest = w; }
    }
    return largest;
}

- (NSTextField *)labelWithText:(NSString *)t frame:(NSRect)f {
    NSTextField *l = [[NSTextField alloc] initWithFrame:f];
    l.stringValue = t; l.editable = NO; l.bordered = NO; l.bezeled = NO;
    l.drawsBackground = NO; l.textColor = [NSColor whiteColor];
    l.font = [NSFont systemFontOfSize:14 weight:NSFontWeightMedium];
    return l;
}

- (NSPanel *)makeChildPanel:(NSRect)rect ignoresMouse:(BOOL)ignore {
    NSPanel *p = [[NSPanel alloc] initWithContentRect:rect
        styleMask:(NSWindowStyleMaskBorderless | NSWindowStyleMaskNonactivatingPanel)
        backing:NSBackingStoreBuffered defer:NO];
    p.opaque = NO; p.backgroundColor = [NSColor clearColor]; p.hasShadow = NO;
    p.hidesOnDeactivate = NO; p.floatingPanel = YES; p.becomesKeyOnlyIfNeeded = YES;
    p.ignoresMouseEvents = ignore;
    return p;
}

- (void)buildAnim {
    NSRect hf = self.host.frame;
    self.animWindow = [self makeChildPanel:NSMakeRect(0, 0, hf.size.width, hf.size.height) ignoresMouse:YES];
    self.animWindow.contentView.wantsLayer = YES;
    [self.host addChildWindow:self.animWindow ordered:NSWindowAbove];
    [self.animWindow orderOut:nil];
}

- (void)buildButton {
    NSRect r = NSMakeRect(0, 0, 52, 52);
    self.buttonWindow = [self makeChildPanel:r ignoresMouse:NO];
    PatchgramLogoButton *b = [[PatchgramLogoButton alloc] initWithFrame:r];
    b.overlay = self;
    self.logoButton = b;
    [self.buttonWindow.contentView addSubview:b];
    [self.host addChildWindow:self.buttonWindow ordered:NSWindowAbove];
    [self.buttonWindow orderFront:nil];
}

- (void)buildDim {
    NSRect hf = self.host.frame;
    self.dimWindow = [self makeChildPanel:NSMakeRect(0, 0, hf.size.width, hf.size.height) ignoresMouse:YES];
    self.dimWindow.contentView.wantsLayer = YES;
    self.dimWindow.contentView.layer.backgroundColor = [[NSColor colorWithWhite:0.0 alpha:0.5] CGColor];
    [self.host addChildWindow:self.dimWindow ordered:NSWindowAbove];
    [self.dimWindow orderOut:nil];
}

- (void)buildRegion {
    NSRect hf = self.host.frame;
    NSRect rf = NSMakeRect(0, 0, self.rainFw * hf.size.width, self.rainFh * hf.size.height);
    self.regionWindow = [self makeChildPanel:rf ignoresMouse:NO];
    self.regionWindow.contentView.autoresizesSubviews = YES;
    PatchgramRegionView *v = [[PatchgramRegionView alloc] initWithFrame:NSMakeRect(0, 0, rf.size.width, rf.size.height)];
    v.autoresizingMask = NSViewWidthSizable | NSViewHeightSizable;   // track the window live during resize/move
    v.overlay = self;
    self.regionView = v;
    [self.regionWindow.contentView addSubview:v];
    [self.host addChildWindow:self.regionWindow ordered:NSWindowAbove];
    [self.regionWindow orderOut:nil];
}

- (void)regionDidChange {
    NSRect hf = self.host.frame;
    NSRect rf = self.regionWindow.frame;
    if (hf.size.width <= 0 || hf.size.height <= 0) return;
    self.rainFx = (rf.origin.x - hf.origin.x) / hf.size.width;
    self.rainFy = (rf.origin.y - hf.origin.y) / hf.size.height;
    self.rainFw = rf.size.width / hf.size.width;
    self.rainFh = rf.size.height / hf.size.height;
    [self saveState];
    [self updateRain];
}

// Small centered menu window — controls live directly in its content view (this layout
// receives clicks reliably; a full-host non-activating panel does not).
- (void)buildPanel {
    NSRect hf = self.host.frame;
    NSRect r = NSMakeRect(hf.origin.x + (hf.size.width - 360) / 2.0, hf.origin.y + (hf.size.height - 420) / 2.0, 360, 420);
    self.panelWindow = [self makeChildPanel:r ignoresMouse:NO];
    self.panelWindow.movableByWindowBackground = YES;   // drag the menu by its background
    NSView *content = self.panelWindow.contentView;
    content.wantsLayer = YES;
    content.layer.backgroundColor = [[NSColor colorWithWhite:0.16 alpha:0.92] CGColor]; // dark-gray, less transparent
    content.layer.cornerRadius = 16;
    content.layer.borderWidth = 1.0;
    content.layer.borderColor = [[NSColor colorWithWhite:1.0 alpha:0.12] CGColor];

    NSButton *close = [[NSButton alloc] initWithFrame:NSMakeRect(r.size.width - 36, r.size.height - 36, 28, 28)];
    close.bezelStyle = NSBezelStyleCircular; close.bordered = NO; close.title = @"";
    if (@available(macOS 11.0, *)) { close.image = [NSImage imageWithSystemSymbolName:@"xmark.circle.fill" accessibilityDescription:@"Close"]; close.contentTintColor = [NSColor whiteColor]; }
    else close.title = @"x";
    close.target = self; close.action = @selector(closeTapped:);
    [content addSubview:close];

    [content addSubview:[self labelWithText:@"Animation" frame:NSMakeRect(24, 358, 160, 22)]];
    NSSwitch *sw = [[NSSwitch alloc] initWithFrame:NSMakeRect(r.size.width - 24 - 46, 354, 46, 28)];
    sw.state = patchgram_overlay_animation_on ? NSControlStateValueOn : NSControlStateValueOff;
    sw.target = self; sw.action = @selector(animToggled:);
    self.animSwitch = sw;
    [content addSubview:sw];

    [content addSubview:[self labelWithText:@"Auto (follow profile)" frame:NSMakeRect(24, 314, 230, 22)]];
    NSSwitch *au = [[NSSwitch alloc] initWithFrame:NSMakeRect(r.size.width - 24 - 46, 310, 46, 28)];
    au.state = self.autoRegion ? NSControlStateValueOn : NSControlStateValueOff;
    au.target = self; au.action = @selector(autoToggled:);
    self.autoSwitch = au;
    [content addSubview:au];

    [content addSubview:[self labelWithText:@"Style" frame:NSMakeRect(24, 274, 50, 22)]];
    NSSegmentedControl *seg = [[NSSegmentedControl alloc] initWithFrame:NSMakeRect(76, 270, 260, 26)];
    seg.segmentCount = 4;
    [seg setLabel:@"Rain" forSegment:0];
    [seg setLabel:@"Snow" forSegment:1];
    [seg setLabel:@"Float" forSegment:2];
    [seg setLabel:@"Burst" forSegment:3];
    [seg setSelectedSegment:(self.rainStyle >= 0 && self.rainStyle < 4) ? self.rainStyle : 0];
    seg.target = self; seg.action = @selector(styleChanged:);
    self.styleSeg = seg;
    [content addSubview:seg];

    [content addSubview:[self labelWithText:@"Select file" frame:NSMakeRect(24, 226, 110, 22)]];
    NSButton *choose = [[NSButton alloc] initWithFrame:NSMakeRect(140, 222, 96, 28)];
    choose.title = @"Choose…"; choose.bezelStyle = NSBezelStyleRounded;
    choose.target = self; choose.action = @selector(selectPngTapped:);
    [content addSubview:choose];

    NSTextField *val = [self labelWithText:(patchgram_overlay_png_path.lastPathComponent ?: @"(none)") frame:NSMakeRect(24, 194, 312, 20)];
    val.textColor = [NSColor secondaryLabelColor];
    val.font = [NSFont systemFontOfSize:11];
    self.pngValueLabel = val;
    [content addSubview:val];

    [content addSubview:[self labelWithText:@"Size" frame:NSMakeRect(24, 144, 60, 22)]];
    NSSlider *sl = [[NSSlider alloc] initWithFrame:NSMakeRect(84, 146, 252, 20)];
    sl.minValue = 0.2; sl.maxValue = 3.0; sl.doubleValue = self.rainSizeMul;
    sl.continuous = YES; sl.target = self; sl.action = @selector(sizeChanged:);
    self.sizeSlider = sl;
    [content addSubview:sl];

    [content addSubview:[self labelWithText:@"Speed" frame:NSMakeRect(24, 100, 60, 22)]];
    NSSlider *sp = [[NSSlider alloc] initWithFrame:NSMakeRect(84, 102, 252, 20)];
    sp.minValue = 0.25; sp.maxValue = 3.0; sp.doubleValue = self.rainSpeed;
    sp.continuous = YES; sp.target = self; sp.action = @selector(speedChanged:);
    self.speedSlider = sp;
    [content addSubview:sp];

    [content addSubview:[self labelWithText:@"Opacity" frame:NSMakeRect(24, 56, 60, 22)]];
    NSSlider *op = [[NSSlider alloc] initWithFrame:NSMakeRect(84, 58, 252, 20)];
    op.minValue = 0.1; op.maxValue = 1.0; op.doubleValue = self.rainOpacity;
    op.continuous = YES; op.target = self; op.action = @selector(opacityChanged:);
    self.opacitySlider = op;
    [content addSubview:op];

    [self.host addChildWindow:self.panelWindow ordered:NSWindowAbove];
    [self.panelWindow orderOut:nil];
}

// Centered region (≈ a profile popup) the rain covers, scaled to the host resolution.
- (NSRect)rainRegion {
    NSRect hf = self.host.frame;
    return NSMakeRect(self.rainFx * hf.size.width, self.rainFy * hf.size.height,
                      self.rainFw * hf.size.width, self.rainFh * hf.size.height);
}

- (void)reposition {
    NSWindow *host = self.host;
    if (!host) return;
    NSRect hf = host.frame;
    NSRect bf = self.buttonWindow.frame;
    CGFloat bx = hf.origin.x + self.buttonFx * hf.size.width - bf.size.width / 2.0;
    CGFloat by = hf.origin.y + self.buttonFy * hf.size.height - bf.size.height / 2.0;
    [self.buttonWindow setFrameOrigin:NSMakePoint(bx, by)];
    [self.dimWindow setFrame:hf display:YES];
    NSRect rr = NSMakeRect(hf.origin.x + self.rainFx * hf.size.width, hf.origin.y + self.rainFy * hf.size.height,
                           self.rainFw * hf.size.width, self.rainFh * hf.size.height);
    [self.regionWindow setFrame:rr display:YES];
    self.regionView.frame = NSMakeRect(0, 0, rr.size.width, rr.size.height);
    [self.animWindow setFrame:hf display:YES];
    [self updateRain];
}

- (void)buttonDidMove {
    NSRect hf = self.host.frame;
    NSRect bf = self.buttonWindow.frame;
    if (hf.size.width > 0 && hf.size.height > 0) {
        self.buttonFx = (bf.origin.x + bf.size.width / 2.0 - hf.origin.x) / hf.size.width;
        self.buttonFy = (bf.origin.y + bf.size.height / 2.0 - hf.origin.y) / hf.size.height;
        [self saveState];
        patchgram_log("OVERLAY button moved -> (%.2f,%.2f)", self.buttonFx, self.buttonFy);
    }
}

- (void)attemptSetup {
    if (self.buttonWindow) return;
    NSWindow *host = [self findHostWindow];
    if (!host) {
        self.attempts++;
        if (self.attempts > 120) { patchgram_log("OVERLAY giving up: no host window after %d tries", self.attempts); return; }
        dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(0.5 * NSEC_PER_SEC)), dispatch_get_main_queue(), ^{ [self attemptSetup]; });
        return;
    }
    self.host = host;
    patchgram_log("OVERLAY host found frame=%.0fx%.0f after %d tries", host.frame.size.width, host.frame.size.height, self.attempts);
    @try {
        [self buildAnim];
        [self buildDim];
        [self buildRegion];
        [self buildPanel];
        [self buildButton];     // button last → frontmost child
        [self reposition];
        if (patchgram_overlay_animation_on) [self startRain];
        NSNotificationCenter *nc = [NSNotificationCenter defaultCenter];
        [nc addObserver:self selector:@selector(reposition) name:NSWindowDidResizeNotification object:host];
        [nc addObserver:self selector:@selector(reposition) name:NSWindowDidMoveNotification object:host];
        [self installProbeHotkey];
        [self startAutoTimer];   // always on: drives auto-follow AND secondary-window mirroring
        patchgram_log("OVERLAY ready (profile probe: focus Telegram + open a profile + press Ctrl+Alt+D)");
    } @catch (NSException *e) {
        patchgram_log("OVERLAY build EXCEPTION: %s", e.reason.UTF8String ?: "(nil)");
    }
}

- (void)start { [self loadState]; [self attemptSetup]; }

- (void)openTapped:(id)sender {
    BOOL show = !self.menuOpen;
    self.menuOpen = show;
    if (show) {
        [self reposition];
        // Re-add as children (orderOut detaches child windows; addChildWindow re-parents
        // them above the host and makes them visible, in dim<panel<button order).
        [self.host addChildWindow:self.dimWindow ordered:NSWindowAbove];
        if (!self.autoRegion) [self.host addChildWindow:self.regionWindow ordered:NSWindowAbove];
        [self.host addChildWindow:self.panelWindow ordered:NSWindowAbove];
        [self.host addChildWindow:self.buttonWindow ordered:NSWindowAbove];
    } else {
        [self.panelWindow orderOut:nil];
        [self.regionWindow orderOut:nil];
        [self.dimWindow orderOut:nil];
    }
    patchgram_log("OVERLAY panel %s dimVis=%d panelVis=%d panelOrigin=(%.0f,%.0f) size=%.0fx%.0f host=(%.0f,%.0f) lvl=%ld",
        show ? "shown" : "hidden",
        (int)self.dimWindow.isVisible, (int)self.panelWindow.isVisible,
        self.panelWindow.frame.origin.x, self.panelWindow.frame.origin.y,
        self.panelWindow.frame.size.width, self.panelWindow.frame.size.height,
        self.host.frame.origin.x, self.host.frame.origin.y, (long)self.panelWindow.level);
}

- (void)closeTapped:(id)sender {
    self.menuOpen = NO;
    [self.panelWindow orderOut:nil];
    [self.regionWindow orderOut:nil];
    [self.dimWindow orderOut:nil];
    patchgram_log("OVERLAY close -> panel hidden (open button stays)");
}

- (void)animToggled:(id)sender {
    patchgram_overlay_animation_on = (self.animSwitch.state == NSControlStateValueOn);
    [self saveState];
    if (patchgram_overlay_animation_on) {
        if (self.autoRegion) [self autoTick:nil];   // let detection place + start it
        else [self startRain];
    } else {
        [self stopRain];
        [self teardownSecondary];
    }
    patchgram_log("OVERLAY animation toggled -> %d", (int)patchgram_overlay_animation_on);
}

// Builds a configured emitter for a region (shared by the primary and every secondary window).
- (CAEmitterLayer *)makeEmitterForRegion:(NSRect)region cg:(CGImageRef)cg scale:(CGFloat)scale avatar:(CGPoint)avatar valid:(BOOL)avValid {
    CAEmitterLayer *em = [CAEmitterLayer layer];
    em.frame = region;
    em.masksToBounds = YES;
    em.speed = self.rainSpeed;       // scales particle motion + birth rate (Speed slider)
    em.opacity = self.rainOpacity;   // particle transparency (Opacity slider)
    CGFloat W = region.size.width, H = region.size.height;
    CAEmitterCell *cell = [CAEmitterCell emitterCell];
    cell.name = @"rain";   // named → live size updates via setValue:forKeyPath:@"emitterCells.rain.scale"
    cell.contents = (__bridge id)cg;
    CGFloat csize = scale * self.rainSizeMul;
    cell.scale = csize; cell.scaleRange = csize * 0.4;
    cell.alphaRange = 0.3;
    switch (self.rainStyle) {
        // NOTE: emission velocity here points HORIZONTALLY in this layer (emissionLongitude is
        // effectively rotated), so vertical motion is driven by yAcceleration — a Cartesian axis,
        // immune to that rotation. Layer is y-UP (proven by the logo's -s y-flip), so yAccel<0 = DOWN.
        case 1: // Snow — drifts straight down: gentle gravity + isotropic jitter
            em.emitterShape = kCAEmitterLayerLine;
            em.emitterPosition = CGPointMake(W / 2.0, H);   // top
            em.emitterSize = CGSizeMake(W, 1);
            cell.birthRate = 6.0; cell.lifetime = 14.0;
            cell.velocity = 16.0; cell.velocityRange = 8.0;
            cell.emissionRange = 2.0 * M_PI;     // jitter in all dirs; gravity sets the net fall
            cell.yAcceleration = -45.0;          // DOWN
            cell.spin = 0.3; cell.spinRange = 0.9;
            break;
        case 2: // Float up — rises by upward gravity
            em.emitterShape = kCAEmitterLayerLine;
            em.emitterPosition = CGPointMake(W / 2.0, 0);   // bottom
            em.emitterSize = CGSizeMake(W, 1);
            cell.birthRate = 6.0; cell.lifetime = 11.0;
            cell.velocity = 0.0; cell.velocityRange = 6.0;
            cell.emissionRange = 2.0 * M_PI;
            cell.yAcceleration = 90.0;           // UP
            cell.spin = 0.4; cell.spinRange = 1.0;
            break;
        case 3: // Burst — radial fountain (rotation-agnostic) from the avatar (auto) or region centre
            em.emitterShape = kCAEmitterLayerPoint;
            em.emitterPosition = [self burstPositionInRegion:region avatar:avatar valid:avValid];
            em.emitterSize = CGSizeMake(0, 0);
            cell.birthRate = 18.0; cell.lifetime = 5.0;
            cell.velocity = 120.0; cell.velocityRange = 70.0;
            cell.emissionRange = 2.0 * M_PI;
            cell.yAcceleration = -34.0;
            cell.spin = 1.0; cell.spinRange = 2.0;
            cell.alphaSpeed = -0.2;
            break;
        default: // 0: Rain — straight vertical fall, driven purely by downward gravity (no horizontal)
            em.emitterShape = kCAEmitterLayerLine;
            em.emitterPosition = CGPointMake(W / 2.0, H);   // top
            em.emitterSize = CGSizeMake(W, 1);
            cell.birthRate = 9.0; cell.lifetime = 7.0;
            cell.velocity = 0.0; cell.velocityRange = 0.0;
            cell.emissionRange = 0.0;
            cell.yAcceleration = -380.0;         // strong DOWN → fast straight rain
            cell.spin = 0.0; cell.spinRange = 0.0;
            break;
    }
    em.emitterCells = @[cell];
    return em;
}

- (CAEmitterLayer *)buildEmitterInClip:(CALayer *)clip region:(NSRect)region cg:(CGImageRef)cg scale:(CGFloat)scale avatar:(CGPoint)avatar valid:(BOOL)avValid {
    CAEmitterLayer *em = [self makeEmitterForRegion:region cg:cg scale:scale avatar:avatar valid:avValid];
    [clip addSublayer:em];
    return em;
}

// Re-assert the menu/button z-order on the primary host (after a rain window is re-added on top).
- (void)restackChrome {
    if (self.menuOpen) {
        [self.host addChildWindow:self.dimWindow ordered:NSWindowAbove];
        if (!self.autoRegion) [self.host addChildWindow:self.regionWindow ordered:NSWindowAbove];
        [self.host addChildWindow:self.panelWindow ordered:NSWindowAbove];
    }
    [self.host addChildWindow:self.buttonWindow ordered:NSWindowAbove];
}

- (void)dropPrimaryEmitters {
    [self.emitter removeFromSuperlayer]; self.emitter = nil;
    [self.cardEmitter removeFromSuperlayer]; self.cardEmitter = nil;
}

- (void)startRain {
    if (!patchgram_overlay_png_path.length) { patchgram_log("OVERLAY rain: no file selected"); return; }
    [self stopRain];
    CGImageRef cg = [self loadParticleFirstFrame];
    if (!cg) { patchgram_log("OVERLAY rain: failed to load %s", patchgram_overlay_png_path.UTF8String); return; }
    NSRect region = [self rainRegion];
    CGFloat scale = MAX(0.15, self.host.frame.size.width / 1600.0);
    CALayer *clip = self.animWindow.contentView.layer;
    clip.masksToBounds = NO;
    CAEmitterLayer *em = [self makeEmitterForRegion:region cg:cg scale:scale avatar:self.autoAvatarPoint valid:self.autoAvatarValid];
    [clip addSublayer:em];
    self.emitter = em;
    // Show the rain window above the host (orderFront alone won't re-show a detached child);
    // keep the menu (if open) and the button above the rain.
    [self.host addChildWindow:self.animWindow ordered:NSWindowAbove];
    [self restackChrome];
    if (self.rainFrames.count > 1) [self startFrameTimer];
    patchgram_log("OVERLAY rain started region=%.0fx%.0f scale=%.2f frames=%lu animVis=%d", region.size.width, region.size.height, scale, (unsigned long)self.rainFrames.count, (int)self.animWindow.isVisible);
}

// Loads the chosen file's first particle image. .tgs (if rlottie is linked) renders to frames in
// self.rainFrames (animated); png/anything-else is a single static NSImage. Returns NULL on failure.
- (CGImageRef)loadParticleFirstFrame {
    NSString *p = patchgram_overlay_png_path;
    if (!p.length) return NULL;
    // Reuse already-decoded frames/image when the file is unchanged — auto mode restarts the rain
    // on every profile open/close, and re-decoding a .tgs each time would hitch the main thread.
    if ([p isEqualToString:self.lastParticlePath]) {
        if (self.rainFrames.count) return (__bridge CGImageRef)self.rainFrames.firstObject;
        if (self.rainImage) return [self.rainImage CGImageForProposedRect:NULL context:nil hints:nil];
    }
    self.rainFrames = nil;
    self.rainImage = nil;
    self.lastParticlePath = p;
#if PATCHGRAM_HAVE_RLOTTIE
    if ([p.pathExtension.lowercaseString isEqualToString:@"tgs"]) {
        double fps = 30.0;
        self.rainFrames = patchgram_render_tgs(p, 200, &fps);
        self.rainFps = fps;
        return self.rainFrames.count ? (__bridge CGImageRef)self.rainFrames.firstObject : NULL;
    }
#endif
    self.rainImage = [[NSImage alloc] initWithContentsOfFile:p];
    return [self.rainImage CGImageForProposedRect:NULL context:nil hints:nil];
}

- (void)startFrameTimer {
    [self stopFrameTimer];
    self.frameIndex = 0;
    double fps = self.rainFps > 0 ? self.rainFps : 30.0;
    NSTimeInterval interval = 1.0 / (MIN(fps, 40.0) * MAX(0.1, self.rainSpeed));  // Speed slider scales .tgs playback
    self.frameTimer = [NSTimer scheduledTimerWithTimeInterval:interval target:self
                                                     selector:@selector(frameTick:) userInfo:nil repeats:YES];
}

- (void)stopFrameTimer {
    [self.frameTimer invalidate];
    self.frameTimer = nil;
}

- (void)frameTick:(NSTimer *)t {
    NSArray *frames = self.rainFrames;
    if (frames.count < 2) return;
    self.frameIndex = (self.frameIndex + 1) % (NSInteger)frames.count;
    id img = frames[self.frameIndex];
    if (self.emitter) [self.emitter setValue:img forKeyPath:@"emitterCells.rain.contents"];
    if (self.cardEmitter) [self.cardEmitter setValue:img forKeyPath:@"emitterCells.rain.contents"];
}

- (void)stopRain {
    [self stopFrameTimer];
    [self.emitter removeFromSuperlayer]; self.emitter = nil;
    [self.cardEmitter removeFromSuperlayer]; self.cardEmitter = nil;
    [self.animWindow orderOut:nil];
}

- (void)updateRain {
    if (!self.emitter) return;
    [self updateEmitter:self.emitter region:[self rainRegion] avatar:self.autoAvatarPoint valid:self.autoAvatarValid];
}

- (void)updateEmitter:(CAEmitterLayer *)em region:(NSRect)region avatar:(CGPoint)avatar valid:(BOOL)avValid {
    CGFloat W = region.size.width, H = region.size.height;
    em.frame = region;
    switch (self.rainStyle) {
        case 2: em.emitterPosition = CGPointMake(W / 2.0, 0); em.emitterSize = CGSizeMake(W, 1); break;   // float — bottom
        case 3: em.emitterPosition = [self burstPositionInRegion:region avatar:avatar valid:avValid]; em.emitterSize = CGSizeMake(0, 0); break;
        default: em.emitterPosition = CGPointMake(W / 2.0, H); em.emitterSize = CGSizeMake(W, 1); break;  // rain/snow — top
    }
}

- (void)selectPngTapped:(id)sender {
    NSOpenPanel *panel = [NSOpenPanel openPanel];
    panel.canChooseFiles = YES; panel.canChooseDirectories = NO; panel.allowsMultipleSelection = NO;
#if PATCHGRAM_HAVE_RLOTTIE
    panel.allowedFileTypes = @[@"png", @"tgs"];   // .tgs = animated Lottie sticker
#else
    panel.allowedFileTypes = @[@"png"];
#endif
    NSModalResponse resp = [panel runModal];
    if (resp == NSModalResponseOK && panel.URLs.firstObject) {
        patchgram_overlay_png_path = panel.URLs.firstObject.path;
        self.pngValueLabel.stringValue = (patchgram_overlay_png_path.lastPathComponent ?: @"");
        [self saveState];
        // Defer to the next runloop pass so the rain re-stacks AFTER the modal panel
        // fully tears down — otherwise AppKit's post-modal reorder can leave it over the menu.
        if (self.autoRegion) [self dropPrimaryEmitters];   // auto: next tick rebuilds with the new file
        else if (patchgram_overlay_animation_on) dispatch_async(dispatch_get_main_queue(), ^{ [self startRain]; });
        [self stopSecondaryEmitter];   // secondary rebuilds with the new file on the next tick
        patchgram_log("OVERLAY png selected: %s", patchgram_overlay_png_path.UTF8String);
    } else {
        patchgram_log("OVERLAY png selection cancelled resp=%ld", (long)resp);
    }
}

- (void)styleChanged:(id)sender {
    self.rainStyle = (int)self.styleSeg.selectedSegment;
    [self saveState];
    if (self.autoRegion) [self dropPrimaryEmitters];           // auto: next tick rebuilds both regions
    else if (patchgram_overlay_animation_on) [self startRain]; // manual: single emitter
    [self stopSecondaryEmitter];   // secondary rebuilds with the new style on the next tick
    patchgram_log("OVERLAY style -> %d", self.rainStyle);
}

- (void)speedChanged:(id)sender {
    self.rainSpeed = self.speedSlider.doubleValue;
    [self saveState];
    if (self.emitter) self.emitter.speed = self.rainSpeed;        // live: particle motion
    if (self.cardEmitter) self.cardEmitter.speed = self.rainSpeed;
    if (self.rainFrames.count > 1) [self startFrameTimer];        // live: .tgs frame cadence
    [self stopSecondaryEmitter];   // secondary rebuilds at the new speed on the next tick
    patchgram_log("OVERLAY speed -> %.2f", self.rainSpeed);
}

- (void)opacityChanged:(id)sender {
    self.rainOpacity = self.opacitySlider.doubleValue;
    [self saveState];
    if (self.emitter) self.emitter.opacity = self.rainOpacity;   // live
    if (self.cardEmitter) self.cardEmitter.opacity = self.rainOpacity;
    if (self.secEmitter) self.secEmitter.opacity = self.rainOpacity;
    patchgram_log("OVERLAY opacity -> %.2f", self.rainOpacity);
}

- (void)sizeChanged:(id)sender {
    self.rainSizeMul = self.sizeSlider.doubleValue;
    [self saveState];
    CGFloat csize = MAX(0.15, self.host.frame.size.width / 1600.0) * self.rainSizeMul;
    if (self.emitter) { [self.emitter setValue:@(csize) forKeyPath:@"emitterCells.rain.scale"]; [self.emitter setValue:@(csize * 0.4) forKeyPath:@"emitterCells.rain.scaleRange"]; }
    if (self.cardEmitter) { [self.cardEmitter setValue:@(csize) forKeyPath:@"emitterCells.rain.scale"]; [self.cardEmitter setValue:@(csize * 0.4) forKeyPath:@"emitterCells.rain.scaleRange"]; }
    [self stopSecondaryEmitter];   // secondary rebuilds at the new size on the next tick
    patchgram_log("OVERLAY size -> %.2f", self.rainSizeMul);
}

// ---- Profile-detection probe (Stage 1: data gathering) -------------------------------------
// Telegram is Qt drawing into one NSView, so a profile popup may not exist as a distinct AppKit
// object. This dumps the window/view/layer hierarchy (with frames) so we can SEE whether an open
// profile surfaces anything we could auto-position the rain over. Trigger: focus Telegram, open a
// profile, press Ctrl+Alt+D. Look for a window/view/layer whose frame matches the profile area.
- (BOOL)isOwnWindow:(NSWindow *)w {
    return w == self.buttonWindow || w == self.panelWindow || w == self.animWindow
        || w == self.dimWindow || w == self.regionWindow;
}

- (void)dumpLayer:(CALayer *)l depth:(int)d {
    if (!l || d > 10 || self.probeNodes > 600) return;
    self.probeNodes++;
    CGRect f = l.frame;
    patchgram_log("PROBE %*slayer %s frame=(%.0f,%.0f %.0fx%.0f) contents=%d opaque=%d subs=%lu",
        d * 2, "", l.className.UTF8String, f.origin.x, f.origin.y, f.size.width, f.size.height,
        (int)(l.contents != nil), (int)l.opaque, (unsigned long)l.sublayers.count);
    for (CALayer *s in l.sublayers) [self dumpLayer:s depth:d + 1];
}

- (void)dumpView:(NSView *)v depth:(int)d {
    if (!v || d > 8 || self.probeNodes > 600) return;
    self.probeNodes++;
    NSRect f = v.frame;
    patchgram_log("PROBE %*sview %s frame=(%.0f,%.0f %.0fx%.0f) hidden=%d layer=%s subs=%lu",
        d * 2, "", v.className.UTF8String, f.origin.x, f.origin.y, f.size.width, f.size.height,
        (int)v.isHidden, v.layer ? v.layer.className.UTF8String : "(nil)",
        (unsigned long)v.subviews.count);
    for (NSView *s in v.subviews) [self dumpView:s depth:d + 1];
}

// Walk the NSAccessibility tree (Qt bridges QAccessible → NSAccessibility). If populated, an open
// profile is a subtree here with a real (screen-coords) frame — the one structured handle left now
// that everything renders into a single Metal layer.
- (void)dumpAX:(id)el depth:(int)d {
    if (!el || d > 12 || self.probeNodes > 1200) return;
    self.probeNodes++;
    NSString *role = ([el respondsToSelector:@selector(accessibilityRole)] ? [el accessibilityRole] : nil) ?: @"";
    NSString *label = ([el respondsToSelector:@selector(accessibilityLabel)] ? [el accessibilityLabel] : nil) ?: @"";
    NSRect fr = [el respondsToSelector:@selector(accessibilityFrame)] ? [el accessibilityFrame] : NSZeroRect;
    NSArray *kids = [el respondsToSelector:@selector(accessibilityChildren)] ? [el accessibilityChildren] : nil;
    patchgram_log("PROBE %*sax %s role=%s frame=(%.0f,%.0f %.0fx%.0f) kids=%lu label=\"%.40s\"",
        d * 2, "", NSStringFromClass([el class]).UTF8String, role.UTF8String,
        fr.origin.x, fr.origin.y, fr.size.width, fr.size.height,
        (unsigned long)kids.count, label.UTF8String);
    // Show ALL root children (the profile column is one of them), but cap deeper nodes so a huge
    // list (e.g. the 689-cell chat list) can't exhaust the budget before later siblings are seen.
    NSUInteger cap = (d == 0) ? kids.count : MIN(kids.count, (NSUInteger)8);
    for (NSUInteger k = 0; k < cap; k++) [self dumpAX:kids[k] depth:d + 1];
    if (kids.count > cap)
        patchgram_log("PROBE %*s  …(+%lu more)", d * 2, "", (unsigned long)(kids.count - cap));
}

// Detect the profile "third column" from the AX tree. The conversation message list is the
// right-most AXList still left of centre (the leftmost AXList is the chat/dialog list); its right
// edge is the profile boundary. When the info pane is open, ≥3 root children sit to its right.
// Returns the pane rect in HOST-LOCAL coords (origin bottom-left), the same space as -rainRegion.
// Largest near-square AXButton whose centre-x is in [minX,maxX] and in the upper part of the window
// → the profile avatar (host-local centre). Used as the burst emission origin in auto mode.
- (void)findAvatarIn:(NSArray *)kids minCX:(CGFloat)minX maxCX:(CGFloat)maxX win:(NSRect)win out:(CGPoint *)avatarOut valid:(BOOL *)validOut {
    if (!avatarOut) return;
    CGFloat bestArea = 0, midY = win.origin.y + win.size.height * 0.30;
    for (id k in kids) {
        NSString *role = [k respondsToSelector:@selector(accessibilityRole)] ? [k accessibilityRole] : nil;
        if (![role isEqualToString:@"AXButton"]) continue;
        NSRect f = [k accessibilityFrame];
        CGFloat cx = f.origin.x + f.size.width / 2.0;
        if (f.size.width <= 0 || cx < minX || cx > maxX) continue;
        CGFloat ar = f.size.height / f.size.width, area = f.size.width * f.size.height;
        if (ar > 0.8 && ar < 1.25 && f.size.width >= 40 && f.size.width <= 160
            && (f.origin.y + f.size.height / 2.0) > midY && area > bestArea) {
            bestArea = area;
            *avatarOut = CGPointMake(cx - win.origin.x, f.origin.y + f.size.height / 2.0 - win.origin.y);
            if (validOut) *validOut = YES;
        }
    }
}

// (A) Right third-column profile (chat/channel info): a narrow cluster at the window's right edge.
- (BOOL)detectRightColumnForHost:(NSWindow *)host out:(NSRect *)out avatar:(CGPoint *)avatarOut avatarValid:(BOOL *)avatarValidOut {
    if (avatarValidOut) *avatarValidOut = NO;
    NSView *cv = host.contentView;
    if (![cv respondsToSelector:@selector(accessibilityChildren)]) return NO;
    NSArray *kids = [cv accessibilityChildren];
    if (!kids.count) return NO;
    NSRect win = host.frame;
    CGFloat wx0 = win.origin.x;
    CGFloat winRight = wx0 + win.size.width;
    CGFloat center = wx0 + win.size.width / 2.0;
    BOOL haveConv = NO; CGFloat convRight = 0;
    for (id k in kids) {
        NSString *role = [k respondsToSelector:@selector(accessibilityRole)] ? [k accessibilityRole] : nil;
        if (![role isEqualToString:@"AXList"]) continue;
        NSRect f = [k accessibilityFrame];
        CGFloat right = f.origin.x + f.size.width;
        if (f.origin.x < center && (!haveConv || right > convRight)) { convRight = right; haveConv = YES; }
    }
    if (!haveConv) return NO;
    int rightCount = 0;
    for (id k in kids) {
        NSRect f = [k respondsToSelector:@selector(accessibilityFrame)] ? [k accessibilityFrame] : NSZeroRect;
        if (f.size.width > 0 && f.origin.x >= convRight - 6 && f.origin.x < winRight) rightCount++;
    }
    // A real info column is NARROW (~0.28 of the window); a wide gap means we mistook another list
    // (e.g. a centred card's own list) for the conversation → not a right column.
    if (rightCount >= 3 && (winRight - convRight) >= 150 && (winRight - convRight) <= win.size.width * 0.45) {
        CGFloat lx = convRight - wx0; if (lx < 0) lx = 0;
        *out = NSMakeRect(lx, 0, win.size.width - lx, win.size.height);
        [self findAvatarIn:kids minCX:convRight - 6 maxCX:winRight win:win out:avatarOut valid:avatarValidOut];
        return YES;
    }
    return NO;
}

// (B) Centred profile card (member/user card): anchored on a LARGE near-square avatar near the
// window centre, then the cluster of rows in a band around it. Independent of the right column.
- (BOOL)detectCardForHost:(NSWindow *)host out:(NSRect *)out avatar:(CGPoint *)avatarOut avatarValid:(BOOL *)avatarValidOut {
    if (avatarValidOut) *avatarValidOut = NO;
    NSView *cv = host.contentView;
    if (![cv respondsToSelector:@selector(accessibilityChildren)]) return NO;
    NSArray *kids = [cv accessibilityChildren];
    if (!kids.count) return NO;
    NSRect win = host.frame;
    CGFloat wx0 = win.origin.x, wy0 = win.origin.y;
    CGFloat winRight = wx0 + win.size.width, winTop = wy0 + win.size.height;
    CGFloat winCx = wx0 + win.size.width / 2.0;
    CGFloat bestArea = 0, acx = 0, acy = 0; BOOL haveAv = NO;
    for (id k in kids) {
        NSString *role = [k respondsToSelector:@selector(accessibilityRole)] ? [k accessibilityRole] : nil;
        if (![role isEqualToString:@"AXButton"]) continue;
        NSRect f = [k accessibilityFrame];
        if (f.size.width <= 0) continue;
        CGFloat cx = f.origin.x + f.size.width / 2.0, ar = f.size.height / f.size.width;
        if (ar > 0.8 && ar < 1.25 && f.size.width >= 56 && f.size.width <= 170
            && fabs(cx - winCx) < win.size.width * 0.22 && f.size.width * f.size.height > bestArea) {
            bestArea = f.size.width * f.size.height; acx = cx; acy = f.origin.y + f.size.height / 2.0; haveAv = YES;
        }
    }
    if (!haveAv) return NO;
    CGFloat band = win.size.width * 0.20;
    int cnt = 0; CGFloat minX = 1e18, minY = 1e18, maxX = -1e18, maxY = -1e18;
    for (id k in kids) {
        NSString *role = [k respondsToSelector:@selector(accessibilityRole)] ? [k accessibilityRole] : nil;
        if ([role isEqualToString:@"AXList"]) continue;
        NSRect f = [k accessibilityFrame];
        if (f.size.width <= 0 || fabs(f.origin.x + f.size.width / 2.0 - acx) > band) continue;
        cnt++;
        if (f.origin.x < minX) minX = f.origin.x;
        if (f.origin.y < minY) minY = f.origin.y;
        if (f.origin.x + f.size.width > maxX) maxX = f.origin.x + f.size.width;
        if (f.origin.y + f.size.height > maxY) maxY = f.origin.y + f.size.height;
    }
    if (cnt < 8) return NO;
    if (minY < wy0) minY = wy0;   if (maxY > winTop) maxY = winTop;
    CGFloat half = MIN(acx - minX, maxX - acx);
    if (half < 100) half = MAX(acx - minX, maxX - acx);
    CGFloat L = acx - half, R = acx + half, ph = maxY - minY;
    if (L < wx0) L = wx0;   if (R > winRight) R = winRight;
    CGFloat pw = R - L;
    if (pw >= 220 && ph >= 200) {
        *out = NSMakeRect(L - wx0, minY - wy0, pw, ph);
        if (avatarOut) { *avatarOut = CGPointMake(acx - wx0, acy - wy0); if (avatarValidOut) *avatarValidOut = YES; }
        return YES;
    }
    return NO;
}

// Single-region wrapper (right column preferred, else the centred card) — used by the probe and the
// secondary window. The PRIMARY window paints both at once (see autoTick).
- (BOOL)detectProfilePaneRect:(NSRect *)out avatar:(CGPoint *)avatarOut avatarValid:(BOOL *)avatarValidOut forHost:(NSWindow *)host {
    if ([self detectRightColumnForHost:host out:out avatar:avatarOut avatarValid:avatarValidOut]) return YES;
    return [self detectCardForHost:host out:out avatar:avatarOut avatarValid:avatarValidOut];
}

// burst emission point (emitter-local): the profile avatar in auto mode, else the region centre.
- (CGPoint)burstPositionInRegion:(NSRect)region avatar:(CGPoint)avatar valid:(BOOL)valid {
    if (self.autoRegion && valid) {
        return CGPointMake(avatar.x - region.origin.x, avatar.y - region.origin.y);
    }
    return CGPointMake(region.size.width / 2.0, region.size.height / 2.0);
}

- (void)startAutoTimer {
    [self stopAutoTimer];
    // Fast enough to react to in-window layout changes (e.g. collapsing the chat-list/side column,
    // which shifts the profile boundary without a window resize notification).
    self.autoTimer = [NSTimer scheduledTimerWithTimeInterval:0.3 target:self
                                                    selector:@selector(autoTick:) userInfo:nil repeats:YES];
}
- (void)stopAutoTimer { [self.autoTimer invalidate]; self.autoTimer = nil; }

// Auto mode: snap the rain region to the detected profile pane; rain shows only while one is open.
- (void)autoTick:(NSTimer *)t {
    // Primary host (auto mode): paint BOTH a right info-column AND a centred profile card if present.
    if (self.autoRegion && patchgram_overlay_animation_on && patchgram_overlay_png_path.length) {
        CGImageRef cg = [self loadParticleFirstFrame];
        if (cg) {
            CALayer *clip = self.animWindow.contentView.layer; clip.masksToBounds = NO;
            CGFloat scale = MAX(0.15, self.host.frame.size.width / 1600.0);
            BOOL changed = NO;
            NSRect r; CGPoint av = CGPointZero; BOOL avv = NO;
            if ([self detectRightColumnForHost:self.host out:&r avatar:&av avatarValid:&avv]) {
                if (!self.emitter) { self.emitter = [self buildEmitterInClip:clip region:r cg:cg scale:scale avatar:av valid:avv]; changed = YES; }
                else [self updateEmitter:self.emitter region:r avatar:av valid:avv];
            } else if (self.emitter) { [self.emitter removeFromSuperlayer]; self.emitter = nil; changed = YES; }
            NSRect cr; CGPoint cav = CGPointZero; BOOL cavv = NO;
            if ([self detectCardForHost:self.host out:&cr avatar:&cav avatarValid:&cavv]) {
                if (!self.cardEmitter) { self.cardEmitter = [self buildEmitterInClip:clip region:cr cg:cg scale:scale avatar:cav valid:cavv]; changed = YES; }
                else [self updateEmitter:self.cardEmitter region:cr avatar:cav valid:cavv];
            } else if (self.cardEmitter) { [self.cardEmitter removeFromSuperlayer]; self.cardEmitter = nil; changed = YES; }
            if (self.emitter || self.cardEmitter) {
                // Only re-add (which re-orders child windows) when an emitter appeared/vanished —
                // doing it every tick would flicker the menu/button z-order.
                if (changed || !self.animWindow.isVisible) {
                    [self.host addChildWindow:self.animWindow ordered:NSWindowAbove];
                    [self restackChrome];
                }
                if (self.rainFrames.count > 1 && !self.frameTimer) [self startFrameTimer];
            } else {
                [self.animWindow orderOut:nil]; [self stopFrameTimer];
            }
        }
    }
    // Secondary Telegram windows (media viewer / popped-out chat): mirror the rain there too.
    [self syncSecondary];
}

// Largest visible Telegram (Qt) window that isn't the primary host or one of our own panels.
- (NSWindow *)secondTelegramWindowExcluding:(NSWindow *)primary {
    NSWindow *best = nil; CGFloat area = 0;
    for (NSWindow *w in NSApp.windows) {
        if (w == primary || !w.isVisible) continue;
        if (w == self.buttonWindow || w == self.panelWindow || w == self.dimWindow
            || w == self.regionWindow || w == self.animWindow || w == self.secAnim) continue;
        if (![w.className hasPrefix:@"QNSWindow"]) continue;   // Telegram's Qt windows
        if (w.frame.size.width < 320 || w.frame.size.height < 260) continue;
        CGFloat a = w.frame.size.width * w.frame.size.height;
        if (a > area) { area = a; best = w; }
    }
    return best;
}

- (void)stopSecondaryEmitter {
    [self.secEmitter removeFromSuperlayer]; self.secEmitter = nil;
    [self.secTimer invalidate]; self.secTimer = nil;
}

- (void)teardownSecondary {
    [self stopSecondaryEmitter];
    [self.secAnim orderOut:nil]; self.secAnim = nil; self.secHost = nil;
}

- (void)secFrameTick:(NSTimer *)t {
    NSArray *frames = self.rainFrames;
    if (!self.secEmitter || frames.count < 2) return;
    self.secFrameIndex = (self.secFrameIndex + 1) % (NSInteger)frames.count;
    [self.secEmitter setValue:frames[self.secFrameIndex] forKeyPath:@"emitterCells.rain.contents"];
}

// Build/update/teardown the rain on a 2nd Telegram window, mirroring the primary's config.
- (void)syncSecondary {
    NSWindow *w2 = [self secondTelegramWindowExcluding:self.host];
    if (!w2 || !patchgram_overlay_animation_on || !patchgram_overlay_png_path.length) { [self teardownSecondary]; return; }
    if (self.secHost != w2) { [self teardownSecondary]; self.secHost = w2; }
    NSRect hf = w2.frame;
    if (!self.secAnim) {
        self.secAnim = [self makeChildPanel:NSMakeRect(0, 0, hf.size.width, hf.size.height) ignoresMouse:YES];
        self.secAnim.contentView.wantsLayer = YES;
        self.secAnim.contentView.layer.masksToBounds = NO;
        [w2 addChildWindow:self.secAnim ordered:NSWindowAbove];
    }
    [self.secAnim setFrame:hf display:YES];
    NSRect region; BOOL show = YES;
    if (self.autoRegion) {
        NSRect pane; CGPoint av = CGPointZero; BOOL avv = NO;
        if ([self detectProfilePaneRect:&pane avatar:&av avatarValid:&avv forHost:w2]) {
            region = pane; self.secAvatarPoint = av; self.secAvatarValid = avv;
        } else { show = NO; }
    } else {
        region = NSMakeRect(self.rainFx * hf.size.width, self.rainFy * hf.size.height,
                            self.rainFw * hf.size.width, self.rainFh * hf.size.height);
        self.secAvatarValid = NO;
    }
    if (!show) { [self stopSecondaryEmitter]; return; }
    if (!self.secEmitter) {
        CGImageRef cg = self.rainFrames.count ? (__bridge CGImageRef)self.rainFrames.firstObject
                       : (self.rainImage ? [self.rainImage CGImageForProposedRect:NULL context:nil hints:nil] : NULL);
        if (!cg) return;
        CGFloat scale = MAX(0.15, hf.size.width / 1600.0);
        CAEmitterLayer *em = [self makeEmitterForRegion:region cg:cg scale:scale avatar:self.secAvatarPoint valid:self.secAvatarValid];
        [self.secAnim.contentView.layer addSublayer:em];
        self.secEmitter = em;
        [w2 addChildWindow:self.secAnim ordered:NSWindowAbove];
        if (self.rainFrames.count > 1) {
            double fps = self.rainFps > 0 ? self.rainFps : 30.0;
            self.secFrameIndex = 0;
            self.secTimer = [NSTimer scheduledTimerWithTimeInterval:1.0 / (MIN(fps, 40.0) * MAX(0.1, self.rainSpeed))
                                                             target:self selector:@selector(secFrameTick:) userInfo:nil repeats:YES];
        }
        patchgram_log("OVERLAY secondary rain on %s region=%.0fx%.0f", w2.className.UTF8String, region.size.width, region.size.height);
    } else {
        [self updateEmitter:self.secEmitter region:region avatar:self.secAvatarPoint valid:self.secAvatarValid];
    }
}

- (void)autoToggled:(id)sender {
    self.autoRegion = (self.autoSwitch.state == NSControlStateValueOn);
    [self saveState];
    if (self.autoRegion) {
        [self.regionWindow orderOut:nil];   // hide the manual region frame
    } else {
        if (self.menuOpen) [self.host addChildWindow:self.regionWindow ordered:NSWindowAbove];
    }
    [self dropPrimaryEmitters];    // region model changed → rebuild from scratch
    [self stopSecondaryEmitter];
    if (self.autoRegion) [self autoTick:nil];                  // auto: builds right column + card
    else if (patchgram_overlay_animation_on) [self startRain]; // manual: single emitter
    patchgram_log("OVERLAY auto-region -> %d", (int)self.autoRegion);
}

- (void)probeHierarchy:(NSString *)reason {
    self.probeNodes = 0;
    patchgram_log("PROBE ===== %s =====", reason.UTF8String);
    NSArray<NSWindow *> *wins = [NSApp windows];
    patchgram_log("PROBE windows=%lu", (unsigned long)wins.count);
    int i = 0;
    for (NSWindow *w in wins) {
        NSRect f = w.frame;
        patchgram_log("PROBE win[%d]%s %s frame=(%.0f,%.0f %.0fx%.0f) lvl=%ld vis=%d key=%d parent=%s children=%lu title=\"%s\"",
            i++, [self isOwnWindow:w] ? " [patchgram]" : "", w.className.UTF8String,
            f.origin.x, f.origin.y, f.size.width, f.size.height, (long)w.level,
            (int)w.isVisible, (int)w.isKeyWindow,
            w.parentWindow ? w.parentWindow.className.UTF8String : "(none)",
            (unsigned long)w.childWindows.count, (w.title ?: @"").UTF8String);
    }
    if (self.host.contentView) {
        patchgram_log("PROBE --- host view tree (frames in superview coords) ---");
        [self dumpView:self.host.contentView depth:0];
        patchgram_log("PROBE --- host layer tree ---");
        [self dumpLayer:self.host.contentView.layer depth:0];
        patchgram_log("PROBE --- host AX tree (frames in SCREEN coords; empty = Qt a11y inactive) ---");
        self.probeNodes = 0;
        @try { [self dumpAX:self.host.contentView depth:0]; }
        @catch (NSException *e) { patchgram_log("PROBE ax EXCEPTION: %s", e.reason.UTF8String ?: "(nil)"); }
        patchgram_log("PROBE ax nodes=%d", self.probeNodes);
    }
    CGFloat w = self.host.frame.size.width, h = self.host.frame.size.height;
    if (w > 0 && h > 0) {
        NSRect r; CGPoint av = CGPointZero; BOOL avv = NO;
        if ([self detectRightColumnForHost:self.host out:&r avatar:&av avatarValid:&avv])
            patchgram_log("PROBE DETECT right-column host-local=(%.0f,%.0f %.0fx%.0f) fx=%.3f fw=%.3f",
                r.origin.x, r.origin.y, r.size.width, r.size.height, r.origin.x / w, r.size.width / w);
        else patchgram_log("PROBE DETECT right-column: none");
        NSRect cr; CGPoint cav = CGPointZero; BOOL cavv = NO;
        if ([self detectCardForHost:self.host out:&cr avatar:&cav avatarValid:&cavv])
            patchgram_log("PROBE DETECT card host-local=(%.0f,%.0f %.0fx%.0f) fx=%.3f fw=%.3f avatar=%s(%.0f,%.0f)",
                cr.origin.x, cr.origin.y, cr.size.width, cr.size.height, cr.origin.x / w, cr.size.width / w,
                cavv ? "yes" : "no", cav.x, cav.y);
        else patchgram_log("PROBE DETECT card: none");
    }
    patchgram_log("PROBE ===== end =====");
}

- (void)installProbeHotkey {
    __weak PatchgramOverlay *weakSelf = self;
    [NSEvent addLocalMonitorForEventsMatchingMask:NSEventMaskKeyDown handler:^NSEvent *(NSEvent *e) {
        // Ctrl+Alt+D dumps the hierarchy (keyCode 2 == 'd' on US layout).
        if ((e.modifierFlags & NSEventModifierFlagControl) &&
            (e.modifierFlags & NSEventModifierFlagOption) && e.keyCode == 2) {
            [weakSelf probeHierarchy:@"hotkey ctrl-alt-d"];
            return nil;
        }
        return e;
    }];
}

@end

static void patchgram_overlay_start(void) {
    if (!g_overlay_enabled) { patchgram_log("OVERLAY disabled (overlayEnabled=0)"); return; }
    patchgram_log("OVERLAY enabled -> scheduling setup on main queue");
    dispatch_async(dispatch_get_main_queue(), ^{
        if (!g_patchgram_overlay) g_patchgram_overlay = [[PatchgramOverlay alloc] init];
        [g_patchgram_overlay start];
    });
}

__attribute__((constructor))
static void patchgram_bot_verification_init(void) {
    const char *config_path = getenv("PATCHGRAM_RUNTIME_CONFIG");
    if (!config_path || !config_path[0]) {
        config_path = getenv("PATCHGRAM_BOT_VERIFICATION_CONFIG");
    }
    patchgram_set_log_path(config_path);
    patchgram_log("BEGIN Patchgram runtime hook");
    (void)g_patchgram_runtime_build_marker;

    if (!config_path || !config_path[0]) {
        patchgram_log("ERROR Missing PATCHGRAM_RUNTIME_CONFIG");
        return;
    }
    snprintf(g_config_path, sizeof(g_config_path), "%s", config_path);
    if (!patchgram_has_telegram_executable_image()) {
        patchgram_log("SKIP Patchgram runtime hook for non-Telegram image=%s", patchgram_main_image_name());
        return;
    }
    // IMPORTANT: load the config but DEFER memory patches (apply_memory_patches=false).
    // Runtime memory patches rewrite mid-body code, and some legitimately land inside a
    // hooked function (e.g. data.user.verification_status.* writes at UserData::setFlags
    // +0x34, which overlaps the tail of setFlags' resolution signature). If patches ran
    // first they would corrupt the very bytes the signature matches on → "signature miss"
    // → the hook silently dies (userFlags=0 → custom phone / local channel / usernames
    // break). So resolve+install hooks against the PRISTINE binary first, THEN apply the
    // memory patches: the trampoline lives at the function entry, the patch lands mid-body,
    // and the two coexist.
    if (!patchgram_load_runtime_config(g_config_path, false, "initial")) {
        return;
    }
    if (g_bot_verification_enabled && !g_configured_icon_id) {
        patchgram_log("ERROR Missing customEmojiId");
    }
    patchgram_install_bot_verification_hooks();
    patchgram_apply_memory_patches("initial");
    patchgram_start_runtime_reload_thread();
    patchgram_overlay_start();
    // Open the MTProto logger now (still in the constructor → before main → before the first
    // packet) so a full request/response trace is captured from the very first send.
    patchgram_mtproto_logger_start();
}
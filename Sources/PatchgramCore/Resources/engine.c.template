            "CUSTOM USERNAMES response substituted requestId=%d username=%s date=%d amount=%lld currency=%s cryptoAmount=%lld cryptoCurrency=%s url=%s",
            (int)request_id,
            username_entry->username,
            (int)username_entry->purchase_date,
            (long long)username_entry->amount,
            username_entry->currency,
            (long long)username_entry->crypto_amount,
            username_entry->crypto_currency,
            username_entry->url
        );
    }
    return true;
}

static uint32_t *patchgram_build_fact_check_reply(int32_t count, int64_t *word_count_out) {
    if (word_count_out) {
        *word_count_out = 0;
    }
    if (count <= 0 || !g_message_fact_check_text[0]) {
        return NULL;
    }
    const char *country = g_message_fact_check_country;
    const char *text = g_message_fact_check_text;
    const int32_t flags = (g_message_fact_check_need_check ? 1 : 0) | 2;
    const size_t one_fact_check_size = sizeof(uint32_t)
        + sizeof(int32_t)
        + patchgram_tl_string_length(country)
        + sizeof(uint32_t)
        + patchgram_tl_string_length(text)
        + sizeof(uint32_t)
        + sizeof(int32_t)
        + sizeof(int64_t);
    const size_t byte_count = sizeof(uint32_t) + sizeof(int32_t) + one_fact_check_size * (size_t)count;
    const size_t padded_count = (byte_count + 3U) & ~(size_t)3U;
    uint8_t *buffer = (uint8_t *)calloc(padded_count, 1);
    if (!buffer) {
        return NULL;
    }
    size_t offset = 0;
    patchgram_tl_write_u32(buffer, &offset, PATCHGRAM_TL_VECTOR);
    patchgram_tl_write_i32(buffer, &offset, count);
    for (int32_t i = 0; i < count; i++) {
        patchgram_tl_write_u32(buffer, &offset, PATCHGRAM_TL_FACT_CHECK);
        patchgram_tl_write_i32(buffer, &offset, flags);
        patchgram_tl_write_string(buffer, &offset, country);
        patchgram_tl_write_u32(buffer, &offset, PATCHGRAM_TL_TEXT_WITH_ENTITIES);
        patchgram_tl_write_string(buffer, &offset, text);
        patchgram_tl_write_u32(buffer, &offset, PATCHGRAM_TL_VECTOR);
        patchgram_tl_write_i32(buffer, &offset, 0);
        patchgram_tl_write_i64(buffer, &offset, g_message_fact_check_hash);
    }
    if (word_count_out) {
        *word_count_out = (int64_t)(padded_count / sizeof(uint32_t));
    }
    return (uint32_t *)buffer;
}

static bool patchgram_apply_fact_check_response(void *response) {
    if (!response || !g_message_settings_enabled || !g_message_fact_check_enabled) {
        return false;
    }
    int32_t request_id = 0;
    memcpy(&request_id, (const uint8_t *)response + PATCHGRAM_RESPONSE_REQUEST_ID_OFFSET, sizeof(request_id));
    const int32_t count = patchgram_take_fact_check_request(request_id);
    if (count <= 0) {
        return false;
    }
    int64_t word_count = 0;
    uint32_t *words = patchgram_build_fact_check_reply(count, &word_count);
    if (!words || word_count <= 0) {
        free(words);
        return false;
    }
    void *data_header = NULL;
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_D_OFFSET, &data_header, sizeof(data_header));
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, &words, sizeof(words));
    memcpy((uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, &word_count, sizeof(word_count));
    if (g_message_fact_check_response_logs < 96) {
        g_message_fact_check_response_logs++;
        patchgram_log(
            "FACT CHECK response substituted requestId=%d count=%d words=%lld text=%s country=%s hash=%lld needCheck=%d",
            (int)request_id,
            (int)count,
            (long long)word_count,
            g_message_fact_check_text,
            g_message_fact_check_country,
            (long long)g_message_fact_check_hash,
            g_message_fact_check_need_check ? 1 : 0
        );
    }
    return true;
}

static bool patchgram_should_force_fact_check_item(void *item) {
    if (!item) {
        return false;
    }
    bool should_force = false;
    pthread_mutex_lock(&g_forced_fact_check_items_mutex);
    size_t empty_index = PATCHGRAM_MAX_FORCED_FACT_CHECK_ITEMS;
    for (size_t i = 0; i < PATCHGRAM_MAX_FORCED_FACT_CHECK_ITEMS; i++) {
        if (g_forced_fact_check_items[i].item == item) {
            if (g_forced_fact_check_items[i].attempts < 8) {
                g_forced_fact_check_items[i].attempts++;
                should_force = true;
            }
            pthread_mutex_unlock(&g_forced_fact_check_items_mutex);
            return should_force;
        }
        if (!g_forced_fact_check_items[i].item && empty_index == PATCHGRAM_MAX_FORCED_FACT_CHECK_ITEMS) {
            empty_index = i;
        }
    }
    if (empty_index != PATCHGRAM_MAX_FORCED_FACT_CHECK_ITEMS) {
        g_forced_fact_check_items[empty_index].item = item;
        g_forced_fact_check_items[empty_index].attempts = 1;
    } else {
        g_forced_fact_check_items[0].item = item;
        g_forced_fact_check_items[0].attempts = 1;
    }
    should_force = true;
    pthread_mutex_unlock(&g_forced_fact_check_items_mutex);
    return should_force;
}

/* Force message#7600b9d3 noforwards (flags.26) to false on the constructed
 * HistoryItem by clearing the internal MessageFlag::NoForwards bit (1<<17) in
 * _flags @ 0x1e8. forbidsForward()/forbidsSaving() read this live each time, so
 * clearing it makes copy-text and save-media available on restricted messages.
 * Offset + bit verified on 6.9.1; the write is a same-width read-modify-write of
 * the exact 8-byte field the inlined gate loads (LDR X,[item,#0x1e8]). */
/* A heap object pointer on arm64 macOS: above the 4 GB image base, within the
 * 48-bit canonical range, and 8-byte aligned. Rejects NULL, misread text/scalars
 * (e.g. the UTF-16 "ages" word 0x0073006500670061 has bits >= 48 set), and
 * misaligned values, so a wrong struct offset fails the guard instead of faulting
 * or corrupting memory. */
static bool patchgram_ptr_looks_valid(const void *p) {
    const uintptr_t v = (uintptr_t)p;
    return v >= 0x100000000ULL && (v >> 48) == 0 && (v & 0x7ULL) == 0;
}

static void patchgram_clear_noforwards_on_item(void *item) {
    if (!item || !g_message_settings_enabled || !g_message_allow_noforwards_copy) {
        return;
    }
    /* (1) Item-level: HistoryItem::_flags NoForwards -> forbidsSaving() == false. */
    uint64_t *flags = (uint64_t *)((uint8_t *)item + PATCHGRAM_HISTORY_ITEM_FLAGS_OFFSET);
    const uint64_t before = *flags;
    if (before & PATCHGRAM_MESSAGE_FLAG_NO_FORWARDS) {
        const uint64_t after = before & ~PATCHGRAM_MESSAGE_FLAG_NO_FORWARDS;
        *flags = after;
        static uint32_t logs = 0;
        if (logs < 64) {
            logs++;
            patchgram_log(
                "NOFORWARDS clear item=%p flagsBefore=0x%llx flagsAfter=0x%llx",
                item,
                (unsigned long long)before,
                (unsigned long long)after
            );
        }
    }
    /* (2) Channel-level: clear ChannelData NoForwards so peer->allowsForwarding()
     * returns true (the other half of the copy/save menu gate). Guarded every step:
     * a wrong offset yields an invalid pointer or a non-channel type and is skipped,
     * never written. Only channels/supergroups (ChannelData layout @ 0x1e8); chats
     * and users are left untouched. */
    void *history = NULL;
    memcpy(&history, (const uint8_t *)item + PATCHGRAM_HISTORY_ITEM_HISTORY_OFFSET, sizeof(history));
    if (!patchgram_ptr_looks_valid(history)) {
        return;
    }
    void *peer = NULL;
    memcpy(&peer, (const uint8_t *)history + PATCHGRAM_HISTORY_PEER_OFFSET, sizeof(peer));
    if (!patchgram_ptr_looks_valid(peer)) {
        return;
    }
    const uint8_t peer_type = patchgram_peer_type_from_peer(peer);
    if (peer_type == PATCHGRAM_PEER_TYPE_CHANNEL) {
        uint64_t *peer_flags = (uint64_t *)((uint8_t *)peer + PATCHGRAM_PEER_FLAGS_OFFSET);
        const uint64_t peer_before = *peer_flags;
        if (peer_before & PATCHGRAM_CHANNEL_FLAG_NO_FORWARDS) {
            const uint64_t peer_after = peer_before & ~PATCHGRAM_CHANNEL_FLAG_NO_FORWARDS;
            *peer_flags = peer_after;
            static uint32_t channel_logs = 0;
            if (channel_logs < 64) {
                channel_logs++;
                patchgram_log(
                    "NOFORWARDS channel clear peer=%p rawPeer=0x%llx flagsBefore=0x%llx flagsAfter=0x%llx",
                    peer,
                    (unsigned long long)patchgram_raw_peer_id_from_peer(peer),
                    (unsigned long long)peer_before,
                    (unsigned long long)peer_after
                );
            }
        }
    } else if (peer_type == PATCHGRAM_PEER_TYPE_CHAT) {
        uint32_t *chat_flags = (uint32_t *)((uint8_t *)peer + PATCHGRAM_CHAT_FLAGS_OFFSET);
        const uint32_t chat_before = *chat_flags;
        if (chat_before & PATCHGRAM_CHAT_FLAG_NO_FORWARDS) {
            const uint32_t chat_after = chat_before & ~PATCHGRAM_CHAT_FLAG_NO_FORWARDS;
            *chat_flags = chat_after;
            static uint32_t chat_logs = 0;
            if (chat_logs < 64) {
                chat_logs++;
                patchgram_log(
                    "NOFORWARDS chat clear peer=%p rawPeer=0x%llx flagsBefore=0x%x flagsAfter=0x%x",
                    peer,
                    (unsigned long long)patchgram_raw_peer_id_from_peer(peer),
                    chat_before,
                    chat_after
                );
            }
        }
    }
}

/* Disable message ttl_period (auto-delete) by zeroing HistoryItem::_ttlDestroyAt.
 * Only acts when the field holds a plausible auto-delete time (destroy strictly
 * after a sane _date), which both confirms the 0x7c offset and avoids ever touching
 * _date (0x78) or firing on a non-ttl message — so a wrong offset is a safe no-op,
 * never a crash. View-once media ttl_seconds is handled at construction by the
 * create_media memory patch, not here. */
static void patchgram_disable_ttl_on_item(void *item) {
    if (!item || !g_message_settings_enabled || !g_message_disable_ttl) {
        return;
    }
    uint32_t date = 0;
    uint32_t destroy = 0;
    memcpy(&date, (const uint8_t *)item + PATCHGRAM_HISTORY_ITEM_DATE_OFFSET, sizeof(date));
    memcpy(&destroy, (const uint8_t *)item + PATCHGRAM_HISTORY_ITEM_TTL_DESTROY_OFFSET, sizeof(destroy));
    if (destroy != 0 && date > 1000000000u && destroy > date) {
        const uint32_t zero = 0;
        memcpy((uint8_t *)item + PATCHGRAM_HISTORY_ITEM_TTL_DESTROY_OFFSET, &zero, sizeof(zero));
        static uint32_t logs = 0;
        if (logs < 64) {
            logs++;
            patchgram_log(
                "TTL clear item=%p date=%u destroyBefore=%u",
                item,
                date,
                destroy
            );
        }
    }
    /* Media self-destruct (view-once video/voice/document): zero MediaFile::_ttlSeconds
     * on the object so the Element about to be built renders it as normal media. */
    void *media = NULL;
    memcpy(&media, (const uint8_t *)item + PATCHGRAM_HISTORY_ITEM_MEDIA_OFFSET, sizeof(media));
    if (!patchgram_ptr_looks_valid(media)) {
        return;
    }
    void *media_vtable = NULL;
    memcpy(&media_vtable, media, sizeof(media_vtable));
    if (media_vtable != patchgram_resolve_vmaddr(PATCHGRAM_MEDIA_FILE_VTABLE_VMADDR)) {
        return;
    }
    uint64_t *media_ttl = (uint64_t *)((uint8_t *)media + PATCHGRAM_MEDIA_FILE_TTL_SECONDS_OFFSET);
    if (*media_ttl != 0) {
        const uint64_t before = *media_ttl;
        *media_ttl = 0;
        static uint32_t media_logs = 0;
        if (media_logs < 64) {
            media_logs++;
            patchgram_log(
                "TTL media clear item=%p media=%p ttlBefore=%llu",
                item,
                media,
                (unsigned long long)before
            );
        }
    }
}

static bool patchgram_set_local_fact_check_on_item(void *item) {
    if (!item
        || !g_history_item_set_factcheck
        || !g_message_settings_enabled
        || !g_message_fact_check_enabled
        || g_message_fact_check_text_utf16_size <= 0) {
        return false;
    }
    uint8_t info[PATCHGRAM_MESSAGE_FACTCHECK_SIZE];
    memset(info, 0, sizeof(info));
    patchgram_apply_raw_qstring(
        info + PATCHGRAM_MESSAGE_FACTCHECK_TEXT_OFFSET + PATCHGRAM_QSTRING_D_OFFSET,
        g_message_fact_check_text_utf16,
        g_message_fact_check_text_utf16_size
    );
    memset(
        info + PATCHGRAM_MESSAGE_FACTCHECK_TEXT_OFFSET + PATCHGRAM_TEXT_WITH_ENTITIES_ENTITIES_OFFSET,
        0,
        PATCHGRAM_QT_ARRAY_DATA_POINTER_SIZE
    );
    patchgram_apply_raw_qstring(
        info + PATCHGRAM_MESSAGE_FACTCHECK_COUNTRY_OFFSET,
        g_message_fact_check_country_utf16,
        g_message_fact_check_country_utf16_size
    );
    uint64_t effective_hash = (uint64_t)g_message_fact_check_hash;
    if (effective_hash == 0) {
        effective_hash = 1;
    }
    memcpy(info + PATCHGRAM_MESSAGE_FACTCHECK_HASH_OFFSET, &effective_hash, sizeof(effective_hash));
    const uint8_t need_check = g_message_fact_check_need_check ? 1 : 0;
    memcpy(info + PATCHGRAM_MESSAGE_FACTCHECK_NEED_CHECK_OFFSET, &need_check, sizeof(need_check));
    g_history_item_set_factcheck(item, info);
    if (g_message_fact_check_direct_set_logs < 256) {
        g_message_fact_check_direct_set_logs++;
        patchgram_log(
            "FACT CHECK direct set item=%p textLength=%lld countryLength=%lld hash=%llu configuredHash=%lld needCheck=%d",
            item,
            (long long)g_message_fact_check_text_utf16_size,
            (long long)g_message_fact_check_country_utf16_size,
            (unsigned long long)effective_hash,
            (long long)g_message_fact_check_hash,
            g_message_fact_check_need_check ? 1 : 0
        );
    }
    return true;
}

static bool patchgram_history_item_has_unrequested_factcheck(void *item) {
    const bool original = g_original_history_item_has_unrequested_factcheck
        ? g_original_history_item_has_unrequested_factcheck(item)
        : false;
    if (original
        || !g_message_settings_enabled
        || !g_message_fact_check_enabled
        || !g_message_fact_check_text[0]) {
        return original;
    }
    const bool forced = patchgram_should_force_fact_check_item(item);
    const bool direct_set = forced && patchgram_set_local_fact_check_on_item(item);
    if (forced && g_message_fact_check_trigger_logs < 256) {
        g_message_fact_check_trigger_logs++;
        patchgram_log(
            "FACT CHECK trigger forced item=%p textLength=%zu directSet=%d",
            item,
            strlen(g_message_fact_check_text),
            direct_set ? 1 : 0
        );
    }
    if (direct_set) {
        return false;
    }
    return forced;
}

static void patchgram_history_item_create_view(
    void *result,
    void *item,
    void *delegate,
    void *replacing
) {
    patchgram_clear_noforwards_on_item(item);
    patchgram_disable_ttl_on_item(item);
    const bool direct_set = patchgram_set_local_fact_check_on_item(item);
    if (direct_set && g_message_fact_check_early_layout_logs < 256) {
        g_message_fact_check_early_layout_logs++;
        patchgram_log(
            "FACT CHECK early createView item=%p result=%p delegate=%p replacing=%p",
            item,
            result,
            delegate,
            replacing
        );
    }
    if (g_original_history_item_create_view) {
        g_original_history_item_create_view(result, item, delegate, replacing);
    }
}

static void patchgram_data_factchecks_request_for(void *factchecks, void *item) {
    if (g_message_settings_enabled
        && g_message_fact_check_enabled
        && g_message_fact_check_text[0]
        && g_message_fact_check_request_for_logs < 256) {
        g_message_fact_check_request_for_logs++;
        patchgram_log(
            "FACT CHECK requestFor called factchecks=%p item=%p textLength=%zu country=%s hash=%lld needCheck=%d",
            factchecks,
            item,
            strlen(g_message_fact_check_text),
            g_message_fact_check_country,
            (long long)g_message_fact_check_hash,
            g_message_fact_check_need_check ? 1 : 0
        );
    }
    if (g_original_data_factchecks_request_for) {
        g_original_data_factchecks_request_for(factchecks, item);
    }
}

/* Strip `noforwards` from incoming MTP objects in the raw received word-buffer,
 * BEFORE Telegram deserializes it. This is the robust fix that defeats channelFull
 * re-setting the channel flag (which beat the render-time createView flag-clears):
 * the flag is gone from the wire data, so it is never set on the HistoryItem or the
 * ChannelData in the first place. Both are `?true` flags -> clearing the bit does NOT
 * change the serialized length, so the rest of the buffer stays valid.
 *   message#7600b9d3 : noforwards = flags.26 (0x04000000), flags is the word after the magic
 *   channel#1c32b11c : noforwards = flags.27 (0x08000000), flags is the word after the magic
 * A flat magic scan finds every (possibly nested) message/channel object. */
static void patchgram_strip_noforwards_in_response(void *response) {
    if (!response || !g_message_settings_enabled || !g_message_allow_noforwards_copy) {
        return;
    }
    uint32_t *words = NULL;
    int64_t word_count = 0;
    memcpy(&words, (const uint8_t *)response + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&word_count, (const uint8_t *)response + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(word_count));
    if (!words || word_count <= 1) {
        return;
    }
    const int64_t scan = (word_count < 262144) ? word_count : 262144;
    static uint32_t strip_logs = 0;
    for (int64_t i = 0; i + 1 < scan; i++) {
        if (words[i] == 0x7600b9d3u) {
            if (words[i + 1] & 0x04000000u) {
                words[i + 1] &= ~0x04000000u;
                if (strip_logs < 96) {
                    strip_logs++;
                    patchgram_log("NOFORWARDS wire strip message word=%lld flagsAfter=0x%x",
                                  (long long)i, words[i + 1]);
                }
            }
        } else if (words[i] == 0x1c32b11cu) {
            if (words[i + 1] & 0x08000000u) {
                words[i + 1] &= ~0x08000000u;
                if (strip_logs < 96) {
                    strip_logs++;
                    patchgram_log("NOFORWARDS wire strip channel word=%lld flagsAfter=0x%x",
                                  (long long)i, words[i + 1]);
                }
            }
        }
    }
}

/* ===== In-dylib TL decoder — turns the raw request/response words into a readable line ===== */
/* Param type opcodes — MUST match scripts/gen_tl_schema_c.py. */
enum {
    PG_TL_INT = 0, PG_TL_LONG = 1, PG_TL_DOUBLE = 2, PG_TL_STRING = 3, PG_TL_BYTES = 4,
    PG_TL_INT128 = 5, PG_TL_INT256 = 6, PG_TL_FLAGS = 7, PG_TL_TRUE = 8, PG_TL_BOXED = 9,
    PG_TL_COMPLEX = 10
};
struct PatchgramTLCtor { uint32_t id; uint32_t name_off; uint16_t pstart; uint16_t pcount; };
struct PatchgramTLParam { uint32_t name_off; uint8_t flag_idx; uint8_t flag_bit; uint8_t vec; uint8_t op; };

/* Schema data (string pool + id-sorted ctor table + param table). Generated from the bundled
 * tl_schema.c.inc and substituted in at apply time, mirroring the memory-patch-table placeholder.
 * A missing .inc degrades to an empty table (every ctor reads as unknown#id). */
__PATCHGRAM_TL_SCHEMA_PLACEHOLDER__

#define PATCHGRAM_TL_VECTOR_ID 0x1cb5c415u
#define PATCHGRAM_TL_MESSAGES_STICKER_SET 0x6e153f16u
#define PATCHGRAM_TL_STAR_GIFT_UPGRADE_PREVIEW 0x3de1dfedu  // payments.starGiftUpgradePreview (sample_attributes)
#define PATCHGRAM_TL_DOC_ATTR_STICKER 0x6319d612u       // documentAttributeSticker
#define PATCHGRAM_TL_DOC_ATTR_CUSTOM_EMOJI 0xfd149899u  // documentAttributeCustomEmoji

struct PatchgramTLReader { const uint8_t *p; size_t len; size_t pos; bool err; };
struct PatchgramTLOut { char *buf; size_t cap; size_t len; bool full; };

/* Star-gift spoof: ctor ids (api.tl layer @61caec4b) used to target fields inside a
 * payments.savedStarGifts response, and a rewrite context threaded through the TL walker.
 * Overwrites are in-place, fixed-size scalars only (date int / id|stars|sender long), so the
 * walk's offsets never shift and the buffer stays valid; flags/counts are never touched. */
#define PATCHGRAM_TL_PAYMENTS_SAVED_STAR_GIFTS 0x95f389b1u
#define PATCHGRAM_TL_SAVED_STAR_GIFT 0x41df43fcu
#define PATCHGRAM_TL_STAR_GIFT 0x313a9547u
#define PATCHGRAM_TL_STAR_GIFT_UNIQUE 0x85f0a9cdu
#define PATCHGRAM_TL_STAR_GIFT_ATTR_BACKDROP 0x9f2504e4u  // starGiftAttributeBackdrop (name, backdrop_id, 4 colors, rarity)
#define PATCHGRAM_TL_STAR_GIFT_ATTR_RARITY 0x36437737u    // starGiftAttributeRarity (permille:int)
#define PATCHGRAM_TL_STAR_GIFT_ATTR_MODEL 0x565251e2u     // starGiftAttributeModel (flags, name, document, rarity)
#define PATCHGRAM_TL_STAR_GIFT_ATTR_PATTERN 0x4e7085eau   // starGiftAttributePattern (name, document, rarity)
#define PATCHGRAM_TL_PEER_USER 0x59511722u
#define PATCHGRAM_TL_PEER_CHANNEL 0xa2a5371eu
#define PATCHGRAM_TL_PEER_CHAT 0x36c6019au
#define PATCHGRAM_TL_DOCUMENT 0x8fd4c4d8u
#define PATCHGRAM_TL_TEXT_WITH_ENTITIES 0x751f3146u
#define PATCHGRAM_TL_PAYMENTS_STAR_GIFTS 0x2ed82995u       // payments.starGifts (available-gifts response)
#define PATCHGRAM_TL_PAYMENTS_GET_STAR_GIFTS 0xc4563590u   // payments.getStarGifts (request)
#define PATCHGRAM_TL_HELP_APP_CONFIG 0xdd18782eu           // help.appConfig (config response: hash, config:JSONValue)
#define PATCHGRAM_TL_JSON_OBJECT 0x99c1d49du               // jsonObject (value:Vector<JSONObjectValue>)
#define PATCHGRAM_TL_JSON_OBJECT_VALUE 0xc0de1bd9u         // jsonObjectValue (key:string, value:JSONValue)
#define PATCHGRAM_TL_JSON_NUMBER 0x2be0dfa4u               // jsonNumber (value:double)
#define PATCHGRAM_TL_JSON_STRING 0xb71e767au               // jsonString (value:string)
#define PATCHGRAM_ACCOUNT_FREEZE_UNTIL 2015320271          // freeze_until_date = 2033-11-11 11:11:11 UTC
#define PATCHGRAM_TL_VECTOR_BYTES 4
#define PATCHGRAM_MAX_GIFT_ENTRIES 64

// Per-savedStarGift byte offsets captured during the walk, used to rebuild the response with a
// caption (the message TextWithEntities is variable-length, so it needs a splice rebuild — done
// only when the result fits within the original buffer, which it does because we empty the gift
// sticker's now-redundant thumbs + file_reference to make room).
struct PatchgramGiftEntry {
    size_t flags_off;       // savedStarGift flags field offset
    uint32_t saved_flags;   // savedStarGift flags value (to set can_upgrade / message-present bits)
    int has_message;        // original flags.2 was set
    size_t msg_off;         // message field offset (existing or insert point)
    size_t msg_len;         // existing message field byte length (0 if absent)
    size_t sg_flags_off;    // starGift flags field offset
    uint32_t sg_flags;      // starGift flags value (limited/auction/upgrade bits)
    size_t avail_at;        // insert point for availability_remains (right after starGift.stars)
    size_t upgrade_at;      // insert point for starGift.upgrade_stars
    size_t auction_at;      // insert point for starGift.auction_slug
    size_t thumbs_off;      // sticker Document.thumbs vector offset (0 if absent) — emptied to free room
    size_t thumbs_len;      // sticker Document.thumbs vector byte length
    size_t fr_off;          // sticker Document.file_reference offset (0 if absent)
    size_t fr_len;          // sticker Document.file_reference byte length
    size_t title_off;       // starGift.title field offset (existing or insert point)
    size_t title_len;       // starGift.title byte length (0 if absent)
    size_t gift_num_at;     // savedStarGift.gift_num insert point (absent → set even so)
    size_t sticker_doc_off; // starGift.sticker whole Document offset
    size_t sticker_doc_len; // starGift.sticker whole Document byte length
    // Unique-gift (starGiftUnique) capture for the Spoof-profile-unique-gifts patch.
    int is_unique;          // this savedStarGift's gift is a starGiftUnique
    size_t u_title_off;     // starGiftUnique.title field offset / byte length (string → rebuild)
    size_t u_title_len;
    size_t bd_name_off;     // starGiftAttributeBackdrop.name field offset / byte length (string → rebuild)
    size_t bd_name_len;
    size_t model_name_off;  // starGiftAttributeModel.name (string → rebuild)
    size_t model_name_len;
    size_t symbol_name_off; // starGiftAttributePattern.name (string → rebuild)
    size_t symbol_name_len;
    // Convert regular→unique: the whole savedStarGift.gift (a starGift) field range, to be replaced by a
    // freshly-built starGiftUnique. gift_doc_* is the regular gift's sticker Document (cloned for the
    // model/pattern attributes of the built unique gift).
    size_t gift_field_off;
    size_t gift_field_len;
};
struct PatchgramTLRewrite {
    uint8_t *base;          // writable buffer base (== reader->p, same memory)
    int64_t sender_id;      // internal peer id; 0 = leave unchanged
    int sender_peer_type;   // when sender_id set: 0 = peerUser, 1 = peerChannel, 2 = peerChat
    int32_t date;           // 0 = leave unchanged
    int64_t gift_id;        // 0 = leave unchanged
    int64_t sticker_id;     // 0 = leave; else overwrite the gift sticker Document.id (custom emoji id)
    int64_t stars;          // 0 = leave unchanged
    int64_t convert_stars;  // 0 = leave; else overwrite starGift + savedStarGift convert_stars
    int32_t available;      // starGift.availability_remains (exact value when force_limited; 0 allowed)
    int32_t total;          // starGift.availability_total (exact value when force_limited; 0 allowed)
    int force_limited;      // when set, supply is authoritative — write available/total verbatim
    int32_t gift_num;       // savedStarGift.gift_num; 0 = leave (in-place overwrite when present)
    int was_refunded;       // set savedStarGift.refunded (flag.9) in place during the walk
    int in_from_id;         // >0 while walking a savedStarGift.from_id Peer
    int in_sticker;         // >0 while walking a starGift.sticker Document
    int unique;             // 1 = Spoof-profile-unique-gifts pass (enables starGiftUnique capture/rewrite)
    int in_unique;          // >0 while walking a starGiftUnique
    int in_backdrop;        // >0 while walking a starGiftAttributeBackdrop (for its nested rarity)
    int in_model;           // >0 while walking a starGiftAttributeModel (its document.id + rarity)
    int in_pattern;         // >0 while walking a starGiftAttributePattern (its document.id + rarity)
    int in_owner;           // >0 while walking starGiftUnique.owner_id (Peer) — in-place id swap
    int in_host;            // >0 while walking starGiftUnique.host_id (Peer) — in-place id swap
    int applied;            // number of fields overwritten
    int capture;            // 1 = record per-gift offsets for the caption rebuild
    int gift_count;
    struct PatchgramGiftEntry *cur;
    struct PatchgramGiftEntry entries[PATCHGRAM_MAX_GIFT_ENTRIES];
    // Generic Document finder — locate a Document by id ANYWHERE in a response (used to capture the
    // target custom-emoji document from getCustomEmojiDocuments / messages.stickerSet / etc.).
    int64_t find_doc_id;    // when != 0, capture the Document with this id
    size_t last_ctor_start; // byte offset of the most recent boxed ctor (set in decode_value)
    size_t found_off;       // start offset of the matched Document
    size_t found_len;       // byte length of the matched Document (0 = not found yet)
    int doc_match_pending;  // 1 between matching a Document's id and the end of its ctor
    int find_sticker_attr;  // when != 0, locate a documentAttributeSticker to convert to customEmoji
    size_t sticker_attr_off;// ctor offset of the documentAttributeSticker (0 = not found)
    uint32_t sticker_attr_flags; // its flags word (only convertible when 0 → no mask_coords)
    int find_first_doc;     // when != 0, capture the FIRST Document of any id (clone template)
    int find_gifts_end;     // when != 0, capture the offset where payments.starGifts.gifts ends
    size_t gifts_end_off;   // = start of the `chats` field (used as a well-formed-response guard)
};

static const struct PatchgramTLCtor *patchgram_tl_find(uint32_t id) {
    int lo = 0, hi = (int)g_tl_ctor_count - 1;
    while (lo <= hi) {
        int mid = (lo + hi) >> 1;
        uint32_t v = g_tl_ctors[mid].id;
        if (v < id) { lo = mid + 1; }
        else if (v > id) { hi = mid - 1; }
        else { return &g_tl_ctors[mid]; }
    }
    return NULL;
}
static void patchgram_tl_put(struct PatchgramTLOut *o, const char *s) {
    if (o->full) { return; }
    while (*s) {
        if (o->len + 1 >= o->cap) { o->full = true; break; }
        o->buf[o->len++] = *s++;
    }
    o->buf[o->len] = 0;
}
static void patchgram_tl_put_raw(struct PatchgramTLOut *o, const uint8_t *b, size_t n) {
    if (o->full) { return; }
    for (size_t i = 0; i < n; i++) {
        if (o->len + 1 >= o->cap) { o->full = true; break; }
        o->buf[o->len++] = (char)b[i];
    }
    o->buf[o->len] = 0;
}
static uint32_t patchgram_tl_u32(struct PatchgramTLReader *r) {
    if (r->pos + 4 > r->len) { r->err = true; return 0; }
    uint32_t v; memcpy(&v, r->p + r->pos, 4); r->pos += 4; return v;
}
static int64_t patchgram_tl_i64(struct PatchgramTLReader *r) {
    if (r->pos + 8 > r->len) { r->err = true; return 0; }
    int64_t v; memcpy(&v, r->p + r->pos, 8); r->pos += 8; return v;
}
static double patchgram_tl_f64(struct PatchgramTLReader *r) {
    if (r->pos + 8 > r->len) { r->err = true; return 0; }
    double v; memcpy(&v, r->p + r->pos, 8); r->pos += 8; return v;
}
static void patchgram_tl_put_hex(struct PatchgramTLOut *o, const uint8_t *b, size_t n) {
    static const char H[] = "0123456789abcdef";
    patchgram_tl_put(o, "0x");
    for (size_t i = 0; i < n && !o->full; i++) {
        char two[2] = { H[b[i] >> 4], H[b[i] & 0xf] };
        patchgram_tl_put_raw(o, (const uint8_t *)two, 2);
    }
}
// TL string/bytes: 1-or-4-byte length prefix, payload, padded to 4. Text shown quoted (raw UTF-8,
// capped), binary shown as hex (capped). Advances the reader past the padded field.
static void patchgram_tl_str(struct PatchgramTLReader *r, struct PatchgramTLOut *o, bool as_text) {
    if (r->pos >= r->len) { r->err = true; return; }
    size_t head, n;
    uint32_t L = r->p[r->pos];
    if (L < 254) { n = L; head = 1; }
    else {
        if (r->pos + 4 > r->len) { r->err = true; return; }
        n = (size_t)r->p[r->pos + 1] | ((size_t)r->p[r->pos + 2] << 8) | ((size_t)r->p[r->pos + 3] << 16);
        head = 4;
    }
    size_t start = r->pos + head;
    if (start + n > r->len) { r->err = true; n = (start < r->len) ? r->len - start : 0; }
    if (as_text) {
        size_t shown = n > 96 ? 96 : n;
        patchgram_tl_put(o, "\"");
        patchgram_tl_put_raw(o, r->p + start, shown);
        if (n > shown) { patchgram_tl_put(o, "\xe2\x80\xa6"); }
        patchgram_tl_put(o, "\"");
    } else {
        size_t shown = n > 32 ? 32 : n;
        patchgram_tl_put_hex(o, r->p + start, shown);
        if (n > shown) { patchgram_tl_put(o, "\xe2\x80\xa6"); }
    }
    size_t total = head + n;
    r->pos += total + ((4 - (total & 3)) & 3);
}

static void patchgram_tl_decode_ctor(uint32_t id, struct PatchgramTLReader *r,
                                     struct PatchgramTLOut *o, int depth, bool with_id,
                                     struct PatchgramTLRewrite *rw);

// Star-gift spoof: if this (ctor, param) is a target scalar, overwrite the value at the reader's
// current position (in place, same size) before the walker consumes it. Only INT/LONG leaf fields
// are touched — never flags or vector counts — so the walk's offsets are unaffected.
static void patchgram_gift_rewrite_field(struct PatchgramTLRewrite *rw, uint32_t ctor,
                                         const struct PatchgramTLParam *p,
                                         struct PatchgramTLReader *r) {
    if (p->vec) { return; }
    const char *name = g_tl_strpool + p->name_off;
    if (ctor == PATCHGRAM_TL_SAVED_STAR_GIFT && p->op == PG_TL_INT
        && rw->date && strcmp(name, "date") == 0) {
        if (r->pos + 4 <= r->len) { int32_t v = rw->date; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if ((ctor == PATCHGRAM_TL_STAR_GIFT || ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE)
               && p->op == PG_TL_LONG && rw->gift_id && strcmp(name, "id") == 0) {
        if (r->pos + 8 <= r->len) { int64_t v = rw->gift_id; memcpy(rw->base + r->pos, &v, 8); rw->applied++; }
    } else if (ctor == PATCHGRAM_TL_STAR_GIFT && p->op == PG_TL_LONG
               && rw->stars && strcmp(name, "stars") == 0) {
        if (r->pos + 8 <= r->len) { int64_t v = rw->stars; memcpy(rw->base + r->pos, &v, 8); rw->applied++; }
    } else if ((ctor == PATCHGRAM_TL_STAR_GIFT || ctor == PATCHGRAM_TL_SAVED_STAR_GIFT)
               && p->op == PG_TL_LONG && rw->convert_stars && strcmp(name, "convert_stars") == 0) {
        // convert-to-Stars value — present on starGift (always) and savedStarGift (flag.4 when set); both
        // overwritten in place. The displayed "convert to N Stars" reads the savedStarGift one.
        if (r->pos + 8 <= r->len) { int64_t v = rw->convert_stars; memcpy(rw->base + r->pos, &v, 8); rw->applied++; }
    } else if (ctor == PATCHGRAM_TL_STAR_GIFT && p->op == PG_TL_INT
               && rw->force_limited && strcmp(name, "availability_remains") == 0) {
        // Already-limited gift (flag.0 present) — overwrite supply verbatim (0 = sold out is valid);
        // adding it to a non-limited gift is done by the rebuild instead.
        if (r->pos + 4 <= r->len) { int32_t v = rw->available; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (ctor == PATCHGRAM_TL_STAR_GIFT && p->op == PG_TL_INT
               && rw->force_limited && strcmp(name, "availability_total") == 0) {
        if (r->pos + 4 <= r->len) { int32_t v = rw->total; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (ctor == PATCHGRAM_TL_SAVED_STAR_GIFT && p->op == PG_TL_INT
               && rw->gift_num && strcmp(name, "gift_num") == 0) {
        // Present only when flag.19 is set — overwrite the gift number in place; adding it to a gift
        // without one is done by the rebuild instead.
        if (r->pos + 4 <= r->len) { int32_t v = rw->gift_num; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (ctor == PATCHGRAM_TL_DOCUMENT && rw->in_sticker && p->op == PG_TL_LONG
               && rw->sticker_id && strcmp(name, "id") == 0) {
        // The gift sticker Document's own id — set it to a custom emoji id so the displayed
        // sticker matches the spoofed gift (Telegram resolves the custom emoji by id).
        if (r->pos + 8 <= r->len) { int64_t v = rw->sticker_id; memcpy(rw->base + r->pos, &v, 8); rw->applied++; }
    } else if ((ctor == PATCHGRAM_TL_PEER_USER || ctor == PATCHGRAM_TL_PEER_CHANNEL)
               && rw->in_from_id && p->op == PG_TL_LONG && rw->sender_id) {
        // peerUser.user_id / peerChannel.channel_id / peerChat.chat_id — the only long in the
        // from_id Peer. Also flip the peer ctor (4 bytes before the id) to the requested peer type.
        if (r->pos + 8 <= r->len && r->pos >= 4) {
            uint32_t peer_ctor = (rw->sender_peer_type == 1) ? PATCHGRAM_TL_PEER_CHANNEL
                               : (rw->sender_peer_type == 2) ? PATCHGRAM_TL_PEER_CHAT
                               : PATCHGRAM_TL_PEER_USER;
            memcpy(rw->base + r->pos - 4, &peer_ctor, sizeof(peer_ctor));
            int64_t v = rw->sender_id;
            memcpy(rw->base + r->pos, &v, 8);
            rw->applied++;
        }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_INT
               && g_unique_num && strcmp(name, "num") == 0) {
        // Unique-gift number (in place) — the displayed "#N". gift_num on the savedStarGift is handled
        // by the existing rw->gift_num path so both stay in sync.
        if (r->pos + 4 <= r->len) { int32_t v = g_unique_num; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_INT
               && g_unique_total_upgraded && strcmp(name, "availability_issued") == 0) {
        if (r->pos + 4 <= r->len) { int32_t v = g_unique_total_upgraded; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_INT
               && g_unique_max_upgraded && strcmp(name, "availability_total") == 0) {
        if (r->pos + 4 <= r->len) { int32_t v = g_unique_max_upgraded; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_LONG
               && g_unique_value_amount && strcmp(name, "value_amount") == 0) {
        // value_amount / value_usd_amount (flags.8) — fixed-size longs, overwritten in place when the
        // gift already carries a value. value_currency (string) is handled in the same pass below.
        if (r->pos + 8 <= r->len) { int64_t v = g_unique_value_amount; memcpy(rw->base + r->pos, &v, 8); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_LONG
               && g_unique_value_usd && strcmp(name, "value_usd_amount") == 0) {
        if (r->pos + 8 <= r->len) { int64_t v = g_unique_value_usd; memcpy(rw->base + r->pos, &v, 8); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_STRING
               && g_unique_value_currency[0] && strcmp(name, "value_currency") == 0) {
        // currency string — same-length in-place replace only (3–4 char codes like TON/USD); a length
        // change would shift every following field, so it's left alone in that rare case.
        size_t end = r->pos;
        if (patchgram_tl_skip_string(rw->base, r->len, &end)) {
            size_t old_span = end - r->pos;
            if (patchgram_tl_string_length(g_unique_value_currency) == old_span) {
                size_t w = r->pos; patchgram_tl_write_string(rw->base, &w, g_unique_value_currency); rw->applied++;
            }
        }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_ATTR_BACKDROP && p->op == PG_TL_INT
               && g_unique_has_backdrop) {
        // backdrop colours — fixed-size ints, overwritten in place (the name is variable-length and is
        // handled by the rebuild). backdrop_id is left as the original (internal id, not user-visible).
        int32_t v = 0; int hit = 1;
        if (strcmp(name, "center_color") == 0) { v = g_unique_backdrop_center; }
        else if (strcmp(name, "edge_color") == 0) { v = g_unique_backdrop_edge; }
        else if (strcmp(name, "pattern_color") == 0) { v = g_unique_backdrop_pattern; }
        else if (strcmp(name, "text_color") == 0) { v = g_unique_backdrop_text; }
        else { hit = 0; }
        if (hit && r->pos + 4 <= r->len) { memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_ATTR_RARITY && rw->in_backdrop
               && p->op == PG_TL_INT && g_unique_has_backdrop && strcmp(name, "permille") == 0) {
        if (r->pos + 4 <= r->len) { int32_t v = g_unique_backdrop_rarity; memcpy(rw->base + r->pos, &v, 4); rw->applied++; }
    } else if (rw->unique && ctor == PATCHGRAM_TL_DOCUMENT && p->op == PG_TL_LONG && strcmp(name, "id") == 0
               && ((rw->in_model && g_unique_model_emoji_id) || (rw->in_pattern && g_unique_symbol_emoji_id))) {
        // model/pattern document id → the chosen custom-emoji id (Telegram resolves the emoji by id).
        if (r->pos + 8 <= r->len) {
            int64_t v = rw->in_model ? g_unique_model_emoji_id : g_unique_symbol_emoji_id;
            memcpy(rw->base + r->pos, &v, 8); rw->applied++;
        }
    } else if (rw->unique && ctor == PATCHGRAM_TL_STAR_GIFT_ATTR_RARITY && p->op == PG_TL_INT
               && strcmp(name, "permille") == 0
               && ((rw->in_model && g_unique_model_emoji_id) || (rw->in_pattern && g_unique_symbol_emoji_id))) {
        if (r->pos + 4 <= r->len) {
            int32_t v = rw->in_model ? g_unique_model_rarity : g_unique_symbol_rarity;
            memcpy(rw->base + r->pos, &v, 4); rw->applied++;
        }
    } else if (rw->unique && p->op == PG_TL_LONG
               && (ctor == PATCHGRAM_TL_PEER_USER || ctor == PATCHGRAM_TL_PEER_CHANNEL || ctor == PATCHGRAM_TL_PEER_CHAT)
               && ((rw->in_owner && g_unique_owner_id) || (rw->in_host && g_unique_host_id))) {
        // existing unique gift: swap owner_id / host_id Peer (ctor 4 bytes back + the id long) in place.
        if (r->pos + 8 <= r->len && r->pos >= 4) {
            int peer_type = rw->in_owner ? g_unique_owner_peer_type : g_unique_host_peer_type;
            int64_t v = rw->in_owner ? g_unique_owner_id : g_unique_host_id;
            uint32_t pc = (peer_type == 1) ? PATCHGRAM_TL_PEER_CHANNEL
                        : (peer_type == 2) ? PATCHGRAM_TL_PEER_CHAT : PATCHGRAM_TL_PEER_USER;
            memcpy(rw->base + r->pos - 4, &pc, 4);
            memcpy(rw->base + r->pos, &v, 8);
            rw->applied++;
        }
    }
}

static void patchgram_tl_decode_value(uint8_t vec, uint8_t op, struct PatchgramTLReader *r,
                                      struct PatchgramTLOut *o, int depth, struct PatchgramTLRewrite *rw) {
    if (r->err || (o->full && !rw)) { return; }
    if (depth > 24) { r->err = true; return; }
    if (vec) {
        if (vec == 1) {
            if (patchgram_tl_u32(r) != PATCHGRAM_TL_VECTOR_ID) { patchgram_tl_put(o, "<novec>"); r->err = true; return; }
        }
        int32_t n = (int32_t)patchgram_tl_u32(r);
        if (n < 0 || n > 200000) { patchgram_tl_put(o, "<badvec>"); r->err = true; return; }
        patchgram_tl_put(o, "[");
        for (int32_t k = 0; k < n && !r->err && (!o->full || rw); k++) {
            if (k) { patchgram_tl_put(o, ", "); }
            patchgram_tl_decode_value(0, op, r, o, depth + 1, rw);
        }
        patchgram_tl_put(o, "]");
        return;
    }
    char tmp[48];
    switch (op) {
        case PG_TL_INT:    snprintf(tmp, sizeof tmp, "%d", (int32_t)patchgram_tl_u32(r)); patchgram_tl_put(o, tmp); break;
        case PG_TL_FLAGS:  snprintf(tmp, sizeof tmp, "0x%x", patchgram_tl_u32(r)); patchgram_tl_put(o, tmp); break;
        case PG_TL_LONG:   snprintf(tmp, sizeof tmp, "%lld", (long long)patchgram_tl_i64(r)); patchgram_tl_put(o, tmp); break;
        case PG_TL_DOUBLE: snprintf(tmp, sizeof tmp, "%g", patchgram_tl_f64(r)); patchgram_tl_put(o, tmp); break;
        case PG_TL_INT128: if (r->pos + 16 <= r->len) { patchgram_tl_put_hex(o, r->p + r->pos, 16); r->pos += 16; } else { r->err = true; } break;
        case PG_TL_INT256: if (r->pos + 32 <= r->len) { patchgram_tl_put_hex(o, r->p + r->pos, 32); r->pos += 32; } else { r->err = true; } break;
        case PG_TL_STRING: patchgram_tl_str(r, o, true); break;
        case PG_TL_BYTES:  patchgram_tl_str(r, o, false); break;
        case PG_TL_TRUE:   patchgram_tl_put(o, "true"); break;
        case PG_TL_BOXED:  if (rw) { rw->last_ctor_start = r->pos; } patchgram_tl_decode_ctor(patchgram_tl_u32(r), r, o, depth + 1, false, rw); break;
        default:           patchgram_tl_put(o, "<complex>"); r->err = true; break;
    }
}

static void patchgram_tl_decode_ctor(uint32_t id, struct PatchgramTLReader *r,
                                     struct PatchgramTLOut *o, int depth, bool with_id,
                                     struct PatchgramTLRewrite *rw) {
    if (r->err || (o->full && !rw)) { return; }
    if (depth > 24) { r->err = true; return; }
    char scratch[24];
    const struct PatchgramTLCtor *c = patchgram_tl_find(id);
    if (!c) {
        snprintf(scratch, sizeof scratch, "unknown#%08x", id);
        patchgram_tl_put(o, scratch);
        r->err = true;  /* unknown params → stop rather than misparse */
        return;
    }
    patchgram_tl_put(o, g_tl_strpool + c->name_off);
    if (with_id) { snprintf(scratch, sizeof scratch, "#%08x", id); patchgram_tl_put(o, scratch); }
    if (rw && rw->find_sticker_attr && rw->sticker_attr_off == 0
        && id == PATCHGRAM_TL_DOC_ATTR_STICKER && r->pos + 4 <= r->len) {
        rw->sticker_attr_off = rw->last_ctor_start;          // where the ctor u32 sits
        memcpy(&rw->sticker_attr_flags, r->p + r->pos, 4);   // its flags field (first param)
    }
    if (rw && rw->find_first_doc && rw->found_len == 0 && !rw->doc_match_pending
        && id == PATCHGRAM_TL_DOCUMENT) {
        rw->found_off = rw->last_ctor_start;  // capture the first Document's byte range (clone template)
        rw->doc_match_pending = 1;
    }
    if (c->pcount == 0) { return; }
    if (rw && rw->capture && id == PATCHGRAM_TL_SAVED_STAR_GIFT && rw->gift_count < PATCHGRAM_MAX_GIFT_ENTRIES) {
        rw->cur = &rw->entries[rw->gift_count];
        rw->gift_count++;
        memset(rw->cur, 0, sizeof(*rw->cur));
    }
    // Unique-gift pass: track being inside a starGiftUnique / its backdrop attribute for the duration
    // of this ctor's param walk (balanced decrement before the closing put). No early returns lie
    // between here and that put, so the counters never leak.
    int entered_unique = 0, entered_backdrop = 0, entered_model = 0, entered_pattern = 0;
    if (rw && rw->unique && id == PATCHGRAM_TL_STAR_GIFT_UNIQUE) {
        rw->in_unique++; entered_unique = 1;
        if (rw->capture && rw->cur) { rw->cur->is_unique = 1; }
    } else if (rw && rw->unique && id == PATCHGRAM_TL_STAR_GIFT_ATTR_BACKDROP) {
        rw->in_backdrop++; entered_backdrop = 1;
    } else if (rw && rw->unique && id == PATCHGRAM_TL_STAR_GIFT_ATTR_MODEL) {
        rw->in_model++; entered_model = 1;
    } else if (rw && rw->unique && id == PATCHGRAM_TL_STAR_GIFT_ATTR_PATTERN) {
        rw->in_pattern++; entered_pattern = 1;
    }
    uint32_t flagvals[256];
    memset(flagvals, 0, sizeof flagvals);
    patchgram_tl_put(o, " { ");
    bool first = true;
    for (uint16_t i = 0; i < c->pcount && !r->err && (!o->full || rw); i++) {
        const struct PatchgramTLParam *p = &g_tl_params[c->pstart + i];
        const char *pname0 = g_tl_strpool + p->name_off;
        // Generic Document finder: when this is a Document's id field and it matches, remember the
        // document's start (the boxed ctor offset recorded in decode_value) and its end (below).
        if (rw && rw->find_doc_id && rw->found_len == 0 && id == PATCHGRAM_TL_DOCUMENT
            && p->op == PG_TL_LONG && strcmp(pname0, "id") == 0 && r->pos + 8 <= r->len) {
            int64_t did = 0; memcpy(&did, r->p + r->pos, 8);
            if (did == rw->find_doc_id) { rw->found_off = rw->last_ctor_start; rw->doc_match_pending = 1; }
        }
        const bool capture_saved_gift_message = rw && rw->capture && rw->cur
            && id == PATCHGRAM_TL_SAVED_STAR_GIFT && strcmp(pname0, "message") == 0;
        const bool capture_star_gift_title = rw && rw->capture && rw->cur
            && id == PATCHGRAM_TL_STAR_GIFT && strcmp(pname0, "title") == 0;
        const bool capture_unique_title = rw && rw->unique && rw->capture && rw->cur
            && id == PATCHGRAM_TL_STAR_GIFT_UNIQUE && strcmp(pname0, "title") == 0;
        const bool capture_backdrop_name = rw && rw->unique && rw->capture && rw->cur
            && id == PATCHGRAM_TL_STAR_GIFT_ATTR_BACKDROP && strcmp(pname0, "name") == 0;
        const bool capture_model_name = rw && rw->unique && rw->capture && rw->cur
            && id == PATCHGRAM_TL_STAR_GIFT_ATTR_MODEL && strcmp(pname0, "name") == 0;
        const bool capture_symbol_name = rw && rw->unique && rw->capture && rw->cur
            && id == PATCHGRAM_TL_STAR_GIFT_ATTR_PATTERN && strcmp(pname0, "name") == 0;
        const bool capture_gift_field = rw && rw->unique && rw->capture && rw->cur
            && id == PATCHGRAM_TL_SAVED_STAR_GIFT && strcmp(pname0, "gift") == 0;
        if (capture_saved_gift_message) { rw->cur->msg_off = r->pos; }  // insert point (set even if absent)
        if (capture_star_gift_title) { rw->cur->title_off = r->pos; }   // insert point (set even if absent)
        if (capture_unique_title) { rw->cur->u_title_off = r->pos; }    // starGiftUnique.title (string)
        if (capture_backdrop_name) { rw->cur->bd_name_off = r->pos; }   // backdrop.name (string)
        if (capture_model_name) { rw->cur->model_name_off = r->pos; }   // model.name (string)
        if (capture_symbol_name) { rw->cur->symbol_name_off = r->pos; } // pattern.name (string)
        if (capture_gift_field) { rw->cur->gift_field_off = r->pos; }   // savedStarGift.gift (StarGift)
        // starGift / savedStarGift insert points — captured at the param boundary even when the
        // optional field is absent (flag unset), so the rebuild knows exactly where to splice it in.
        if (rw && rw->capture && rw->cur && id == PATCHGRAM_TL_STAR_GIFT) {
            if (strcmp(pname0, "availability_remains") == 0) { rw->cur->avail_at = r->pos; }
            else if (strcmp(pname0, "upgrade_stars") == 0) { rw->cur->upgrade_at = r->pos; }
            else if (strcmp(pname0, "auction_slug") == 0) { rw->cur->auction_at = r->pos; }
        } else if (rw && rw->capture && rw->cur && id == PATCHGRAM_TL_SAVED_STAR_GIFT) {
            if (strcmp(pname0, "gift_num") == 0) { rw->cur->gift_num_at = r->pos; }
        }
        if (rw && rw->find_gifts_end && id == PATCHGRAM_TL_PAYMENTS_STAR_GIFTS
            && strcmp(pname0, "chats") == 0) {
            rw->gifts_end_off = r->pos;  // gifts vector ends here; insert injected gifts before chats
        }
        if (p->op == PG_TL_FLAGS) {
            const size_t flags_pos = r->pos;
            uint32_t v = patchgram_tl_u32(r);
            // refunded#flag.9 is a pure boolean — set it in place during the walk (works even with no
            // rebuild). flag.9 gates no field, so it never desyncs the structure.
            if (rw && id == PATCHGRAM_TL_SAVED_STAR_GIFT && rw->was_refunded && !((v >> 9) & 1u)) {
                v |= (1u << 9);
                if (flags_pos + 4 <= r->len) { memcpy(rw->base + flags_pos, &v, 4); rw->applied++; }
            }
            if (rw && rw->capture && rw->cur && id == PATCHGRAM_TL_SAVED_STAR_GIFT) {
                rw->cur->flags_off = flags_pos; rw->cur->saved_flags = v;
            } else if (rw && rw->capture && rw->cur && id == PATCHGRAM_TL_STAR_GIFT) {
                rw->cur->sg_flags_off = flags_pos; rw->cur->sg_flags = v;
            }
            if (i < 256) { flagvals[i] = v; }
            if (!first) { patchgram_tl_put(o, ", "); }
            first = false;
            patchgram_tl_put(o, g_tl_strpool + p->name_off);
            snprintf(scratch, sizeof scratch, "=0x%x", v);
            patchgram_tl_put(o, scratch);
            continue;
        }
        if (p->flag_idx != 0xFF) {
            uint32_t fv = flagvals[p->flag_idx];  // flag_idx is uint8 → always in [0,255]
            if (!((fv >> p->flag_bit) & 1u)) { continue; }
            if (p->op == PG_TL_TRUE) {
                if (!first) { patchgram_tl_put(o, ", "); }
                first = false;
                patchgram_tl_put(o, g_tl_strpool + p->name_off);
                patchgram_tl_put(o, "=true");
                continue;
            }
        }
        if (!first) { patchgram_tl_put(o, ", "); }
        first = false;
        patchgram_tl_put(o, g_tl_strpool + p->name_off);
        patchgram_tl_put(o, "=");
        bool mark_from_id = false;
        bool mark_sticker = false;
        bool mark_owner = false;
        bool mark_host = false;
        if (rw) {
            patchgram_gift_rewrite_field(rw, id, p, r);
            const char *pname = g_tl_strpool + p->name_off;
            if (id == PATCHGRAM_TL_SAVED_STAR_GIFT && p->op == PG_TL_BOXED && !p->vec
                && strcmp(pname, "from_id") == 0) {
                mark_from_id = true;
                rw->in_from_id++;
            } else if (id == PATCHGRAM_TL_STAR_GIFT && p->op == PG_TL_BOXED && !p->vec
                       && strcmp(pname, "sticker") == 0) {
                mark_sticker = true;
                rw->in_sticker++;
            } else if (rw->unique && id == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_BOXED && !p->vec
                       && strcmp(pname, "owner_id") == 0) {
                mark_owner = true;
                rw->in_owner++;
            } else if (rw->unique && id == PATCHGRAM_TL_STAR_GIFT_UNIQUE && p->op == PG_TL_BOXED && !p->vec
                       && strcmp(pname, "host_id") == 0) {
                mark_host = true;
                rw->in_host++;
            }
        }
        const size_t before_pos = r->pos;
        patchgram_tl_decode_value(p->vec, p->op, r, o, depth, rw);
        if (mark_from_id) { rw->in_from_id--; }
        if (mark_owner) { rw->in_owner--; }
        if (mark_host) { rw->in_host--; }
        if (mark_sticker) {
            rw->in_sticker--;
            if (rw->capture && rw->cur) { rw->cur->sticker_doc_off = before_pos; rw->cur->sticker_doc_len = r->pos - before_pos; }
        }
        if (rw && rw->capture && rw->cur) {
            if (capture_saved_gift_message) {
                rw->cur->msg_len = r->pos - before_pos;
                rw->cur->has_message = 1;
            } else if (capture_star_gift_title) {
                rw->cur->title_len = r->pos - before_pos;
            } else if (capture_unique_title) {
                rw->cur->u_title_len = r->pos - before_pos;
            } else if (capture_backdrop_name) {
                rw->cur->bd_name_len = r->pos - before_pos;
            } else if (capture_model_name) {
                rw->cur->model_name_len = r->pos - before_pos;
            } else if (capture_symbol_name) {
                rw->cur->symbol_name_len = r->pos - before_pos;
            } else if (capture_gift_field) {
                rw->cur->gift_field_len = r->pos - before_pos;
            } else if (rw->in_sticker && id == PATCHGRAM_TL_DOCUMENT) {
                const char *pn = g_tl_strpool + p->name_off;
                if (strcmp(pn, "thumbs") == 0) { rw->cur->thumbs_off = before_pos; rw->cur->thumbs_len = r->pos - before_pos; }
                else if (strcmp(pn, "file_reference") == 0) { rw->cur->fr_off = before_pos; rw->cur->fr_len = r->pos - before_pos; }
            }
        }
    }
    if (rw && rw->doc_match_pending && id == PATCHGRAM_TL_DOCUMENT && !r->err) {
        rw->found_len = r->pos - rw->found_off;  // full Document byte range now known
        rw->doc_match_pending = 0;
        rw->find_doc_id = 0;
    }
    if (entered_unique) { rw->in_unique--; }
    if (entered_backdrop) { rw->in_backdrop--; }
    if (entered_model) { rw->in_model--; }
    if (entered_pattern) { rw->in_pattern--; }
    patchgram_tl_put(o, " }");
}

// Decode one MTProto object (the body words) into `out`. Never crashes: on an unknown ctor or a
// short/odd buffer it stops and keeps whatever decoded so far (+ "…" if the output was truncated).
static void patchgram_tl_decode(const uint8_t *body, size_t bytelen, char *out, size_t outcap) {
    if (outcap < 8) { if (outcap) { out[0] = 0; } return; }
    out[0] = 0;
    struct PatchgramTLReader r = { body, bytelen, 0, false };
    struct PatchgramTLOut o = { out, outcap, 0, false };
    uint32_t top = patchgram_tl_u32(&r);
    if (r.err) { patchgram_tl_put(&o, "<empty>"); return; }
    patchgram_tl_decode_ctor(top, &r, &o, 0, true, NULL);
    if (o.full && outcap >= 4) { memcpy(out + outcap - 4, "\xe2\x80\xa6", 3); out[outcap - 1] = 0; }
}

// Walk a payments.savedStarGifts response IN PLACE, overwriting the configured scalar fields of each
// savedStarGift (sender id / date / gift id / stars). Returns the number of fields overwritten.
// Output text is suppressed (full sink); the rw context makes the walk ignore the output cap so it
// traverses the whole response. No-op unless the top constructor is payments.savedStarGifts.
static int patchgram_tl_rewrite_saved_star_gifts(uint8_t *body, size_t bytelen,
                                                 struct PatchgramTLRewrite *rw) {
    if (!body || bytelen < 4) { return 0; }
    struct PatchgramTLReader r = { body, bytelen, 0, false };
    char sink = 0;
    struct PatchgramTLOut o = { &sink, 1, 0, true };  // full=true → patchgram_tl_put no-ops
    rw->base = body;
    rw->in_from_id = 0;
    rw->applied = 0;
    uint32_t top = patchgram_tl_u32(&r);
    if (r.err || top != PATCHGRAM_TL_PAYMENTS_SAVED_STAR_GIFTS) { return 0; }
    patchgram_tl_decode_ctor(top, &r, &o, 0, false, rw);
    return rw->applied;
}

#define PATCHGRAM_TL_GET_SAVED_STAR_GIFTS 0xa319e569u
#define PATCHGRAM_TL_INPUT_PEER_SELF 0x7da07ec9u
#define PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS 32
static int32_t g_gift_request_ids[PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS] = {0};
static int g_gift_request_head = 0;
static pthread_mutex_t g_gift_request_mutex = PTHREAD_MUTEX_INITIALIZER;

static void patchgram_track_gift_request(int32_t request_id) {
    if (request_id == 0) { return; }
    pthread_mutex_lock(&g_gift_request_mutex);
    g_gift_request_ids[g_gift_request_head] = request_id;
    g_gift_request_head = (g_gift_request_head + 1) % PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS;
    pthread_mutex_unlock(&g_gift_request_mutex);
}

static bool patchgram_take_gift_request(int32_t request_id) {
    if (request_id == 0) { return false; }
    bool found = false;
    pthread_mutex_lock(&g_gift_request_mutex);
    for (int i = 0; i < PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS; i++) {
        if (g_gift_request_ids[i] == request_id) { g_gift_request_ids[i] = 0; found = true; break; }
    }
    pthread_mutex_unlock(&g_gift_request_mutex);
    return found;
}

// The unique-gifts pass tracks getSavedStarGifts requests in its OWN ring (separate target mode), so it
// can take() independently of the base spoof — both can process the same response, each per its own mode.
static int32_t g_gift_unique_request_ids[PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS] = {0};
static int g_gift_unique_request_head = 0;
static void patchgram_track_unique_gift_request(int32_t request_id) {
    if (request_id == 0) { return; }
    pthread_mutex_lock(&g_gift_request_mutex);
    g_gift_unique_request_ids[g_gift_unique_request_head] = request_id;
    g_gift_unique_request_head = (g_gift_unique_request_head + 1) % PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS;
    pthread_mutex_unlock(&g_gift_request_mutex);
}
static bool patchgram_take_unique_gift_request(int32_t request_id) {
    if (request_id == 0) { return false; }
    bool found = false;
    pthread_mutex_lock(&g_gift_request_mutex);
    for (int i = 0; i < PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS; i++) {
        if (g_gift_unique_request_ids[i] == request_id) { g_gift_unique_request_ids[i] = 0; found = true; break; }
    }
    pthread_mutex_unlock(&g_gift_request_mutex);
    return found;
}

// A payments.getSavedStarGifts request that `mode` wants spoofed → returns its request_id.
static bool patchgram_gift_request_should_spoof(void *request_ref, enum PatchgramTargetMode mode,
                                                int32_t *request_id_out) {
    if (!request_ref) { return false; }
    void *request_data = NULL;
    memcpy(&request_data, request_ref, sizeof(request_data));
    if (!request_data) { return false; }
    uint32_t *words = NULL;
    int64_t word_count = 0;
    memcpy(&words, (const uint8_t *)request_data + PATCHGRAM_QVECTOR_PTR_OFFSET, sizeof(words));
    memcpy(&word_count, (const uint8_t *)request_data + PATCHGRAM_QVECTOR_SIZE_OFFSET, sizeof(word_count));
    if (!words || word_count <= PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION) { return false; }
    if (words[PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION] != PATCHGRAM_TL_GET_SAVED_STAR_GIFTS) { return false; }
    int32_t request_id = 0;
    memcpy(&request_id, (const uint8_t *)request_data + PATCHGRAM_REQUEST_DATA_REQUEST_ID_OFFSET, sizeof(request_id));
    if (request_id == 0) { return false; }
    bool has_self = false;
    const size_t max_scan = (word_count < 256) ? (size_t)word_count : 256;
    for (size_t i = PATCHGRAM_SERIALIZED_REQUEST_BODY_POSITION; i < max_scan; i++) {
        if (words[i] == PATCHGRAM_TL_INPUT_PEER_SELF) { has_self = true; break; }
    }
    if (mode == PatchgramTargetOnlySelf && !has_self) { return false; }
    if (mode == PatchgramTargetAllExceptSelf && has_self) { return false; }
    *request_id_out = request_id;
    return true;
}

// payments.getUniqueStarGiftValueInfo#4365af6b — the "value details" request. For a CONVERTED gift its
// slug is our marker ("Patchgram") which the server rejects (STARGIFT_SLUG_INVALID), so we track the
// request and fabricate a uniqueStarGiftValueInfo reply over the error (same technique as fragment phone).
#define PATCHGRAM_TL_GET_UNIQUE_STAR_GIFT_VALUE_INFO 0x4365af6bu
static int32_t g_unique_value_info_request_ids[PATCHGRAM_MAX_TRACKED_GIFT_REQUESTS] = {0};
static int g_unique_value_info_request_head = 0;
static pthread_mutex_t g_unique_value_info_request_mutex = PTHREAD_MUTEX_INITIALIZER;
static void patchgram_track_unique_value_info_request(int32_t request_id) {
    if (request_id == 0) { return; }

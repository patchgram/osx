    patchgram_json_string(json, "fragmentPhoneUrl", fragment_phone_url, sizeof(fragment_phone_url));
    patchgram_json_string(json, "giftSpoofTargetMode", gift_spoof_target_mode, sizeof(gift_spoof_target_mode));
    patchgram_json_string(json, "giftSpoofCaption", gift_spoof_caption, sizeof(gift_spoof_caption));
    patchgram_json_string(json, "customListUsernamesPayload", custom_list_usernames_payload, sizeof(custom_list_usernames_payload));
    patchgram_json_string(json, "messageFactCheckText", message_fact_check_text, sizeof(message_fact_check_text));
    patchgram_json_string(json, "messageFactCheckCountry", message_fact_check_country, sizeof(message_fact_check_country));
    if (!self_phone_target_mode[0]) {
        snprintf(self_phone_target_mode, sizeof(self_phone_target_mode), "%s", "onlySelf");
    }
    if (!self_user_id_target_mode[0]) {
        snprintf(self_user_id_target_mode, sizeof(self_user_id_target_mode), "%s", "onlySelf");
    }
    if (!personal_channel_target_mode[0]) {
        snprintf(personal_channel_target_mode, sizeof(personal_channel_target_mode), "%s", "onlySelf");
    }
    if (!fragment_phone_target_mode[0]) {
        snprintf(fragment_phone_target_mode, sizeof(fragment_phone_target_mode), "%s", "onlySelf");
    }
    if (!gift_spoof_target_mode[0]) {
        snprintf(gift_spoof_target_mode, sizeof(gift_spoof_target_mode), "%s", "onlySelf");
    }
    g_gift_spoof_enabled = patchgram_json_bool(json, "giftSpoofEnabled", false);
    g_gift_spoof_target_mode = patchgram_parse_target_mode(gift_spoof_target_mode);
    g_gift_spoof_sender_id = patchgram_json_i64(json, "giftSpoofSenderId", 0);
    g_gift_spoof_sender_peer_type = (int)patchgram_json_i64(json, "giftSpoofSenderPeerType", 0);
    g_gift_spoof_date = (int32_t)patchgram_json_i64(json, "giftSpoofDate", 0);
    g_gift_spoof_gift_id = patchgram_json_i64(json, "giftSpoofGiftId", 0);
    g_gift_spoof_sticker_id = patchgram_json_i64(json, "giftSpoofStickerId", 0);
    g_gift_spoof_stars = patchgram_json_i64(json, "giftSpoofStars", 0);
    g_gift_spoof_convert_stars = patchgram_json_i64(json, "giftSpoofConvertStars", 0);
    snprintf(g_gift_spoof_caption, sizeof(g_gift_spoof_caption), "%s", gift_spoof_caption);
    g_gift_spoof_available = (int32_t)patchgram_json_i64(json, "giftSpoofAvailable", 0);
    g_gift_spoof_total = (int32_t)patchgram_json_i64(json, "giftSpoofTotal", 0);
    g_gift_spoof_force_limited = patchgram_json_bool(json, "giftSpoofLimited", false) ? 1 : 0;
    g_gift_spoof_force_upgrade = patchgram_json_bool(json, "giftSpoofUpgrade", false) ? 1 : 0;
    g_gift_spoof_force_auction = patchgram_json_bool(json, "giftSpoofAuction", false) ? 1 : 0;
    g_gift_spoof_upgrade_price = patchgram_json_i64(json, "giftSpoofUpgradePrice", 0);
    gift_spoof_auction_title[0] = 0;
    patchgram_json_string(json, "giftSpoofAuctionTitle", gift_spoof_auction_title, sizeof(gift_spoof_auction_title));
    snprintf(g_gift_spoof_auction_title, sizeof(g_gift_spoof_auction_title), "%s", gift_spoof_auction_title);
    g_gift_spoof_gift_num = (int32_t)patchgram_json_i64(json, "giftSpoofGiftNum", 0);
    g_gift_spoof_was_refunded = patchgram_json_bool(json, "giftSpoofWasRefunded", false) ? 1 : 0;
    // Spoof profile UNIQUE gifts: title/num + backdrop (name + colours + rarity). sender/date are reused
    // from the base giftSpoof* values above.
    g_gift_unique_enabled = patchgram_json_bool(json, "giftUniqueEnabled", false) ? 1 : 0;
    g_fake_transfer_enabled = patchgram_json_bool(json, "giftFakeTransferEnabled", false) ? 1 : 0;
    {
        char unique_title[256]; unique_title[0] = 0;
        patchgram_json_string(json, "giftUniqueTitle", unique_title, sizeof(unique_title));
        snprintf(g_unique_title, sizeof(g_unique_title), "%s", unique_title);
        char unique_bd_name[128]; unique_bd_name[0] = 0;
        patchgram_json_string(json, "giftUniqueBackdropName", unique_bd_name, sizeof(unique_bd_name));
        snprintf(g_unique_backdrop_name, sizeof(g_unique_backdrop_name), "%s", unique_bd_name);
    }
    g_unique_num = (int32_t)patchgram_json_i64(json, "giftUniqueNum", 0);
    g_unique_has_backdrop = patchgram_json_bool(json, "giftUniqueHasBackdrop", false) ? 1 : 0;
    g_unique_backdrop_center = (int32_t)patchgram_json_i64(json, "giftUniqueBackdropCenter", 0);
    g_unique_backdrop_edge = (int32_t)patchgram_json_i64(json, "giftUniqueBackdropEdge", 0);
    g_unique_backdrop_pattern = (int32_t)patchgram_json_i64(json, "giftUniqueBackdropPattern", 0);
    g_unique_backdrop_text = (int32_t)patchgram_json_i64(json, "giftUniqueBackdropText", 0);
    g_unique_backdrop_rarity = (int32_t)patchgram_json_i64(json, "giftUniqueBackdropRarity", 0);
    {
        char unique_target_mode[32]; unique_target_mode[0] = 0;
        patchgram_json_string(json, "giftUniqueTargetMode", unique_target_mode, sizeof(unique_target_mode));
        g_gift_unique_target_mode = patchgram_parse_target_mode(unique_target_mode);
        char unique_gift_name[128]; unique_gift_name[0] = 0;
        patchgram_json_string(json, "giftUniqueGiftName", unique_gift_name, sizeof(unique_gift_name));
        snprintf(g_unique_gift_name, sizeof(g_unique_gift_name), "%s", unique_gift_name);
        // Title fallback: empty title → use the chosen gift's name (e.g. "Artisan Brick").
        if (!g_unique_title[0] && g_unique_gift_name[0]) {
            snprintf(g_unique_title, sizeof(g_unique_title), "%s", g_unique_gift_name);
        }
        char unique_model_name[128]; unique_model_name[0] = 0;
        patchgram_json_string(json, "giftUniqueModelName", unique_model_name, sizeof(unique_model_name));
        snprintf(g_unique_model_name, sizeof(g_unique_model_name), "%s", unique_model_name);
        char unique_symbol_name[128]; unique_symbol_name[0] = 0;
        patchgram_json_string(json, "giftUniqueSymbolName", unique_symbol_name, sizeof(unique_symbol_name));
        snprintf(g_unique_symbol_name, sizeof(g_unique_symbol_name), "%s", unique_symbol_name);
    }
    g_unique_model_emoji_id = patchgram_json_i64(json, "giftUniqueModelEmojiId", 0);
    g_unique_model_rarity = (int32_t)patchgram_json_i64(json, "giftUniqueModelRarity", 0);
    g_unique_symbol_emoji_id = patchgram_json_i64(json, "giftUniqueSymbolEmojiId", 0);
    g_unique_symbol_rarity = (int32_t)patchgram_json_i64(json, "giftUniqueSymbolRarity", 0);
    g_unique_total_upgraded = (int32_t)patchgram_json_i64(json, "giftUniqueTotalUpgraded", 0);
    g_unique_max_upgraded = (int32_t)patchgram_json_i64(json, "giftUniqueMaxUpgraded", 0);
    g_unique_date = (int32_t)patchgram_json_i64(json, "giftUniqueDate", 0);
    g_unique_sender_id = patchgram_json_i64(json, "giftUniqueSenderId", 0);
    g_unique_sender_peer_type = (int)patchgram_json_i64(json, "giftUniqueSenderPeerType", 0);
    g_unique_owner_id = patchgram_json_i64(json, "giftUniqueOwnerId", 0);
    g_unique_owner_peer_type = (int)patchgram_json_i64(json, "giftUniqueOwnerPeerType", 0);
    g_unique_host_id = patchgram_json_i64(json, "giftUniqueHostId", 0);
    g_unique_host_peer_type = (int)patchgram_json_i64(json, "giftUniqueHostPeerType", 0);
    {
        char unique_owner_addr[192]; unique_owner_addr[0] = 0;
        patchgram_json_string(json, "giftUniqueOwnerAddress", unique_owner_addr, sizeof(unique_owner_addr));
        snprintf(g_unique_owner_address, sizeof(g_unique_owner_address), "%s", unique_owner_addr);
    }
    g_unique_value_amount = patchgram_json_i64(json, "giftUniqueValueAmount", 0);
    g_unique_value_usd = patchgram_json_i64(json, "giftUniqueValueUsdAmount", 0);
    g_unique_last_resale_amount = patchgram_json_i64(json, "giftUniqueLastResaleAmount", 0);
    g_unique_last_resale_date = (int32_t)patchgram_json_i64(json, "giftUniqueLastResaleDate", 0);
    {
        char cur[16]; cur[0] = 0;
        patchgram_json_string(json, "giftUniqueValueCurrency", cur, sizeof(cur));
        snprintf(g_unique_value_currency, sizeof(g_unique_value_currency), "%s", cur);
        cur[0] = 0;
        patchgram_json_string(json, "giftUniqueLastResaleCurrency", cur, sizeof(cur));
        snprintf(g_unique_last_resale_currency, sizeof(g_unique_last_resale_currency), "%s", cur);
    }
    // Show hidden gifts: enabled flag + the gift→custom-emoji pairs to inject. The pairs are the known
    // hidden gifts with their api.changes.tg emoji ids (baked in); an optional config
    // "giftHiddenPayload" ("giftId:emojiId,…") overrides them.
    g_show_hidden_gifts_enabled = patchgram_json_bool(json, "giftShowHiddenEnabled", false) ? 1 : 0;
    g_account_freeze_enabled = patchgram_json_bool(json, "accountFreezeEnabled", false) ? 1 : 0;
    g_hidden_gift_count = 0;
    {
        static char hidden_payload[PATCHGRAM_MAX_HIDDEN_GIFTS * 48];
        hidden_payload[0] = 0;
        patchgram_json_string(json, "giftHiddenPayload", hidden_payload, sizeof(hidden_payload));
        const char *p = hidden_payload;
        while (*p && g_hidden_gift_count < PATCHGRAM_MAX_HIDDEN_GIFTS) {
            char *end = NULL;
            long long gid = strtoll(p, &end, 10);
            if (end == p || *end != ':') { break; }
            p = end + 1;
            long long eid = strtoll(p, &end, 10);
            if (end == p) { break; }
            p = end;
            if (gid != 0 && eid != 0) {
                g_hidden_gift_ids[g_hidden_gift_count] = (int64_t)gid;
                g_hidden_emoji_ids[g_hidden_gift_count] = (int64_t)eid;
                g_hidden_gift_count++;
            }
            while (*p == ',' || *p == ' ') { p++; }
        }
        if (g_hidden_gift_count == 0) {  // no override → use the baked-in hidden gifts
            static const int64_t def_gift[] = {
                6026193266406327981LL, 5969796561943660080LL, 5935895822435615975LL,
                5893356958802511476LL, 5866352046986232958LL, 5801108895304779062LL,
                5800655655995968830LL, 5922558454332916696LL, 5956217000635139069LL };
            static const int64_t def_emoji[] = {
                5447213743417105726LL, 5393309541620291208LL, 5359736160224586485LL,
                5317000922096769303LL, 5294268489127731562LL, 5224628072619216265LL,
                5226661632259691727LL, 5345935030143196497LL, 5379850840691476775LL };
            const int n = (int)(sizeof(def_gift) / sizeof(def_gift[0]));
            for (int i = 0; i < n && i < PATCHGRAM_MAX_HIDDEN_GIFTS; i++) {
                g_hidden_gift_ids[i] = def_gift[i];
                g_hidden_emoji_ids[i] = def_emoji[i];
            }
            g_hidden_gift_count = n;
        }

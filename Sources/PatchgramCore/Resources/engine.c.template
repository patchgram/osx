// Minimal absolute SVG path parser (M,L,C,V,H,Z) → appends to a CGMutablePath.
static void patchgram_svg_append(CGMutablePathRef path, const char *d) {
    double cx = 0, cy = 0, nums[8]; int n = 0; char cmd = 0;
    const char *p = d;
    while (*p) {
        while (*p == ' ' || *p == ',' || *p == '\n' || *p == '\t') p++;
        if (!*p) break;
        char c = *p;
        if ((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')) {
            cmd = c; p++; n = 0;
            if (cmd == 'Z' || cmd == 'z') CGPathCloseSubpath(path);
            continue;
        }
        char *end; double v = strtod(p, &end);
        if (end == p) { p++; continue; }
        p = end; nums[n++] = v;
        int need = (cmd == 'C') ? 6 : ((cmd == 'V' || cmd == 'H') ? 1 : 2);
        if (n < need) continue;
        switch (cmd) {
            case 'M': cx = nums[0]; cy = nums[1]; CGPathMoveToPoint(path, NULL, cx, cy); cmd = 'L'; break;
            case 'L': cx = nums[0]; cy = nums[1]; CGPathAddLineToPoint(path, NULL, cx, cy); break;
            case 'C': CGPathAddCurveToPoint(path, NULL, nums[0], nums[1], nums[2], nums[3], nums[4], nums[5]); cx = nums[4]; cy = nums[5]; break;
            case 'V': cy = nums[0]; CGPathAddLineToPoint(path, NULL, cx, cy); break;
            case 'H': cx = nums[0]; CGPathAddLineToPoint(path, NULL, cx, cy); break;
            default: break;
        }
        n = 0;
    }
}

// Build the logo path scaled into a [0,S]x[0,S] box, Y-flipped for CALayer (bottom-left origin).
static CGPathRef patchgram_overlay_logo_path(CGFloat S) {
    CGMutablePathRef raw = CGPathCreateMutable();
    patchgram_svg_append(raw, PATCHGRAM_LOGO_PATH_1);
    patchgram_svg_append(raw, PATCHGRAM_LOGO_PATH_2);
    CGFloat s = S / 690.0; // viewBox is 690 wide/tall, min 190
    CGAffineTransform t = CGAffineTransformMake(s, 0, 0, -s, -190.0 * s, S + 190.0 * s);
    CGPathRef out = CGPathCreateCopyByTransformingPath(raw, &t);
    CGPathRelease(raw);
    return out;
}

static NSString *patchgram_overlay_state_path(void) {
    NSString *dir = [NSString stringWithFormat:@"%@/Library/Application Support/Patchgram", NSHomeDirectory()];
    [[NSFileManager defaultManager] createDirectoryAtPath:dir withIntermediateDirectories:YES attributes:nil error:nil];
    return [dir stringByAppendingPathComponent:@"overlay_state.plist"];
}

// Open the MTProto logger's file for this run. Target dir is the host app's Resources
// (<Telegram.app>/Contents/Resources/logs_mtproto_pg). Called from the dylib constructor,
// before main() runs, so the file exists before the first MTP packet. One file per launch,
// named log_<start time>.log; the started guard keeps it to a single file per run.
static void patchgram_mtproto_logger_start(void) {
    if (!g_mtproto_logger_enabled || g_mtproto_logger_started) {
        return;
    }
    @autoreleasepool {
        NSString *resources = [[NSBundle mainBundle] resourcePath];
        if (!resources.length) {
            NSString *bundlePath = [[NSBundle mainBundle] bundlePath];
            if (bundlePath.length) {
                resources = [bundlePath stringByAppendingPathComponent:@"Contents/Resources"];
            }
        }
        if (!resources.length) {
            patchgram_log("MTPROTO LOGGER no resources path; logger disabled this run");
            return;
        }
        NSString *dir = [resources stringByAppendingPathComponent:@"logs_mtproto_pg"];
        NSError *err = nil;
        if (![[NSFileManager defaultManager] createDirectoryAtPath:dir
                                       withIntermediateDirectories:YES
                                                        attributes:nil
                                                             error:&err]) {
            patchgram_log("MTPROTO LOGGER mkdir failed dir=%s err=%s",
                          dir.UTF8String,
                          err.localizedDescription.UTF8String ?: "?");
            return;
        }
        time_t now = time(NULL);
        struct tm tm_value;
        localtime_r(&now, &tm_value);
        char stamp[32];
        strftime(stamp, sizeof(stamp), "%Y-%m-%d_%H-%M-%S", &tm_value);
        NSString *file = [dir stringByAppendingPathComponent:
                          [NSString stringWithFormat:@"log_%s.log", stamp]];
        snprintf(g_mtproto_log_path, sizeof(g_mtproto_log_path), "%s", file.UTF8String);
        g_mtproto_logger_started = true;
        FILE *f = fopen(g_mtproto_log_path, "a");
        if (f) {
            char ts[32];
            strftime(ts, sizeof(ts), "%Y-%m-%dT%H:%M:%S", &tm_value);
            fprintf(f, "# Patchgram MTProto logger\n");
            fprintf(f, "# started %s\n", ts);
            fprintf(f, "# format: [time] DIRECTION reqId=<id> method/type#id { decoded TL body }\n");
            fclose(f);
        }
        patchgram_log("MTPROTO LOGGER started path=%s", g_mtproto_log_path);
    }
}

#if PATCHGRAM_HAVE_RLOTTIE
#include <zlib.h>
// rlottie C API — librlottie.a is linked by the apply-time compile when the static lib is bundled
// (BinaryPatchEngine adds -DPATCHGRAM_HAVE_RLOTTIE=1 + the .a + -lc++ -lz). Lets .tgs animated
// stickers (gzipped Lottie JSON) be rendered to frames for the particle effect.
typedef struct Lottie_Animation_S Lottie_Animation;
extern Lottie_Animation *lottie_animation_from_data(const char *data, const char *key, const char *resource_path);
extern void lottie_animation_destroy(Lottie_Animation *animation);
extern size_t lottie_animation_get_totalframe(const Lottie_Animation *animation);
extern double lottie_animation_get_framerate(const Lottie_Animation *animation);
extern void lottie_animation_render(Lottie_Animation *animation, size_t frame_num, uint32_t *buffer, size_t width, size_t height, size_t bytes_per_line);

// .tgs is gzip-compressed; windowBits 15+32 auto-detects the gzip wrapper.
static NSData *patchgram_gunzip(NSData *gz) {
    if (!gz.length) return nil;
    z_stream s; memset(&s, 0, sizeof(s));
    if (inflateInit2(&s, 15 + 32) != Z_OK) return nil;
    s.next_in = (Bytef *)gz.bytes; s.avail_in = (uInt)gz.length;
    NSMutableData *out = [NSMutableData dataWithLength:gz.length * 6 + 65536];
    NSUInteger total = 0; int rc;
    do {
        if (total >= out.length) [out increaseLengthBy:out.length];
        s.next_out = (Bytef *)out.mutableBytes + total;
        s.avail_out = (uInt)(out.length - total);
        rc = inflate(&s, Z_NO_FLUSH);
        total = out.length - s.avail_out;
        if (rc != Z_OK && rc != Z_STREAM_END) { inflateEnd(&s); return nil; }
    } while (rc != Z_STREAM_END);
    inflateEnd(&s);
    out.length = total;
    return out;
}

// Render a .tgs to an NSArray of CGImages (bridged). *outFps = effective playback fps after subsampling.
static NSArray *patchgram_render_tgs(NSString *path, size_t side, double *outFps) {
    NSData *json = patchgram_gunzip([NSData dataWithContentsOfFile:path]);
    if (!json.length) { patchgram_log("OVERLAY tgs: gunzip failed %s", path.UTF8String); return nil; }
    NSMutableData *cstr = [NSMutableData dataWithData:json];
    [cstr appendBytes:"\0" length:1];   // rlottie wants a NUL-terminated JSON string
    Lottie_Animation *anim = lottie_animation_from_data((const char *)cstr.bytes, path.UTF8String, "");
    if (!anim) { patchgram_log("OVERLAY tgs: parse failed %s", path.UTF8String); return nil; }
    size_t total = lottie_animation_get_totalframe(anim);
    double fr = lottie_animation_get_framerate(anim);
    if (fr <= 0) fr = 30.0;
    if (total == 0) { lottie_animation_destroy(anim); return nil; }
    size_t maxFrames = 80;
    size_t step = (total > maxFrames) ? ((total + maxFrames - 1) / maxFrames) : 1;
    size_t W = side, H = side, stride = W * 4;
    CGColorSpaceRef cs = CGColorSpaceCreateDeviceRGB();
    uint32_t *buf = (uint32_t *)malloc(stride * H);
    NSMutableArray *frames = [NSMutableArray array];
    if (buf) {
        for (size_t f = 0; f < total; f += step) {
            memset(buf, 0, stride * H);
            lottie_animation_render(anim, f, buf, W, H, stride);
            CGContextRef ctx = CGBitmapContextCreate(buf, W, H, 8, stride, cs,
                kCGImageAlphaPremultipliedFirst | kCGBitmapByteOrder32Little);
            if (ctx) {
                CGImageRef img = CGBitmapContextCreateImage(ctx);
                if (img) { [frames addObject:(__bridge id)img]; CGImageRelease(img); }
                CGContextRelease(ctx);
            }
        }
        free(buf);
    }
    CGColorSpaceRelease(cs);
    lottie_animation_destroy(anim);
    if (outFps) *outFps = fr / (double)step;
    patchgram_log("OVERLAY tgs: %lu frames (of %zu, step %zu) @%.1ffps", (unsigned long)frames.count, total, step, fr);
    return frames.count ? frames : nil;
}
#endif // PATCHGRAM_HAVE_RLOTTIE

@class PatchgramOverlay;

// Draggable circular logo button. Click (no drag) toggles the menu; drag moves the window.
@interface PatchgramLogoButton : NSView
@property (nonatomic, weak) PatchgramOverlay *overlay;
@property (nonatomic, assign) NSPoint dragOriginWin;
@property (nonatomic, assign) NSPoint dragOriginMouse;
@property (nonatomic, assign) BOOL didDrag;
@end
@implementation PatchgramLogoButton
- (instancetype)initWithFrame:(NSRect)f {
    self = [super initWithFrame:f];
    if (self) {
        self.wantsLayer = YES;
        self.layer.backgroundColor = [[NSColor colorWithWhite:0.11 alpha:0.9] CGColor];
        self.layer.cornerRadius = f.size.width / 2.0;
        self.layer.borderWidth = 1.0;
        self.layer.borderColor = [[NSColor colorWithWhite:1.0 alpha:0.18] CGColor];
        CGFloat inset = f.size.width * 0.27;
        CGFloat S = f.size.width - inset * 2.0;
        CAShapeLayer *logo = [CAShapeLayer layer];
        CGPathRef pth = patchgram_overlay_logo_path(S);
        logo.path = pth; CGPathRelease(pth);
        logo.fillColor = [[NSColor whiteColor] CGColor];
        logo.frame = CGRectMake(inset, inset, S, S);
        [self.layer addSublayer:logo];
    }
    return self;
}
- (void)mouseDown:(NSEvent *)e {
    self.dragOriginWin = self.window.frame.origin;
    self.dragOriginMouse = [NSEvent mouseLocation];
    self.didDrag = NO;
}
- (void)mouseDragged:(NSEvent *)e {
    NSPoint m = [NSEvent mouseLocation];
    CGFloat dx = m.x - self.dragOriginMouse.x, dy = m.y - self.dragOriginMouse.y;
    if (fabs(dx) > 3.0 || fabs(dy) > 3.0) self.didDrag = YES;
    [self.window setFrameOrigin:NSMakePoint(self.dragOriginWin.x + dx, self.dragOriginWin.y + dy)];
}
- (void)mouseUp:(NSEvent *)e {
    if (self.didDrag) [(id)self.overlay performSelector:@selector(buttonDidMove)];
    else [(id)self.overlay performSelector:@selector(openTapped:) withObject:nil];
}
// Deliver clicks even though our parent is a non-key, non-activating panel.
- (BOOL)acceptsFirstMouse:(NSEvent *)event { return YES; }
@end


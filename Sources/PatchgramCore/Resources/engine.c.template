@class PatchgramOverlay;
// Draggable + bottom-right-resizable frame that confines the rain. Shown only while the
// menu is open (configure mode); the rain itself renders clipped to this rect.
@interface PatchgramRegionView : NSView
@property (nonatomic, weak) PatchgramOverlay *overlay;
@property (nonatomic, assign) NSRect startFrame;
@property (nonatomic, assign) NSPoint startMouse;
@property (nonatomic, assign) BOOL resizing;
@end
@implementation PatchgramRegionView
- (instancetype)initWithFrame:(NSRect)f {
    self = [super initWithFrame:f];
    if (self) {
        self.wantsLayer = YES;
        self.layer.backgroundColor = [[NSColor colorWithWhite:1.0 alpha:0.05] CGColor];
        self.layer.borderColor = [[NSColor colorWithRed:0.30 green:0.68 blue:1.0 alpha:0.95] CGColor];
        self.layer.borderWidth = 2.0;
        self.layer.cornerRadius = 6.0;
        CALayer *grip = [CALayer layer];
        grip.name = @"grip";
        grip.backgroundColor = [[NSColor colorWithRed:0.30 green:0.68 blue:1.0 alpha:0.95] CGColor];
        grip.cornerRadius = 3.0;
        grip.frame = CGRectMake(f.size.width - 20, 6, 14, 14);
        [self.layer addSublayer:grip];
    }
    return self;
}
- (BOOL)acceptsFirstMouse:(NSEvent *)e { return YES; }
- (void)layout {
    [super layout];
    for (CALayer *l in self.layer.sublayers)
        if ([l.name isEqualToString:@"grip"]) l.frame = CGRectMake(self.bounds.size.width - 20, 6, 14, 14);
}
- (void)mouseDown:(NSEvent *)e {
    NSPoint p = [self convertPoint:e.locationInWindow fromView:nil];
    self.resizing = (p.x > self.bounds.size.width - 26 && p.y < 26);
    self.startFrame = self.window.frame;
    self.startMouse = [NSEvent mouseLocation];
}
- (void)mouseDragged:(NSEvent *)e {
    NSPoint m = [NSEvent mouseLocation];
    CGFloat dx = m.x - self.startMouse.x, dy = m.y - self.startMouse.y;
    NSRect fr = self.startFrame;
    if (self.resizing) {
        CGFloat w = MAX(90, fr.size.width + dx);
        CGFloat h = MAX(90, fr.size.height - dy);
        [self.window setFrame:NSMakeRect(fr.origin.x, fr.origin.y + (fr.size.height - h), w, h) display:YES];
    } else {
        [self.window setFrameOrigin:NSMakePoint(fr.origin.x + dx, fr.origin.y + dy)];
    }
    [(id)self.overlay performSelector:@selector(regionDidChange)];
}
- (void)mouseUp:(NSEvent *)e { [(id)self.overlay performSelector:@selector(regionDidChange)]; }
@end

